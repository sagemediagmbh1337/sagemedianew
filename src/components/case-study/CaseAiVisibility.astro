---
import Section from '../Section.astro'
import SectionHeader from '../SectionHeader.astro'

interface AiItem {
  type: 'google-aio' | 'chatgpt'
  query: string
  clientInitials: string
  clientColor?: string
  summary: string
  bulletTitle?: string
  bullets?: string[]
  sourceLabel?: string
  sourceExtra?: string
}

interface Props {
  items: AiItem[]
}

const { items } = Astro.props
---

<Section gray class="!py-20 md:!py-28">
  <SectionHeader
    eyebrow="KI-Sichtbarkeit"
    title="Sichtbar in"
    titleAccent="KI-Ergebnissen"
    subtitle="Google und ChatGPT zitieren als vertrauenswürdige Quelle – die neue Stufe der digitalen Sichtbarkeit."
  />

  <div class={`grid ${items.length === 1 ? 'max-w-2xl mx-auto' : 'md:grid-cols-2'} gap-6`}>
    {items.map((item) => (
      <div class="fade-up">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] overflow-hidden hover:border-emerald-200 hover:shadow-[0_16px_48px_rgba(16,185,129,0.08)] transition-all duration-500">

          {/* Header bar */}
          <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between bg-gray-50/60">
            <div class="flex items-center gap-2.5">
              {item.type === 'google-aio' ? (
                <>
                  <span class="text-[10px] font-mono font-bold text-amber-500 bg-amber-50 border border-amber-100 px-2 py-0.5 rounded-full flex items-center gap-1">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    AI Overview
                  </span>
                  <span class="text-[10px] font-mono text-gray-400">Google</span>
                </>
              ) : (
                <>
                  <span class="text-[10px] font-mono font-bold text-gray-600 bg-gray-100 border border-gray-200 px-2 py-0.5 rounded-full flex items-center gap-1">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="4" fill="white" /></svg>
                    ChatGPT
                  </span>
                </>
              )}
            </div>
            <div class="flex items-center gap-1.5">
              <span class={`w-5 h-5 rounded-md ${item.clientColor || 'bg-emerald-600'} text-white text-[8px] font-bold flex items-center justify-center`}>{item.clientInitials}</span>
              <span class="text-[10px] font-mono text-emerald-600 font-medium">Zitiert</span>
            </div>
          </div>

          {/* Search query */}
          <div class="px-5 pt-4 pb-3">
            <div class="flex items-center gap-2 bg-gray-50 rounded-full px-3.5 py-2 border border-gray-100">
              <svg class="w-3.5 h-3.5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" stroke-linecap="round" />
              </svg>
              <span class="text-sm text-gray-700 truncate">{item.query}</span>
            </div>
          </div>

          {/* AI Summary */}
          <div class="px-5 pb-4">
            <div class="relative bg-gradient-to-br from-gray-50 to-white rounded-xl border border-gray-100 p-4">
              {/* Sparkle icon */}
              <div class="absolute -top-2.5 -left-2">
                <span class="w-5 h-5 rounded-full bg-amber-100 border border-amber-200 flex items-center justify-center">
                  <svg class="w-3 h-3 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.2H22l-6 4.8 2.4 7.2L12 16.4 5.6 21.2 8 14 2 9.2h7.6z" /></svg>
                </span>
              </div>

              <p class="text-xs text-gray-600 leading-relaxed mt-1">{item.summary}</p>

              {/* Source attribution */}
              <div class="mt-3 flex items-center gap-2">
                <span class={`w-4 h-4 rounded-sm ${item.clientColor || 'bg-emerald-600'} text-white text-[7px] font-bold flex items-center justify-center shrink-0`}>{item.clientInitials}</span>
                <span class="text-[11px] font-semibold text-emerald-700">{item.sourceLabel || 'Als Quelle zitiert'}</span>
                {item.sourceExtra && <span class="text-[10px] text-gray-400">{item.sourceExtra}</span>}
              </div>

              {/* Bullets */}
              {item.bullets && item.bullets.length > 0 && (
                <div class="mt-3 pt-3 border-t border-gray-100">
                  {item.bulletTitle && (
                    <p class="text-[10px] font-mono font-medium uppercase tracking-wider text-gray-400 mb-2">{item.bulletTitle}</p>
                  )}
                  <ul class="space-y-1.5">
                    {item.bullets.map((b) => (
                      <li class="flex items-start gap-2 text-xs text-gray-500 leading-relaxed">
                        <span class="w-1 h-1 rounded-full bg-emerald-400 mt-1.5 shrink-0"></span>
                        {b}
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</Section>
