---
import Section from '../Section.astro'
import SectionHeader from '../SectionHeader.astro'

interface Props {
  keyword: string
  resultCount?: string
  featured: {
    url: string
    breadcrumb: string
    title: string
    description: string
    sitelinks?: string[]
  }
  competitors?: {
    url: string
    breadcrumb: string
    title: string
    description: string
  }[]
}

interface FullProps extends Props {
  sponsored?: boolean
  sectionTitle?: string
  sectionSubtitle?: string
}

const { keyword, resultCount = '1.240.000', featured, competitors = [], sponsored = false, sectionTitle, sectionSubtitle } = Astro.props as FullProps

function getInitial(url: string): string {
  try {
    const domain = url.replace(/^https?:\/\//, '').split('/')[0].replace('www.', '')
    return domain.charAt(0).toUpperCase()
  } catch {
    return 'W'
  }
}

function getDomain(url: string): string {
  try {
    return url.replace(/^https?:\/\//, '').split('/')[0]
  } catch {
    return url
  }
}

const initialColors = [
  'bg-emerald-600',
  'bg-blue-600',
  'bg-orange-500',
  'bg-rose-500',
  'bg-violet-600',
  'bg-cyan-600',
  'bg-amber-600',
]

function getColorForDomain(url: string, index: number): string {
  return initialColors[index % initialColors.length]
}
---

<Section>
  <SectionHeader
    eyebrow={sponsored ? 'Ganz oben bei Google' : 'Position 1 bei Google'}
    title={sectionTitle || 'So sieht Erfolg aus'}
    subtitle={sectionSubtitle || (sponsored ? 'Ganz oben bei Google – genau dort, wo Kunden aktiv suchen.' : 'Top-Rankings dort, wo potenzielle Kunden aktiv nach Ihren Leistungen suchen.')}
    center
  />

  <div class="max-w-3xl mx-auto fade-up">
    {/* Browser-like card wrapper */}
    <div class="rounded-2xl border border-gray-200 bg-white shadow-xl shadow-gray-200/50 overflow-hidden">

      {/* Google-style top bar */}
      <div class="bg-gray-50 border-b border-gray-200 px-5 py-3 flex items-center gap-3">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-gray-300"></span>
          <span class="w-3 h-3 rounded-full bg-gray-300"></span>
          <span class="w-3 h-3 rounded-full bg-gray-300"></span>
        </div>
        <div class="flex-1 bg-white rounded-full border border-gray-200 px-4 py-1.5 flex items-center gap-2 text-sm text-gray-400">
          <svg class="w-3.5 h-3.5 shrink-0 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
          <span class="text-gray-600 text-xs truncate">google.de/search?q={keyword.replace(/\s/g, '+')}</span>
        </div>
      </div>

      {/* Search bar area */}
      <div class="px-6 pt-6 pb-4 border-b border-gray-100">
        <div class="flex items-center gap-4 mb-4">
          {/* Google logo text */}
          <span class="text-2xl font-bold tracking-tight select-none" aria-hidden="true">
            <span class="text-blue-500">G</span><span class="text-red-500">o</span><span class="text-amber-400">o</span><span class="text-blue-500">g</span><span class="text-emerald-500">l</span><span class="text-red-500">e</span>
          </span>
        </div>
        <div class="relative max-w-lg">
          <div class="flex items-center bg-white border border-gray-300 rounded-full px-5 py-2.5 shadow-sm hover:shadow transition-shadow">
            <span class="flex-1 text-gray-950 text-sm font-normal">{keyword}</span>
            <svg class="w-5 h-5 text-blue-500 shrink-0 ml-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-3">Ungef&auml;hr {resultCount} Ergebnisse</p>
      </div>

      {/* Search results */}
      <div class="px-6 py-5 space-y-6">

        {/* Featured result — Position 1 */}
        <div class="relative group">
          {/* Position badge */}
          <div class="absolute -top-2.5 -left-2 z-10">
            {sponsored ? (
              <span class="inline-flex items-center gap-1 bg-blue-600 text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full shadow-md shadow-blue-600/30">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round" /></svg>
                Gesponsert
              </span>
            ) : (
              <span class="inline-flex items-center gap-1 bg-emerald-500 text-white text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full shadow-md shadow-emerald-500/30">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                Position 1
              </span>
            )}
          </div>

          <div class={`border-2 rounded-xl p-5 pt-6 ${sponsored ? 'border-blue-200 bg-blue-50/30' : 'border-emerald-200 bg-emerald-50/30'}`}>
            {/* URL line */}
            <div class="flex items-center gap-2.5 mb-1">
              <span class={`w-6 h-6 rounded-full ${getColorForDomain(featured.url, 0)} text-white text-xs font-bold flex items-center justify-center shrink-0`}>
                {getInitial(featured.url)}
              </span>
              <div class="min-w-0">
                <p class="text-sm text-gray-950 truncate">{getDomain(featured.url)}</p>
                <p class="text-xs text-emerald-700 truncate">{featured.breadcrumb}</p>
              </div>
            </div>

            {/* Title */}
            <h3 class="text-xl text-blue-700 hover:underline cursor-pointer leading-snug mt-2 font-medium">
              {featured.title}
            </h3>

            {/* Description */}
            <p class="text-sm text-gray-600 leading-relaxed mt-1.5 line-clamp-2">
              {featured.description}
            </p>

            {/* Sitelinks */}
            {featured.sitelinks && featured.sitelinks.length > 0 && (
              <div class="flex flex-wrap gap-x-4 gap-y-1.5 mt-3 pt-3 border-t border-emerald-200/60">
                {featured.sitelinks.map((link) => (
                  <span class="text-sm text-blue-600 hover:underline cursor-pointer">{link}</span>
                ))}
              </div>
            )}
          </div>
        </div>

        {/* Competitor results */}
        {competitors.map((comp, i) => (
          <div class="opacity-50 pl-1">
            <div class="flex items-center gap-2.5 mb-1">
              <span class={`w-6 h-6 rounded-full ${getColorForDomain(comp.url, i + 1)} text-white text-xs font-bold flex items-center justify-center shrink-0`}>
                {getInitial(comp.url)}
              </span>
              <div class="min-w-0">
                <p class="text-sm text-gray-950 truncate">{getDomain(comp.url)}</p>
                <p class="text-xs text-gray-500 truncate">{comp.breadcrumb}</p>
              </div>
            </div>
            <h3 class="text-lg text-blue-800/70 leading-snug mt-1 font-medium">{comp.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed mt-1 line-clamp-2">{comp.description}</p>
          </div>
        ))}

        {/* Fade-out gradient at bottom */}
        <div class="h-8 bg-gradient-to-t from-white to-transparent -mb-5 -mx-6 px-6"></div>
      </div>
    </div>
  </div>
</Section>
