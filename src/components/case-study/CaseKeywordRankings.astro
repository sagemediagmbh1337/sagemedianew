---
import Section from '../Section.astro'
import SectionHeader from '../SectionHeader.astro'

interface Props {
  description?: string
  keywords: {
    keyword: string
    before: string
    after: string
    change: string
  }[]
}

const { description, keywords } = Astro.props
---

<Section gray>
  <SectionHeader eyebrow="Keyword Rankings" title="Von nicht existent zu" titleAccent="Position 1" />

  {description && (
    <p class="text-gray-500 text-lg leading-relaxed max-w-2xl mb-12 -mt-12 fade-up">{description}</p>
  )}

  <!-- Label -->
  <div class="flex items-center gap-3 mb-6 fade-up">
    <span class="inline-block w-5 h-px bg-gray-300"></span>
    <span class="text-[11px] font-mono font-medium uppercase tracking-[0.15em] text-gray-400">Auszug der Suchbegriffe</span>
  </div>

  <!-- Desktop table -->
  <div class="hidden md:block fade-up">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] overflow-hidden">
      <!-- Header row -->
      <div class="grid grid-cols-[1fr_120px_120px_140px] gap-4 px-8 py-4 border-b border-gray-100 bg-gray-50/60">
        <span class="text-xs font-mono font-medium uppercase tracking-[0.15em] text-gray-400">Keyword</span>
        <span class="text-xs font-mono font-medium uppercase tracking-[0.15em] text-gray-400 text-center">Vorher</span>
        <span class="text-xs font-mono font-medium uppercase tracking-[0.15em] text-gray-400 text-center">Nachher</span>
        <span class="text-xs font-mono font-medium uppercase tracking-[0.15em] text-gray-400 text-center">Veränderung</span>
      </div>

      <!-- Data rows -->
      {keywords.map((kw, i) => (
        <div
          class={`grid grid-cols-[1fr_120px_120px_140px] gap-4 px-8 py-5 items-center transition-colors hover:bg-emerald-50/30 fade-up ${i < keywords.length - 1 ? 'border-b border-gray-50' : ''}`}
        >
          <span class="font-semibold text-gray-900">{kw.keyword}</span>
          <span class="font-mono text-sm text-gray-400 text-center">{kw.before}</span>
          <span class="font-mono text-sm font-bold text-emerald-600 text-center">{kw.after}</span>
          <div class="flex justify-center">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold font-mono bg-emerald-50 text-emerald-700 border border-emerald-100">
              {kw.change}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Mobile cards -->
  <div class="md:hidden space-y-3">
    {keywords.map((kw) => (
      <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] p-5 fade-up">
        <div class="flex items-center justify-between mb-4">
          <span class="font-semibold text-gray-900 text-sm">{kw.keyword}</span>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-bold font-mono bg-emerald-50 text-emerald-700 border border-emerald-100">
            {kw.change}
          </span>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <span class="text-[10px] font-mono uppercase tracking-wider text-gray-400 block mb-1">Vorher</span>
            <span class="font-mono text-sm text-gray-400">{kw.before}</span>
          </div>
          <div>
            <span class="text-[10px] font-mono uppercase tracking-wider text-gray-400 block mb-1">Nachher</span>
            <span class="font-mono text-sm font-bold text-emerald-600">{kw.after}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</Section>
