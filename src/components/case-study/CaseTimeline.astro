---
import Section from '../Section.astro'
import SectionHeader from '../SectionHeader.astro'

interface Step {
  date: string
  title: string
  description?: string
  isCurrent?: boolean
}

interface Props {
  steps: Step[]
}

const { steps } = Astro.props
---

<Section gray class="!py-20 md:!py-28">
  <SectionHeader eyebrow="Timeline" title="Der Weg zum" titleAccent="Ergebnis" />

  <!-- Desktop: horizontal -->
  <div class="hidden md:block overflow-x-auto fade-up">
    <div class="relative min-w-max">
      <!-- Connecting line -->
      <div class="absolute top-[18px] left-8 right-8 h-px bg-gradient-to-r from-emerald-200 via-emerald-300 to-emerald-200"></div>

      <div class="grid gap-0" style={`grid-template-columns: repeat(${steps.length}, minmax(180px, 1fr));`}>
        {steps.map((step) => (
          <div class="relative px-4 pt-0 pb-2">
            <!-- Dot -->
            <div class="relative z-10 flex justify-center mb-5">
              <div class={`w-4 h-4 rounded-full border-4 border-white ${step.isCurrent ? 'bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.5)]' : 'bg-emerald-300'}`}></div>
            </div>
            <!-- Content -->
            <div class="text-center">
              <span class="text-[10px] font-mono text-emerald-600 uppercase tracking-wider bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full">{step.date}</span>
              <h4 class="mt-3 text-sm font-bold text-gray-900">{step.title}</h4>
              {step.description && (
                <p class="mt-1.5 text-xs text-gray-500 leading-relaxed">{step.description}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Mobile: vertical compact -->
  <div class="md:hidden fade-up">
    <div class="relative pl-8">
      <!-- Vertical line -->
      <div class="absolute left-[7px] top-2 bottom-2 w-px bg-gradient-to-b from-emerald-200 via-emerald-300 to-emerald-200"></div>

      <div class="space-y-6">
        {steps.map((step) => (
          <div class="relative">
            <!-- Dot -->
            <div class={`absolute -left-8 top-1 w-4 h-4 rounded-full border-4 border-gray-50 ${step.isCurrent ? 'bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.5)]' : 'bg-emerald-300'}`}></div>
            <!-- Content -->
            <div>
              <span class="text-[10px] font-mono text-emerald-600 uppercase tracking-wider bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full">{step.date}</span>
              <h4 class="mt-2 text-sm font-bold text-gray-900">{step.title}</h4>
              {step.description && (
                <p class="mt-1 text-xs text-gray-500 leading-relaxed">{step.description}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Section>
