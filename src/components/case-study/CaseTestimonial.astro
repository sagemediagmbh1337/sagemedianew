---
import Section from '../Section.astro'

interface Props {
  quote: string
  author: string
  role: string
  image?: string
}

const { quote, author, role, image } = Astro.props
---

<Section gray class="!py-20 md:!py-28">
  <div class="max-w-3xl mx-auto text-center fade-up">
    <!-- Quote marks -->
    <svg class="w-12 h-12 mx-auto mb-8 text-emerald-500/30" viewBox="0 0 48 48" fill="currentColor">
      <path d="M12 22c-1.1 0-2-.4-2.8-1.2C8.4 20 8 19.1 8 18V8h12v10c0 3.3-1.2 6.1-3.5 8.5C14.2 28.8 11.5 30.3 8 31l-1-4c2.1-.4 3.8-1.3 5-2.5C13.3 23.3 13.7 22 13 22h-1zm20 0c-1.1 0-2-.4-2.8-1.2C28.4 20 28 19.1 28 18V8h12v10c0 3.3-1.2 6.1-3.5 8.5C34.2 28.8 31.5 30.3 28 31l-1-4c2.1-.4 3.8-1.3 5-2.5C33.3 23.3 33.7 22 33 22h-1z" />
    </svg>

    <blockquote class="text-2xl md:text-3xl font-medium italic leading-relaxed text-gray-800">
      &ldquo;{quote}&rdquo;
    </blockquote>

    <div class="mt-10 flex items-center justify-center gap-4">
      {image && (
        <img src={image} alt={author} class="w-12 h-12 rounded-full object-cover border-2 border-emerald-100" />
      )}
      <div class={image ? 'text-left' : ''}>
        <p class="font-bold text-gray-900">{author}</p>
        <p class="text-sm text-gray-500">{role}</p>
      </div>
    </div>
  </div>
</Section>
