---
import Section from '../Section.astro'
import SectionHeader from '../SectionHeader.astro'

interface Props {
  invested: string
  conversions: string
  avgOrderValue: string
  avgOrderLabel?: string
  potentialRevenue: string
  revenueFormula?: string
  roas?: string
  costPerConversion?: string
  conversionsPerMonth?: string
}

const {
  invested,
  conversions,
  avgOrderValue,
  avgOrderLabel = 'Ø Auftragswert',
  potentialRevenue,
  revenueFormula,
  roas,
  costPerConversion,
  conversionsPerMonth,
} = Astro.props
---

<Section class="!py-20 md:!py-28">
  <SectionHeader eyebrow="ROI" title="Was das unterm Strich" titleAccent="bedeutet" center subtitle="Eine einfache Rechnung zeigt, warum sich Google Ads lohnt." />

  <div class="max-w-3xl mx-auto">
    <!-- Input row -->
    <div class="grid md:grid-cols-3 gap-4 mb-6 fade-up">
      <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] p-6 text-center">
        <p class="text-xs font-mono text-gray-400 uppercase tracking-wider mb-2">Werbebudget investiert</p>
        <p class="text-2xl md:text-3xl font-extrabold text-gray-900 tracking-tight">{invested}</p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] p-6 text-center">
        <p class="text-xs font-mono text-gray-400 uppercase tracking-wider mb-2">Qualifizierte Anfragen</p>
        <p class="text-2xl md:text-3xl font-extrabold text-gray-900 tracking-tight">{conversions}</p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] p-6 text-center">
        <p class="text-xs font-mono text-gray-400 uppercase tracking-wider mb-2">{avgOrderLabel}</p>
        <p class="text-2xl md:text-3xl font-extrabold text-gray-900 tracking-tight">{avgOrderValue}</p>
      </div>
    </div>

    <!-- Arrow -->
    <div class="flex justify-center my-4 fade-up">
      <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M5 9l7 7 7-7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>

    <!-- Result -->
    <div class="bg-gradient-to-br from-emerald-50 to-white rounded-2xl border-2 border-emerald-200 shadow-[0_8px_32px_rgba(16,185,129,0.1)] p-8 text-center fade-up">
      <p class="text-xs font-mono text-emerald-600 uppercase tracking-wider mb-3">Potenzielles Auftragsvolumen</p>
      <p class="text-4xl md:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-emerald-600 to-emerald-400 bg-clip-text text-transparent">{potentialRevenue}</p>
      {revenueFormula && (
        <p class="mt-2 text-sm text-gray-500">{revenueFormula}</p>
      )}
    </div>

    <!-- Bottom stats -->
    {(roas || costPerConversion || conversionsPerMonth) && (
      <div class="grid grid-cols-3 gap-4 mt-6 fade-up">
        {roas && (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] p-5 text-center">
            <p class="text-2xl font-extrabold text-emerald-600 tracking-tight">{roas}</p>
            <p class="mt-1 text-[10px] font-mono text-gray-400 uppercase tracking-wider">Return on Ad Spend</p>
          </div>
        )}
        {costPerConversion && (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] p-5 text-center">
            <p class="text-2xl font-extrabold text-gray-900 tracking-tight">{costPerConversion}</p>
            <p class="mt-1 text-[10px] font-mono text-gray-400 uppercase tracking-wider">Kosten pro Anfrage</p>
          </div>
        )}
        {conversionsPerMonth && (
          <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] p-5 text-center">
            <p class="text-2xl font-extrabold text-gray-900 tracking-tight">{conversionsPerMonth}</p>
            <p class="mt-1 text-[10px] font-mono text-gray-400 uppercase tracking-wider">Anfragen pro Monat</p>
          </div>
        )}
      </div>
    )}
  </div>
</Section>
