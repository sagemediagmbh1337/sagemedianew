---
import Section from '../Section.astro'
import SectionHeader from '../SectionHeader.astro'

interface Props {
  phases: {
    phase: string
    title: string
    description: string
    query?: string
  }[]
  stats?: {
    label: string
    value: string
  }[]
}

const { phases, stats } = Astro.props
---

<Section class="!py-20 md:!py-28">
  <SectionHeader eyebrow="Die Customer Journey" title="Von der ersten Frage" titleAccent="bis zum Lead" />

  {/* Phases pipeline */}
  <div class="relative flex flex-col lg:flex-row gap-6 lg:gap-0">
    {phases.map((item, i) => (
      <div class="flex flex-col lg:flex-row items-stretch flex-1 fade-up">
        {/* Phase card */}
        <div class="relative bg-white rounded-2xl p-7 border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] hover:border-emerald-200 hover:shadow-[0_16px_48px_rgba(16,185,129,0.08)] transition-all duration-500 card-lift flex-1 flex flex-col">
          <span class="text-[11px] font-mono font-medium uppercase tracking-[0.15em] text-emerald-600 mb-3">{item.phase}</span>
          <h3 class="text-lg font-bold text-gray-900 tracking-tight mb-2">{item.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed mb-4 flex-1">{item.description}</p>
          {item.query && (
            <div class="flex items-center gap-2.5 bg-gray-50 rounded-full px-4 py-2.5 border border-gray-100">
              <svg class="w-4 h-4 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" stroke-linecap="round" />
              </svg>
              <span class="text-sm italic text-gray-500 truncate">{item.query}</span>
            </div>
          )}
        </div>

        {/* Arrow connector */}
        {i < phases.length - 1 && (
          <>
            {/* Desktop arrow */}
            <div class="hidden lg:flex items-center justify-center w-10 shrink-0">
              <svg class="w-6 h-6 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            {/* Mobile arrow */}
            <div class="flex lg:hidden items-center justify-center h-8 shrink-0">
              <svg class="w-6 h-6 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M5 9l7 7 7-7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          </>
        )}
      </div>
    ))}
  </div>

  {/* Stats row */}
  {stats && stats.length > 0 && (
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mt-14 fade-up">
      {stats.map((stat) => (
        <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] text-center hover:border-emerald-200 transition-colors duration-300">
          <span class="block text-2xl md:text-3xl font-extrabold text-gray-900 tracking-tight">{stat.value}</span>
          <span class="block mt-1 text-xs font-mono font-medium uppercase tracking-[0.15em] text-gray-400">{stat.label}</span>
        </div>
      ))}
    </div>
  )}
</Section>
