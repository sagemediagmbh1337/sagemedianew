---
import Section from '../Section.astro'
import SectionHeader from '../SectionHeader.astro'

interface Item {
  title: string
  description: string
}

interface Props {
  eyebrow: string
  heading: string
  items: Item[]
  variant?: 'light' | 'gray'
}

const { eyebrow, heading, items, variant = 'light' } = Astro.props
---

<Section gray={variant === 'gray'} class="!py-20 md:!py-28">
  <SectionHeader eyebrow={eyebrow} title={heading} />

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
    {items.map((item, i) => (
      <div class="relative bg-white rounded-2xl p-8 border border-gray-100 shadow-[0_4px_24px_rgba(0,0,0,0.03)] hover:border-emerald-200 hover:shadow-[0_16px_48px_rgba(16,185,129,0.08)] transition-all duration-500 card-lift fade-up">
        <div class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center mb-5">
          <span class="text-xs font-mono font-bold text-emerald-600">{String(i + 1).padStart(2, '0')}</span>
        </div>
        <h3 class="text-lg font-bold text-gray-900 tracking-tight mb-3">{item.title}</h3>
        <p class="text-gray-500 leading-relaxed">{item.description}</p>
      </div>
    ))}
  </div>
</Section>
