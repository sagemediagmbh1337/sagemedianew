---
interface CaseCard {
  slug: string
  company: string
  industry: string
  tags: string[]
  kpis: { value: string; label: string }[]
}

interface Props {
  eyebrow?: string
  title?: string
  titleAccent?: string
  subtitle?: string
  cases: CaseCard[]
  basePath?: string
}

const {
  eyebrow = 'Projekte',
  title = 'Echte Kunden.',
  titleAccent = ' Echte Zahlen.',
  subtitle = '',
  cases,
  basePath = '/v2/ergebnisse',
} = Astro.props
---

<section class="relative py-32 md:py-44 overflow-hidden" id="cases">
  <div class="absolute top-[15%] right-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>

  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-block w-8 h-px bg-emerald-500"></span>
          <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">{eyebrow}</span>
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.04em] text-gray-950">
          {title}
          <span class="bg-gradient-to-r from-emerald-600 to-emerald-400 bg-clip-text text-transparent">{titleAccent}</span>
        </h2>
      </div>
      {subtitle && <p class="text-gray-500 leading-relaxed max-w-sm">{subtitle}</p>}
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {cases.map((c) => (
        <a
          href={`${basePath}/${c.slug}`}
          class="group relative block rounded-2xl border border-gray-100 hover:border-emerald-200 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_20px_60px_-12px_rgba(16,185,129,0.12)] bg-white overflow-hidden"
        >
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style="background: radial-gradient(circle at 0% 0%, rgba(16,185,129,0.04) 0%, transparent 50%);"></div>

          <div class="relative p-8">
            <!-- Industry + Link -->
            <div class="flex items-center justify-between mb-6">
              <span class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold text-emerald-700 bg-emerald-50 border border-emerald-100">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                {c.industry}
              </span>
              <span class="flex items-center gap-1.5 text-xs font-medium text-gray-300 group-hover:text-emerald-600 transition-colors">
                Case Study
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </span>
            </div>

            <!-- Company -->
            <h3 class="text-2xl font-extrabold text-gray-900 tracking-tight mb-6 group-hover:text-emerald-700 transition-colors">{c.company}</h3>

            <!-- Hero Metric -->
            <div class="mb-8">
              <span class="text-4xl md:text-5xl font-extrabold tracking-tight text-gray-950">{c.kpis[0].value}</span>
              <p class="text-sm text-gray-500 mt-1.5">{c.kpis[0].label}</p>
            </div>

            <!-- Secondary Metrics + Tags -->
            <div class="flex items-center gap-8 pt-6 border-t border-gray-100">
              {c.kpis[1] && (
                <div>
                  <span class="text-xl font-extrabold text-gray-900">{c.kpis[1].value}</span>
                  <p class="text-xs text-gray-500 mt-1">{c.kpis[1].label}</p>
                </div>
              )}
              {c.kpis[2] && (
                <>
                  <div class="w-px h-10 bg-gray-100"></div>
                  <div>
                    <span class="text-xl font-extrabold text-gray-900">{c.kpis[2].value}</span>
                    <p class="text-xs text-gray-500 mt-1">{c.kpis[2].label}</p>
                  </div>
                </>
              )}
              <div class="ml-auto flex gap-2">
                {c.tags.map((tag) => (
                  <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium text-gray-500 bg-gray-50">{tag}</span>
                ))}
              </div>
            </div>

            <!-- CTA Button -->
            <div class="mt-8">
              <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold bg-gray-950 text-white group-hover:bg-emerald-600 transition-colors duration-300">
                Case ansehen
                <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
