---
interface BranchFact {
  label: string
  value: string
}

interface Props {
  branch: string
  branchFacts: BranchFact[]
}

const { branch, branchFacts } = Astro.props
---

<div class="relative">
  <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>
  <div class="absolute -inset-6 rounded-[2rem] border border-emerald-500/10 animate-pulse"></div>
  <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
        <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-[0.2em]">{branch}</span>
      </div>
      <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">Branchenexklusiv</span>
    </div>
    <div class="grid grid-cols-2 gap-3 mb-6">
      {branchFacts.map(fact => (
        <div class="p-3 bg-gray-50/80 rounded-xl border border-gray-100">
          <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-400 mb-0.5">{fact.label}</p>
          <p class="text-sm font-extrabold text-gray-900">{fact.value}</p>
        </div>
      ))}
    </div>
    <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>
    <div class="grid grid-cols-3 gap-4">
      <div><p class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-400 mb-1">Rankings</p><p class="text-lg font-extrabold text-gray-900 tracking-tight">100k+</p></div>
      <div><p class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-400 mb-1">Bewertung</p><p class="text-lg font-extrabold text-emerald-600 tracking-tight">5.0</p></div>
      <div><p class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-400 mb-1">Exklusiv</p><p class="text-lg font-extrabold text-gray-900 tracking-tight">1/Region</p></div>
    </div>
  </div>
  <div class="absolute -bottom-5 -left-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3 hero-badge">
    <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_16px_rgba(16,185,129,0.4)]">
      <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" /></svg>
    </div>
    <div><p class="text-xs font-bold text-gray-900">{branch}</p><p class="text-[10px] text-gray-400">Branchenexklusiv</p></div>
  </div>
</div>
