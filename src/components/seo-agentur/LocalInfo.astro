---
import Section from '../Section.astro'

interface Props {
  city: string
  region: string
  industries: string[]
  nearbyAreas: string[]
}

const { city, region, industries, nearbyAreas } = Astro.props
---

<Section>
  <div class="grid lg:grid-cols-2 gap-8">
    <!-- Branchen -->
    <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-[0_4px_24px_rgba(0,0,0,0.03)] card-lift fade-up">
      <div class="flex items-center gap-3 mb-6 pb-5 border-b border-gray-100">
        <div class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" /></svg>
        </div>
        <div>
          <h3 class="text-base font-bold text-gray-900 tracking-tight">Starke Branchen in {city}</h3>
          <p class="text-sm text-gray-500 mt-0.5">Branchen mit SEO-Potenzial</p>
        </div>
      </div>
      <div class="space-y-0">
        {industries.map((industry, i) => (
          <div class={`flex items-center gap-4 py-3 ${i < industries.length - 1 ? 'border-b border-gray-100' : ''}`}>
            <div class="shrink-0 w-6 h-6 rounded-full bg-emerald-50 border border-emerald-100 flex items-center justify-center">
              <span class="text-[10px] font-mono font-bold text-emerald-600">0{i + 1}</span>
            </div>
            <span class="text-sm font-medium text-gray-700">{industry}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Umland -->
    <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-[0_4px_24px_rgba(0,0,0,0.03)] card-lift fade-up">
      <div class="flex items-center gap-3 mb-6 pb-5 border-b border-gray-100">
        <div class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center">
          <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
        </div>
        <div>
          <h3 class="text-base font-bold text-gray-900 tracking-tight">{city} & Umgebung</h3>
          <p class="text-sm text-gray-500 mt-0.5">Regionale SEO-Abdeckung</p>
        </div>
      </div>
      <div class="flex flex-wrap gap-2">
        {nearbyAreas.map(area => (
          <span class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-sm font-medium border border-gray-200 text-gray-600">
            <svg class="w-3 h-3 text-emerald-500/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
            {area}
          </span>
        ))}
      </div>
      <p class="mt-5 text-sm text-gray-500 leading-relaxed">Wir optimieren nicht nur für {city}, sondern für die gesamte Region {region}. Lokale Sichtbarkeit endet nicht an der Stadtgrenze.</p>
    </div>
  </div>
</Section>
