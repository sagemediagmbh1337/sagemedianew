---
interface Keyword {
  keyword: string
  volume: string
  difficulty?: 'niedrig' | 'mittel' | 'hoch'
}

interface Props {
  city: string
  keywords: Keyword[]
  eyebrow?: string
  heading?: string
  headingAccent?: string
  subtitle?: string
}

const { city, keywords, eyebrow, heading, headingAccent, subtitle } = Astro.props
const _eyebrow = eyebrow || `Suchvolumen ${city}`
const _heading = heading || 'So suchen Kunden'
const _accent = headingAccent || ` in ${city}`
const _subtitle = subtitle || `Echte Suchvolumen aus ${city}. Diese Keywords zeigen, wie viele potenzielle Kunden jeden Monat nach lokalen Angeboten suchen.`

const colors: Record<string, string> = {
  niedrig: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
  mittel: 'text-amber-400 bg-amber-400/10 border-amber-400/20',
  hoch: 'text-red-400 bg-red-500/10 border-red-500/20',
}
---

<section class="relative py-28 md:py-36 bg-gray-950 text-white overflow-hidden noise-bg">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent divider-glow"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/20 to-transparent"></div>
  <div class="absolute top-[15%] right-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.1) 0%, transparent 60%);"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16 fade-up">
      <div>
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-block w-8 h-px bg-emerald-400"></span>
          <span class="text-xs font-mono font-medium text-emerald-400 uppercase tracking-[0.2em]">{_eyebrow}</span>
        </div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-[1.1] tracking-[-0.04em]">
          {_heading}<span class="bg-gradient-to-r from-emerald-300 to-emerald-500 bg-clip-text text-transparent">{_accent}</span>
        </h2>
      </div>
      <p class="text-gray-400 leading-relaxed max-w-md">{_subtitle}</p>
    </div>

    <div class="space-y-0 fade-up">
      <div class="hidden md:grid md:grid-cols-[1fr_120px_100px] gap-4 px-6 py-3 mb-2">
        <span class="text-[10px] font-mono font-bold text-gray-500 uppercase tracking-[0.2em]">Keyword</span>
        <span class="text-[10px] font-mono font-bold text-gray-500 uppercase tracking-[0.2em] text-right">Suchvolumen</span>
        <span class="text-[10px] font-mono font-bold text-gray-500 uppercase tracking-[0.2em] text-right">Wettbewerb</span>
      </div>

      {keywords.map((kw, i) => (
        <div class={`md:grid md:grid-cols-[1fr_120px_100px] gap-4 items-center px-6 py-4 rounded-xl bg-white/[0.03] border border-white/[0.06] hover:bg-white/[0.06] transition-all duration-300 fade-up ${i > 0 ? 'mt-2' : ''}`}>
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 text-emerald-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
            <span class="text-sm font-semibold text-white">{kw.keyword}</span>
          </div>
          <div class="text-right mt-2 md:mt-0">
            <span class="text-sm font-extrabold text-white">{kw.volume}</span>
            <span class="text-xs text-gray-500 ml-1">/Monat</span>
          </div>
          <div class="text-right mt-1 md:mt-0">
            <span class={`inline-flex px-2.5 py-1 rounded-full text-[10px] font-mono font-bold uppercase tracking-[0.2em] border ${colors[kw.difficulty || 'mittel']}`}>{kw.difficulty || 'mittel'}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
