---
import Section from '../Section.astro'
import SectionHeader from '../SectionHeader.astro'

interface Step {
  step: string
  text: string
}

interface Props {
  city: string
  heading: string
  text: string
  steps: Step[]
  eyebrow?: string
  title?: string
  titleAccent?: string
}

const { city, heading, text, steps, eyebrow, title, titleAccent } = Astro.props
---

<Section gray>
  <SectionHeader
    eyebrow={eyebrow || `Kundenreise ${city}`}
    title={title || 'So finden Kunden dein'}
    titleAccent={titleAccent || ` Unternehmen in ${city}`}
    subtitle={text}
  />

  <div class="mt-16 relative">
    <!-- Vertical Line -->
    <div class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-emerald-300 via-emerald-500 to-emerald-300 hidden md:block"></div>
    <div class="absolute left-6 top-0 bottom-0 w-px bg-gradient-to-b from-emerald-300 via-emerald-500 to-emerald-300 md:hidden"></div>

    <div class="space-y-8 md:space-y-12">
      {steps.map((item, i) => {
        const isLeft = i % 2 === 0
        return (
          <div class={`relative flex items-start gap-6 md:gap-0 fade-up ${isLeft ? '' : 'md:flex-row-reverse'}`}>
            <!-- Dot -->
            <div class="absolute left-6 md:left-1/2 -translate-x-1/2 w-12 h-12 rounded-full bg-white border-2 border-emerald-500 flex items-center justify-center z-10 shadow-[0_0_24px_rgba(16,185,129,0.2)]">
              <span class="text-xs font-mono font-bold text-emerald-600">0{i + 1}</span>
            </div>

            <!-- Spacer for mobile -->
            <div class="w-12 shrink-0 md:hidden"></div>

            <!-- Content -->
            <div class={`md:w-[calc(50%-3rem)] ${isLeft ? 'md:pr-8 md:text-right' : 'md:pl-8'}`}>
              <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-[0_4px_24px_rgba(0,0,0,0.03)] card-lift">
                <p class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em] mb-2">{item.step}</p>
                <p class="text-sm text-gray-600 leading-relaxed">{item.text}</p>
              </div>
            </div>

            <!-- Empty half for desktop alignment -->
            <div class="hidden md:block md:w-[calc(50%-3rem)]"></div>
          </div>
        )
      })}
    </div>
  </div>
</Section>
