---
interface Props {
  class?: string
}

const { class: className = '' } = Astro.props
---

<div class={`flex items-center gap-6 flex-wrap ${className}`}>
  <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-400">Bekannt aus</span>
  <div class="h-4 w-px bg-gray-300"></div>
  <div class="flex items-center gap-6 flex-wrap">
    <img src="/images/press/radioeins.png" alt="radioeins" class="h-4 opacity-40 hover:opacity-70 transition-opacity invert" loading="lazy" />
    <img src="/images/press/fraenkischer-tag.png" alt="Fränkischer Tag" class="h-4 opacity-40 hover:opacity-70 transition-opacity invert" loading="lazy" />
    <img src="/images/press/gruenderde.png" alt="Gründer.de" class="h-4 opacity-40 hover:opacity-70 transition-opacity invert" loading="lazy" />
    <img src="/images/press/infranken.png" alt="inFranken" class="h-4 opacity-40 hover:opacity-70 transition-opacity invert" loading="lazy" />
    <img src="/images/press/dim.png" alt="DIM" class="h-4 opacity-40 hover:opacity-70 transition-opacity invert" loading="lazy" />
    <img src="/images/press/ihk.jpg" alt="IHK für Oberfranken" class="h-5 opacity-40 hover:opacity-70 transition-opacity" loading="lazy" />
  </div>
</div>
