<!-- ════════════════════════════════════════════
     ORGANIC OVATION (Dark Section)
════════════════════════════════════════════ -->
<section class="relative py-32 md:py-44 bg-gray-950 text-white overflow-hidden noise-bg" id="organic-ovation">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent divider-glow"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>
  <div class="absolute top-[5%] left-[20%] w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.12) 0%, rgba(16,185,129,0.03) 50%, transparent 70%);"></div>
  <div class="absolute bottom-[10%] right-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.08) 0%, transparent 60%);"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Text -->
      <div class="lg:col-span-7 fade-up">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-block w-8 h-px bg-emerald-400"></span>
          <span class="text-xs font-mono font-medium text-emerald-400 uppercase tracking-[0.2em]">Unsere Methodik</span>
        </div>

        <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.04em]">
          <span class="text-white">Organic</span>
          <span class="bg-gradient-to-r from-emerald-300 via-emerald-400 to-emerald-500 bg-clip-text text-transparent"> Ovation</span>
        </h2>

        <p class="mt-6 text-lg text-gray-300 leading-relaxed max-w-2xl">
          Organic Ovation ist die proprietäre SEO-Methodik der sagemedia GmbH, entwickelt über 15 Jahre praktische Erfahrung mit Suchmaschinenoptimierung, validiert durch den Gewinn des deutschen SEO-Contests 2021 und verfeinert durch hundertausende erzielte Top-Rankings in Google, Bing und zunehmend auch in KI-gestützten Suchsystemen.
        </p>
        <p class="mt-4 text-lg text-gray-300 leading-relaxed max-w-2xl">
          Die Methodik verbindet technisches SEO, semantische Content-Architektur, strategischen Linkaufbau und datengetriebene Entscheidungsfindung zu einem ganzheitlichen System. Kein Template-Ansatz, jede Strategie wird individuell auf Branche, Wettbewerb und Geschäftsmodell zugeschnitten.
        </p>
      </div>

      <!-- Trophy -->
      <div class="lg:col-span-5 fade-up">
        <div class="relative flex justify-center">
          <!-- Glow behind trophy -->
          <div class="absolute -inset-8 rounded-full" style="background: radial-gradient(ellipse at 50% 60%, rgba(16,185,129,0.18) 0%, rgba(16,185,129,0.04) 50%, transparent 70%);"></div>
          <!-- Subtle reflection line -->
          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>
          <img
            src="/images/awards/sagemedia-pokal-contest.jpg"
            alt="SEO-Contest 2021, 1. Platz Pokal"
            class="relative w-56 md:w-64 rounded-2xl shadow-[0_32px_80px_-16px_rgba(0,0,0,0.5)] ring-1 ring-white/[0.06]"
            loading="lazy"
          />
          <!-- Caption badge -->
          <div class="absolute -bottom-5 left-1/2 -translate-x-1/2 bg-gradient-to-r from-emerald-500 to-emerald-400 rounded-full px-5 py-2 whitespace-nowrap shadow-[0_8px_24px_rgba(16,185,129,0.4)]">
            <div class="flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 010-5H6" /><path d="M18 9h1.5a2.5 2.5 0 000-5H18" /><path d="M4 22h16" /><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22" /><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22" /><path d="M18 2H6v7a6 6 0 0012 0V2z" /></svg>
              <span class="text-xs font-bold text-white tracking-wide">1. Platz, SEO-Contest 2021</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="mt-20 grid sm:grid-cols-3 gap-px rounded-2xl overflow-hidden fade-up" style="background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(255,255,255,0.03));">
      {[
        { target: '2021', suffix: '', label: 'Contest-Gewinner', noFormat: true },
        { target: '648', suffix: '%', label: 'Ø Wachstum' },
        { target: '15', suffix: '+', label: 'Jahre Entwicklung' },
      ].map((s) => (
        <div class="relative bg-gray-950/90 backdrop-blur-sm p-10 text-center group hover:bg-emerald-950/50 transition-all duration-500 overflow-hidden">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 100%, rgba(16,185,129,0.1) 0%, transparent 70%);"></div>
          <div class="relative">
            <div class="flex items-baseline justify-center gap-1">
              <span class={`text-5xl md:text-6xl font-extrabold tracking-tight text-white counter`} data-target={s.target} data-no-format={s.noFormat ? 'true' : undefined}>{s.target}</span>
              {s.suffix && <span class="text-2xl font-extrabold bg-gradient-to-r from-emerald-300 to-emerald-500 bg-clip-text text-transparent">{s.suffix}</span>}
            </div>
            <p class="mt-3 text-sm text-gray-400 font-mono uppercase tracking-wider">{s.label}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Method Steps -->
    <div class="mt-24 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { step: '01', title: 'Analyse & Audit', desc: 'Technischer SEO-Audit, Wettbewerbsanalyse, Keyword-Recherche und Content-Gap-Analyse. Wir identifizieren, wo du stehst und wo die größten Hebel liegen.' },
        { step: '02', title: 'Strategie & Roadmap', desc: 'Individuelle SEO-Strategie mit priorisierten Maßnahmen, Zeitplan und klaren KPIs. Jede Empfehlung ist datenbasiert und auf dein Geschäftsmodell zugeschnitten.' },
        { step: '03', title: 'Umsetzung', desc: 'Technische Optimierung, Content-Erstellung, Schema-Markup, Linkaufbau und On-Page-SEO. Wir setzen um, systematisch, dokumentiert und nachvollziehbar.' },
        { step: '04', title: 'Skalierung', desc: 'Laufendes Monitoring mit Google Search Console, Ahrefs und eigenen Tools. Monatliches Reporting, iterative Optimierung und Skalierung erfolgreicher Maßnahmen.' },
      ].map((item, i) => (
        <div class="group relative fade-up">
          <div class="relative bg-white/[0.03] backdrop-blur-sm border border-white/[0.06] rounded-2xl p-8 h-full hover:bg-white/[0.06] hover:border-emerald-500/20 transition-all duration-500 overflow-hidden">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 0%, rgba(16,185,129,0.08) 0%, transparent 60%);"></div>
            <span class="text-6xl font-extrabold text-white/[0.03] absolute top-4 right-6 select-none">{item.step}</span>
            <div class="relative">
              <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5 group-hover:bg-emerald-500/20 group-hover:shadow-[0_0_16px_rgba(16,185,129,0.2)] transition-all duration-500">
                <span class="text-xs font-mono font-bold text-emerald-400">{item.step}</span>
              </div>
              <h3 class="text-lg font-bold text-white tracking-tight">{item.title}</h3>
              <p class="mt-2.5 text-sm text-gray-300 leading-relaxed">{item.desc}</p>
            </div>
          </div>
          {i < 3 && <div class="hidden lg:block absolute top-1/2 -right-3 w-6 h-px bg-gradient-to-r from-emerald-500/40 to-transparent"></div>}
        </div>
      ))}
    </div>

    <!-- Branchen Tags -->
    <div class="mt-16 flex flex-wrap items-center gap-3 fade-up">
      <span class="text-xs font-mono text-gray-500 uppercase tracking-wider mr-2">Branchen:</span>
      {['B2B', 'E-Commerce', 'Mittelstand', 'Dienstleister', 'SaaS'].map((tag) => (
        <span class="px-3 py-1 rounded-full border border-white/[0.08] text-xs font-medium text-gray-400 hover:border-emerald-500/30 hover:text-emerald-400 hover:shadow-[0_0_12px_rgba(16,185,129,0.15)] transition-all cursor-default">{tag}</span>
      ))}
    </div>
  </div>
</section>
