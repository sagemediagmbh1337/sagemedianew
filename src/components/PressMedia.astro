<!-- ════════════════════════════════════════════
     PRESSE & MEDIEN (Dark)
════════════════════════════════════════════ -->
<section class="relative py-32 md:py-44 bg-gray-950 text-white overflow-hidden noise-bg">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent divider-glow"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>
  <div class="absolute top-[10%] left-[15%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.1) 0%, rgba(16,185,129,0.02) 50%, transparent 70%);"></div>
  <div class="absolute bottom-[5%] right-[20%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.07) 0%, transparent 60%);"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
      <div>
        <div class="flex items-center gap-3 mb-6 fade-up">
          <span class="inline-block w-8 h-px bg-emerald-400"></span>
          <span class="text-xs font-mono font-medium text-emerald-400 uppercase tracking-[0.2em]">Presse & Medien</span>
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.04em] fade-up">
          <span class="text-white">Über uns</span>
          <span class="bg-gradient-to-r from-emerald-300 via-emerald-400 to-emerald-500 bg-clip-text text-transparent"> berichtet</span>
        </h2>
      </div>
      <p class="text-gray-300 leading-relaxed max-w-sm fade-up">
        Ausgewählte Berichte, Interviews und Auftritte aus Fachmedien und Presse.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 fade-up-stagger">
      {[
        { logoSrc: '/images/press/infranken.png', outlet: 'inFranken', type: 'Print & Online', headline: 'Erster Preis für junge Firma, sagemedia gewinnt SEO-Contest', date: '2021', href: 'https://www.infranken.de/lk/gem/kronach/erster-preis-fuer-junge-firma-art-5270807' },
        { logoSrc: '/images/press/fraenkischer-tag.png', outlet: 'Fränkischer Tag', type: 'Print & Online', headline: 'Janin und André Schäfer haben eine Online-Marketing-Agentur in Bad Staffelstein gegründet', date: '2021', href: 'https://www.fraenkischertag.de/lokales/lichtenfels/wirtschaft/janin-und-andre-schaefer-haben-eine-online-marketing-agentur-in-bad-staffelstein-gegruendet-art-424783' },
        { logoSrc: '/images/press/gruenderde.png', outlet: 'Gründer.de', type: 'Online', headline: 'André Schäfer: SEO-Experte mit Branchenexklusivität als Erfolgsmodell', date: '2025', href: 'https://www.gruender.de/online-marketing/andre-schaefer-seo/' },
        { logoSrc: '/images/press/radioeins.png', outlet: 'radioeins', type: 'Podcast', headline: 'sagemedia bei Radio Eins, Interview über SEO und KI-Suchsysteme', date: '2026', href: 'https://soundcloud.com/sagemedia_seo/sagemedia-bei-radio-eins' },
        { logoSrc: '/images/press/dim.png', outlet: 'Deutsches Institut für Marketing', type: 'Online', headline: 'Sichtbarkeit bei Google, Expertenbeitrag von sagemedia', date: '2024', href: 'https://www.marketinginstitut.biz/blog/sichtbarkeit-bei-google/' },
        { logoSrc: '/images/press/agenturtipp.png', outlet: 'Agenturtipp.de', type: 'Online', headline: 'SEO-Contest 2021: Diese Contentbären stehen auf dem Podest', date: '2021', href: 'https://www.agenturtipp.de/cms/artikel/20-seo-contest-diese-contentbaeren-stehen-auf-dem-podest/' },
        { logoSrc: '/images/press/ihk.jpg', outlet: 'IHK für Oberfranken', type: 'Print', headline: 'sagemedia in der IHK-Zeitschrift Oberfranken, Bericht über die Agentur', date: '2024', href: 'https://www.ihk.de/bayreuth/share/flipping-book/6967822/' },
      ].map((p) => (
        <a href={p.href} target="_blank" rel="noopener" class="group relative bg-white/[0.03] backdrop-blur-sm border border-white/[0.06] rounded-2xl p-7 hover:bg-white/[0.06] hover:border-emerald-500/20 transition-all duration-500 overflow-hidden fade-up block">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 0% 50%, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>
          <div class="relative">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-base font-bold text-white">{p.outlet}</span>
              <span class="text-[10px] font-mono text-emerald-400/60 bg-emerald-500/10 px-2 py-0.5 rounded-full">{p.type}</span>
              <span class="text-[10px] font-mono text-gray-600 ml-auto">{p.date}</span>
            </div>
            <p class="text-sm text-gray-300 leading-relaxed group-hover:text-gray-200 transition-colors">{p.headline}</p>
            <div class="mt-4 flex items-center gap-2 text-xs font-mono text-emerald-500/60 group-hover:text-emerald-400 transition-colors">
              <span>Artikel lesen</span>
              <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Logo bar -->
    <div class="mt-16 pt-12 border-t border-white/[0.06] fade-up">
      <div class="flex flex-wrap items-center justify-center gap-12 md:gap-16">
        <img src="/v2/images/press/radioeins.png" alt="radioeins" class="h-5 opacity-30 hover:opacity-60 transition-opacity duration-500" loading="lazy" />
        <img src="/v2/images/press/fraenkischer-tag.png" alt="Fränkischer Tag" class="h-5 opacity-30 hover:opacity-60 transition-opacity duration-500" loading="lazy" />
        <img src="/v2/images/press/gruenderde.png" alt="Gründer.de" class="h-5 opacity-30 hover:opacity-60 transition-opacity duration-500" loading="lazy" />
        <img src="/v2/images/press/infranken.png" alt="inFranken" class="h-5 opacity-30 hover:opacity-60 transition-opacity duration-500" loading="lazy" />
        <img src="/v2/images/press/dim.png" alt="Deutsches Institut für Marketing" class="h-5 opacity-30 hover:opacity-60 transition-opacity duration-500" loading="lazy" />
        <img src="/v2/images/press/ihk.jpg" alt="IHK für Oberfranken" class="h-6 opacity-30 hover:opacity-60 transition-opacity duration-500" loading="lazy" />
      </div>
    </div>
  </div>
</section>
