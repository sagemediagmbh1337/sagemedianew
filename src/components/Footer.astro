---
const currentYear = new Date().getFullYear()
---

<footer class="bg-gray-950 text-white pt-20 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-12 gap-12 pb-16 border-b border-white/10">
      <!-- Brand -->
      <div class="md:col-span-4">
        <img src="/images/logo-white.png" alt="sagemedia" class="h-8 w-auto mb-5" />
        <p class="text-gray-400 text-sm leading-relaxed max-w-sm">
          Premium-SEO-Agentur aus Bad Staffelstein. Ein Unternehmen pro Branche, keine Kompromisse bei deiner Sichtbarkeit.
        </p>
        <div class="mt-6 space-y-2">
          <a href="tel:+4995733313759" class="flex items-center gap-2 text-sm text-gray-500 hover:text-emerald-400 transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" /></svg>
            09573 / 33 13 759
          </a>
          <a href="mailto:info@sagemedia.de" class="flex items-center gap-2 text-sm text-gray-500 hover:text-emerald-400 transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
            info@sagemedia.de
          </a>
          <p class="text-sm text-gray-600 pl-6">Goethestraße 12, 96231 Bad Staffelstein</p>
        </div>
      </div>

      <!-- Nav -->
      <div class="md:col-span-2">
        <h4 class="text-xs font-mono font-medium uppercase tracking-[0.2em] text-gray-500 mb-5">Navigation</h4>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Home</a></li>
          <li><a href="/team" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Team</a></li>
          <li><a href="/leistungen" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Leistungen</a></li>
          <li><a href="/ergebnisse" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Ergebnisse</a></li>
          <li><a href="/magazin" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Magazin</a></li>
          <li><a href="/lexikon" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Lexikon</a></li>
          <li><a href="/kontakt" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <!-- Leistungen -->
      <div class="md:col-span-3">
        <h4 class="text-xs font-mono font-medium uppercase tracking-[0.2em] text-gray-500 mb-5">Leistungen</h4>
        <ul class="space-y-3">
          <li><a href="/leistungen/seo" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">SEO</a></li>
          <li><a href="/leistungen/google-ads" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Google Ads</a></li>
          <li><a href="/leistungen/geo-aio-llmo" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">GEO / AIO / LLMO</a></li>
          <li><a href="/leistungen/webdesign" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Webdesign</a></li>
          <li><a href="/leistungen/landingpages" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Landingpages</a></li>
          <li><a href="/leistungen/google-stellenanzeigen" class="text-sm text-gray-400 hover:text-emerald-400 transition-colors">Google Stellenanzeigen</a></li>
        </ul>
      </div>

