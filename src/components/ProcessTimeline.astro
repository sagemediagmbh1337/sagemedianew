---
interface Step {
  step: string
  title: string
  desc: string
  detail: string
}

interface Props {
  eyebrow?: string
  title?: string
  titleAccent?: string
  subtitle?: string
  steps: Step[]
  ctaText?: string
  ctaHref?: string
}

const {
  eyebrow = 'Zusammenarbeit',
  title = 'So arbeiten wir',
  titleAccent = ' zusammen',
  subtitle = 'Kein langwieriges Onboarding, keine versteckten Kosten. Vom ersten Gespräch bis zu messbaren Ergebnissen, transparent und strukturiert.',
  steps,
  ctaText = 'Erstgespräch vereinbaren',
  ctaHref = '/kontakt',
} = Astro.props

const sides = ['left', 'right', 'left', 'right'] as const
---

<section class="relative py-32 md:py-44 overflow-hidden">
  <div class="absolute top-[10%] left-[5%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="max-w-2xl mb-20">
      <div class="flex items-center gap-3 mb-6 fade-up">
        <span class="inline-block w-8 h-px bg-emerald-500"></span>
        <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">{eyebrow}</span>
      </div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.04em] text-gray-950 fade-up">
        {title}
        <span class="bg-gradient-to-r from-emerald-600 to-emerald-400 bg-clip-text text-transparent">{titleAccent}</span>
      </h2>
      <p class="mt-6 text-gray-500 leading-relaxed fade-up">{subtitle}</p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <div class="hidden lg:block absolute left-[calc(50%-0.5px)] top-0 bottom-0 w-px bg-gradient-to-b from-emerald-200 via-emerald-300/50 to-transparent"></div>

      <div class="space-y-16 lg:space-y-24">
        {steps.map((item, i) => {
          const side = sides[i % 4]
          return (
            <div class={`relative grid lg:grid-cols-2 gap-8 lg:gap-16 items-center fade-up ${side === 'right' ? 'lg:direction-rtl' : ''}`}>
              <div class={`${side === 'right' ? 'lg:col-start-2 lg:text-left' : ''}`} style="direction: ltr;">
                <div class="relative bg-white rounded-2xl p-8 border border-gray-100 shadow-[0_8px_32px_rgba(0,0,0,0.04)] hover:border-emerald-200 hover:shadow-[0_16px_48px_rgba(16,185,129,0.08)] transition-all duration-500 card-lift">
                  <div class="flex items-center gap-3 mb-4">
                    <div class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center">
                      <span class="text-xs font-mono font-bold text-emerald-600">{item.step}</span>
                    </div>
                    <span class="text-[10px] font-mono text-emerald-500 uppercase tracking-wider bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full">{item.detail}</span>
                  </div>
                  <h3 class="text-xl font-bold text-gray-900 tracking-tight">{item.title}</h3>
                  <p class="mt-3 text-gray-500 leading-relaxed">{item.desc}</p>
                </div>
              </div>
              <div class={`hidden lg:block ${side === 'right' ? 'lg:col-start-1 lg:row-start-1' : ''}`}></div>
              <div class="hidden lg:flex absolute left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-emerald-500 border-4 border-white shadow-[0_0_0_4px_rgba(16,185,129,0.15)]"></div>
            </div>
          )
        })}
      </div>
    </div>

    <!-- CTA -->
    {ctaText && (
      <div class="mt-20 text-center fade-up">
        <a href={ctaHref} class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-semibold overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(16,185,129,0.3)]">
          <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-emerald-500 transition-all duration-500 group-hover:from-emerald-500 group-hover:to-emerald-400"></div>
          <div class="absolute inset-0 rounded-full shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"></div>
          <span class="relative z-10 text-white">{ctaText}</span>
          <svg class="relative z-10 w-4 h-4 text-white group-hover:translate-x-1 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
