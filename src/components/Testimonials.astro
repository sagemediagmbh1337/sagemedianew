---
interface VideoTestimonial {
  title: string
  initials: string
  name: string
  role: string
  vimeoId: string
  vimeoHash?: string
}

interface TextReview {
  quote: string
  initials: string
  name: string
  role: string
}

interface Props {
  eyebrow?: string
  title?: string
  titleAccent?: string
  videos?: VideoTestimonial[]
  reviews?: TextReview[]
  showGoogleBadge?: boolean
}

const {
  eyebrow = 'Kundenstimmen',
  title = 'Was unsere Kunden',
  titleAccent = ' sagen',
  videos = [],
  reviews = [],
  showGoogleBadge = true,
} = Astro.props

import SectionHeader from './SectionHeader.astro'

const sliderId = `video-slider-${Math.random().toString(36).slice(2, 8)}`
---

<section class="relative py-32 md:py-44 bg-gray-50/80 overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
  <div class="absolute top-[20%] left-[5%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 60%);"></div>
  <div class="absolute bottom-[10%] right-[10%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.05) 0%, transparent 60%);"></div>

  <div class="max-w-7xl mx-auto px-6 relative">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16">
      <div class="[&>div]:mb-0">
        <SectionHeader eyebrow={eyebrow} title={title} titleAccent={titleAccent} />
      </div>
      {showGoogleBadge && (
        <div class="flex items-center gap-5 bg-white rounded-2xl px-7 py-5 border border-gray-100 shadow-[0_8px_32px_rgba(0,0,0,0.06)] fade-up">
          <svg class="w-8 h-8 shrink-0" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
          </svg>
          <div>
            <div class="flex items-center gap-1.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
              <span class="text-lg font-extrabold text-gray-900 ml-1">5.0</span>
            </div>
            <p class="text-xs text-gray-400 mt-0.5">Bewertung auf Google</p>
          </div>
        </div>
      )}
    </div>

    <!-- Video Testimonials -->
    {videos.length > 0 && (
      <div class="relative fade-up">
        <div id={sliderId} class="video-slider flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4" style="-ms-overflow-style: none; scrollbar-width: none;">
          {videos.map((t) => (
            <div class="group relative shrink-0 w-full md:w-[calc(50%-0.75rem)] snap-start rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.08)]" data-vimeo-id={t.vimeoId} data-vimeo-hash={t.vimeoHash || ''}>
              <div class="video-thumbnail cursor-pointer aspect-[16/9] bg-gray-900 relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-gray-800 via-gray-900 to-gray-950"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-gray-950/80 via-transparent to-transparent"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-16 h-16 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center group-hover:bg-emerald-500 group-hover:border-emerald-400 group-hover:shadow-[0_0_32px_rgba(16,185,129,0.5)] group-hover:scale-105 transition-all duration-500">
                    <svg class="w-6 h-6 text-white ml-0.5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                  <p class="text-white text-base font-bold leading-snug">{t.title}</p>
                  <div class="mt-3 flex items-center gap-2.5">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center">
                      <span class="text-white text-[10px] font-bold">{t.initials}</span>
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-white/90">{t.name}</p>
                      <p class="text-xs text-white/40">{t.role}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Slider nav -->
        <div class="flex items-center gap-3 mt-6">
          <button class="video-prev w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center hover:border-emerald-300 hover:shadow-[0_0_16px_rgba(16,185,129,0.15)] transition-all cursor-pointer" data-slider={sliderId} aria-label="Zurück">
            <svg class="w-4 h-4 text-gray-500" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4l-4 4 4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
          <button class="video-next w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center hover:border-emerald-300 hover:shadow-[0_0_16px_rgba(16,185,129,0.15)] transition-all cursor-pointer" data-slider={sliderId} aria-label="Weiter">
            <svg class="w-4 h-4 text-gray-500" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </button>
        </div>
      </div>
    )}

    <!-- Google Reviews Masonry -->
    {reviews.length > 0 && (
      <div class={`${videos.length > 0 ? 'mt-14' : ''} columns-1 md:columns-2 gap-5 space-y-5`}>
        {reviews.map((t) => (
          <div class="break-inside-avoid group relative bg-white rounded-2xl p-7 border border-gray-100 hover:border-emerald-200/60 transition-all duration-500 hover:shadow-[0_16px_48px_-8px_rgba(16,185,129,0.08)] overflow-hidden fade-up card-lift">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 100%, rgba(16,185,129,0.04) 0%, transparent 60%);"></div>
            <div class="relative">
              <div class="flex items-center gap-0.5 mb-4">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3.5 h-3.5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              <p class="text-[15px] text-gray-600 leading-relaxed">{t.quote}</p>
              <div class="mt-6 flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_2px_8px_rgba(16,185,129,0.25)]">
                  <span class="text-white text-[10px] font-bold">{t.initials}</span>
                </div>
                <div>
                  <p class="text-sm font-bold text-gray-900">{t.name}</p>
                  <p class="text-xs text-gray-400">{t.role}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
