---
interface Props {
  eyebrow: string
  titleLine1: string
  titleLine2: string
  subtitle: string
  ctaText: string
  ctaHref?: string
  secondaryText?: string
  secondaryHref?: string
  breadcrumbs?: { label: string, href?: string }[]
}

const {
  eyebrow,
  titleLine1,
  titleLine2,
  subtitle,
  ctaText,
  ctaHref = '/v2/kontakt',
  secondaryText,
  secondaryHref,
  breadcrumbs
} = Astro.props

const hasVisual = Astro.slots.has('visual')
---

<section class="relative overflow-hidden py-32 md:py-44">
  <div class="absolute inset-0 bg-[linear-gradient(rgba(16,185,129,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(16,185,129,0.06)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
  <div class="absolute top-[10%] right-[5%] w-[700px] h-[700px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 40%, transparent 70%);"></div>
  <div class="absolute -bottom-[20%] -left-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.1) 0%, transparent 60%);"></div>
  <div class="absolute top-[5%] left-[15%] w-[300px] h-[300px] rounded-full" style="background: radial-gradient(circle, rgba(6,78,59,0.06) 0%, transparent 60%);"></div>
  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-gray-50/80 to-transparent"></div>
  <div class="absolute inset-0 noise-bg pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative">
    {breadcrumbs && (
      <nav class="flex items-center gap-2 text-xs text-gray-400 mb-10 fade-up" aria-label="Breadcrumb">
        {breadcrumbs.map((crumb, i) => (
          <>
            {i > 0 && <span class="text-emerald-500 font-bold text-sm">/</span>}
            {crumb.href ? (
              <a href={crumb.href} class="hover:text-emerald-600 transition-colors">{crumb.label}</a>
            ) : (
              <span class="text-gray-600">{crumb.label}</span>
            )}
          </>
        ))}
      </nav>
    )}

    <div class={hasVisual ? 'grid lg:grid-cols-12 gap-8 lg:gap-6 items-center' : ''}>
      <div class={hasVisual ? 'lg:col-span-7 lg:pr-8' : ''}>
        <div class="hero-eyebrow inline-flex items-center gap-2.5 mb-8">
          <span class="inline-block w-8 h-px bg-emerald-500"></span>
          <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">{eyebrow}</span>
        </div>

        <h1 class="hero-title">
          <span class={`block font-extrabold leading-[1.05] tracking-[-0.04em] text-gray-950 text-[clamp(2.25rem,6vw,6rem)]`}>
            {titleLine1}
          </span>
          <span class={`block font-extrabold leading-[1.05] tracking-[-0.04em] mt-1 bg-gradient-to-r from-emerald-600 via-emerald-500 to-emerald-400 bg-clip-text text-transparent gradient-shimmer text-[clamp(2.25rem,6vw,6rem)]`}>
            {titleLine2}
          </span>
        </h1>

        <p class={`hero-sub mt-8 text-lg md:text-xl text-gray-500 leading-relaxed ${hasVisual ? 'max-w-lg' : 'max-w-2xl'}`}>
          {subtitle}
        </p>

        <div class="hero-cta mt-10 flex flex-wrap items-center gap-5">
          <a href={ctaHref} class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-semibold overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(16,185,129,0.3)]">
            <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-emerald-500 transition-all duration-500 group-hover:from-emerald-500 group-hover:to-emerald-400"></div>
            <div class="absolute inset-0 rounded-full shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"></div>
            <span class="relative z-10 text-white">{ctaText}</span>
            <svg class="relative z-10 w-4 h-4 text-white group-hover:translate-x-1 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </a>
          {secondaryText && secondaryHref && (
            <a href={secondaryHref} class="group inline-flex items-center gap-2 text-gray-500 hover:text-emerald-600 font-medium transition-colors">
              {secondaryText}
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </a>
          )}
        </div>

        <slot name="trust" />
      </div>

      {hasVisual && (
        <div class="lg:col-span-5 hero-visual">
          <slot name="visual" />
        </div>
      )}
    </div>

    <slot />
  </div>
</section>
