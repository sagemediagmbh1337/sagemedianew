<!-- ════════════════════════════════════════════
     AUSZEICHNUNGEN
════════════════════════════════════════════ -->
<section class="relative py-28 md:py-36 bg-gray-50/80 overflow-hidden">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="relative bg-gray-50 rounded-[1.5rem] p-10 md:p-14 border border-gray-100 fade-up">
      <div class="flex items-center gap-3 mb-10">
        <span class="inline-block w-8 h-px bg-emerald-500"></span>
        <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Auszeichnungen</span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 md:gap-10">
        {[
          { img: '/images/awards/seo-contest-2021-2.png', title: 'SEO-Contest 2021', sub: 'Top 3, Deutschland' },
          { img: '/images/awards/seo-contest-2022-2.png', title: 'SEO-Contest 2022', sub: 'Top Platzierung' },
          { img: '/images/awards/top-agentur-2022.png', title: 'Top Agentur 2022', sub: 'Agenturtipp.de' },
          { img: null, title: '#1 Online-Marketing Nürnberg', sub: '8,52/10, Agenturtipp.de 2026', icon: 'trophy' },
          { img: null, title: 'Trustpilot', sub: '5.0 / 5.0 Sterne', icon: 'stars' },
        ].map((a, i) => (
          <div class="group relative fade-up">
            {i > 0 && <div class="hidden md:block absolute -left-4 md:-left-6 top-0 h-full w-px bg-gray-200"></div>}
            {a.img ? (
              <img src={a.img} alt={a.title} class="h-16 w-auto mb-3" loading="lazy" />
            ) : (
              <div class="w-12 h-12 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center mb-3">
                <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  {a.icon === 'trophy' && <><path d="M6 9H4.5a2.5 2.5 0 010-5H6" /><path d="M18 9h1.5a2.5 2.5 0 000-5H18" /><path d="M4 22h16" /><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22" /><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22" /><path d="M18 2H6v7a6 6 0 0012 0V2z" /></>}
                  {a.icon === 'stars' && <><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></>}
                </svg>
              </div>
            )}
            <h3 class="font-sans font-bold text-gray-900 tracking-tight text-sm">{a.title}</h3>
            <p class="text-xs text-gray-400 mt-1">{a.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
