---
interface Props {
  eyebrow: string
  title: string
  titleAccent?: string
  subtitle?: string
  dark?: boolean
  center?: boolean
}

const { eyebrow, title, titleAccent, subtitle, dark = false, center = false } = Astro.props
---

<div class={center ? 'text-center max-w-3xl mx-auto mb-16' : 'flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-20'}>
  <div>
    <div class={`flex items-center gap-3 mb-6 fade-up ${center ? 'justify-center' : ''}`}>
      <span class={`inline-block w-8 h-px ${dark ? 'bg-emerald-400' : 'bg-emerald-500'}`}></span>
      <span class={`text-xs font-mono font-medium uppercase tracking-[0.2em] ${dark ? 'text-emerald-400' : 'text-emerald-600'}`}>{eyebrow}</span>
      {center && <span class={`inline-block w-8 h-px ${dark ? 'bg-emerald-400' : 'bg-emerald-500'}`}></span>}
    </div>
    <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.04em] fade-up">
      <span class={dark ? 'text-white' : 'text-gray-950'}>{title}</span>
      {titleAccent && (
        <span class={`bg-gradient-to-r ${dark ? 'from-emerald-300 via-emerald-400 to-emerald-500' : 'from-emerald-600 to-emerald-400'} bg-clip-text text-transparent`}> {titleAccent}</span>
      )}
    </h2>
  </div>
  {subtitle && !center && (
    <p class={`leading-relaxed max-w-sm fade-up ${dark ? 'text-gray-400' : 'text-gray-500'}`}>{subtitle}</p>
  )}
  {subtitle && center && (
    <p class={`mt-6 text-lg max-w-xl mx-auto fade-up ${dark ? 'text-gray-400' : 'text-gray-500'}`}>{subtitle}</p>
  )}
</div>
