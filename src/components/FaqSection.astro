---
import Section from './Section.astro'
import SectionHeader from './SectionHeader.astro'

interface FaqItem {
  q: string
  a: string
}

interface Props {
  eyebrow?: string
  title?: string
  titleAccent?: string
  subtitle?: string
  faqs: FaqItem[]
  /** Optional: Bild-URL für die CTA-Card */
  contactImage?: string
  /** Optional: gray background */
  gray?: boolean
}

const {
  eyebrow = 'FAQ',
  title = 'Häufige Fragen',
  titleAccent = '',
  subtitle = '',
  faqs,
  contactImage = '/v2/images/andre-schaefer-stage.jpg',
  gray = false,
} = Astro.props
---

<Section id="faq" gray={gray}>
  <SectionHeader eyebrow={eyebrow} title={title} titleAccent={titleAccent} subtitle={subtitle} />

  <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
    <!-- FAQ Accordion -->
    <div class="lg:col-span-7 space-y-4">
      {faqs.map((faq, i) => (
        <details class="group faq-item bg-white rounded-2xl border border-gray-100 hover:border-emerald-200 transition-all duration-300 fade-up overflow-hidden">
          <summary class="flex items-center gap-4 p-6 cursor-pointer list-none">
            <span class="shrink-0 w-8 h-8 rounded-lg bg-gray-50 border border-gray-100 flex items-center justify-center group-open:bg-emerald-50 group-open:border-emerald-200 transition-all duration-300">
              <span class="text-[10px] font-mono font-bold text-gray-400 group-open:text-emerald-600 transition-colors duration-300">{String(i + 1).padStart(2, '0')}</span>
            </span>
            <h3 class="text-base font-bold text-gray-900 pr-8 flex-1">{faq.q}</h3>
            <svg class="w-5 h-5 text-gray-400 shrink-0 group-open:rotate-45 group-open:text-emerald-500 transition-all duration-300" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4v12m-6-6h12" stroke-linecap="round" /></svg>
          </summary>
          <div class="px-6 pb-6 pl-[4.5rem] -mt-1">
            <p class="text-sm text-gray-500 leading-relaxed">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>

    <!-- Sticky CTA Card -->
    <div class="lg:col-span-5 fade-up" style="position: sticky; top: 7rem;">
      <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_8px_32px_rgba(0,0,0,0.04)] overflow-hidden">
        <!-- Image -->
        {contactImage && (
          <div class="aspect-[4/3] bg-gray-100 overflow-hidden">
            <img src={contactImage} alt="André Schäfer, sagemedia" class="w-full h-full object-cover object-top" loading="lazy" />
          </div>
        )}

        <!-- Content -->
        <div class="p-7">
          <h4 class="text-lg font-bold text-gray-900 tracking-tight">Noch Fragen?</h4>
          <p class="mt-2 text-sm text-gray-500 leading-relaxed">
            Sprich direkt mit André, kostenlos und unverbindlich. In 30 Minuten klären wir, ob wir der richtige Partner für dich sind.
          </p>

          <a href="/v2/kontakt" class="group relative mt-6 w-full inline-flex items-center justify-center gap-3 px-6 py-3.5 rounded-full text-sm font-semibold overflow-hidden transition-all duration-500 hover:shadow-[0_0_32px_rgba(16,185,129,0.3)]">
            <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-emerald-500 transition-all duration-500 group-hover:from-emerald-500 group-hover:to-emerald-400"></div>
            <div class="absolute inset-0 rounded-full shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"></div>
            <span class="relative z-10 text-white">Erstgespräch vereinbaren</span>
            <svg class="relative z-10 w-4 h-4 text-white group-hover:translate-x-1 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>

          <!-- Contact details -->
          <div class="mt-6 pt-6 border-t border-gray-100 space-y-3">
            <a href="tel:+4995733313759" class="flex items-center gap-3 text-sm text-gray-500 hover:text-emerald-600 transition-colors">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" /></svg>
              09573 / 33 13 759
            </a>
            <a href="mailto:info@sagemedia.de" class="flex items-center gap-3 text-sm text-gray-500 hover:text-emerald-600 transition-colors">
              <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><path d="M22 6l-10 7L2 6" /></svg>
              info@sagemedia.de
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Section>

<style>
  .faq-item[open] {
    border-left: 2px solid #10b981;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.02) 0%, rgba(255, 255, 255, 1) 100%);
    border-color: #a7f3d0;
    border-left-color: #10b981;
  }
</style>
