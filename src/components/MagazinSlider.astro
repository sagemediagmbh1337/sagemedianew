<!-- ════════════════════════════════════════════
     MAGAZIN (Slider)
════════════════════════════════════════════ -->
<section class="relative py-32 md:py-44 overflow-hidden">
  <div class="absolute top-[15%] right-[5%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 relative">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-14">
      <div>
        <div class="flex items-center gap-3 mb-6 fade-up">
          <span class="inline-block w-8 h-px bg-emerald-500"></span>
          <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Magazin</span>
        </div>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.04em] text-gray-950 fade-up">
          Aktuelle
          <span class="bg-gradient-to-r from-emerald-600 to-emerald-400 bg-clip-text text-transparent"> Beiträge</span>
        </h2>
      </div>
      <div class="flex items-center gap-3 fade-up">
        <button id="slider-prev" class="w-11 h-11 rounded-full border border-gray-200 flex items-center justify-center hover:border-emerald-300 hover:shadow-[0_0_16px_rgba(16,185,129,0.15)] transition-all cursor-pointer" aria-label="Zurück">
          <svg class="w-4 h-4 text-gray-500" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4l-4 4 4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </button>
        <button id="slider-next" class="w-11 h-11 rounded-full border border-gray-200 flex items-center justify-center hover:border-emerald-300 hover:shadow-[0_0_16px_rgba(16,185,129,0.15)] transition-all cursor-pointer" aria-label="Weiter">
          <svg class="w-4 h-4 text-gray-500" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </button>
        <a href="/magazin" class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold text-gray-500 hover:text-emerald-600 transition-colors ml-3">
          Alle Beiträge
          <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Slider -->
  <div class="relative fade-up">
    <div id="magazin-slider" class="flex gap-5 overflow-x-auto scroll-smooth snap-x snap-mandatory px-[max(1.5rem,calc((100vw-80rem)/2+1.5rem))] pb-4" style="-ms-overflow-style: none; scrollbar-width: none;">
      {[
        { href: '/magazin/privatpatienten-gewinnen-zahnarzt', cat: 'SEO für Ärzte', title: 'Privatpatienten gewinnen als Zahnarzt: Strategien im Überblick', date: '11. März 2026', time: '12 Min.', rot: '10deg' },
        { href: '/magazin', cat: 'GEO & AIO', title: 'Google AI Overviews: Was bedeutet das für dein SEO?', date: '5. März 2026', time: '8 Min.', rot: '25deg' },
        { href: '/magazin', cat: 'Local SEO', title: 'Local SEO 2026: Der ultimative Guide für lokale Unternehmen', date: '28. Februar 2026', time: '15 Min.', rot: '40deg' },
        { href: '/magazin', cat: 'E-Commerce', title: 'E-Commerce SEO: So dominierst du die Suchergebnisse', date: '20. Februar 2026', time: '10 Min.', rot: '55deg' },
        { href: '/magazin', cat: 'Technisches SEO', title: 'Core Web Vitals optimieren: Der technische Deep Dive', date: '12. Februar 2026', time: '14 Min.', rot: '70deg' },
        { href: '/magazin', cat: 'Content', title: 'Content-Strategie für B2B: Weniger ist mehr', date: '5. Februar 2026', time: '7 Min.', rot: '85deg' },
      ].map((post) => (
        <a href={post.href} class="group shrink-0 w-[calc(100vw-48px)] sm:w-[360px] snap-start relative bg-white rounded-2xl border border-gray-100 overflow-hidden hover:border-emerald-200 transition-all duration-500 hover:shadow-[0_24px_64px_-12px_rgba(16,185,129,0.1)]">
          <div class="aspect-[16/10] bg-gray-100 relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-emerald-50 via-gray-50 to-gray-100 group-hover:scale-105 transition-transform duration-700"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-30">
              <div class="w-24 h-24 rounded-2xl rotate-12 border-2 border-emerald-300" style={`transform: rotate(${post.rot});`}></div>
              <div class="absolute w-16 h-16 rounded-full border-2 border-emerald-200"></div>
            </div>
            <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm rounded-full px-3 py-1 border border-gray-100">
              <span class="text-[10px] font-mono font-medium text-emerald-600 uppercase tracking-wider">{post.cat}</span>
            </div>
          </div>
          <div class="p-6">
            <h3 class="text-base font-bold text-gray-900 leading-snug tracking-tight group-hover:text-emerald-700 transition-colors line-clamp-2">{post.title}</h3>
            <div class="mt-4 flex items-center gap-3 text-xs text-gray-400">
              <span>{post.date}</span>
              <span class="w-1 h-1 rounded-full bg-gray-300"></span>
              <span>{post.time}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="mt-8 sm:hidden fade-up">
      <a href="/magazin" class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-600">
        Alle Beiträge ansehen
        <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </a>
    </div>
  </div>
</section>

<script>
  const slider = document.getElementById('magazin-slider')
  const prev = document.getElementById('slider-prev')
  const next = document.getElementById('slider-next')
  const step = 380
  prev?.addEventListener('click', () => slider?.scrollBy({ left: -step, behavior: 'smooth' }))
  next?.addEventListener('click', () => slider?.scrollBy({ left: step, behavior: 'smooth' }))
</script>
