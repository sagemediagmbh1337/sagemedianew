---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import HeroPage from '../components/HeroPage.astro'
import CtaSection from '../components/CtaSection.astro'
import VideoLightbox from '../components/VideoLightbox.astro'
import TrustLogos from '../components/TrustLogos.astro'

interface RelatedTerm {
  term: string
  slug: string
}

interface Props {
  term: string
  category: string
  desc: string
  related: RelatedTerm[]
  breadcrumbs: { label: string; href?: string }[]
}

const { term, category, desc, related, breadcrumbs } = Astro.props
---

<Layout title={term + " — SEO-Glossar | sagemedia"} description={desc.substring(0, 160)}>
  <Header />

  <main class="pt-18">

    <HeroPage
      eyebrow={category}
      titleLine1={term}
      titleLine2=""
      subtitle={desc.split('. ').slice(0, 2).join('. ') + '.'}
      ctaText="Erstgespräch vereinbaren"
      secondaryText="Zurück zum Glossar"
      secondaryHref="/glossar"
      breadcrumbs={breadcrumbs}
    >
      <div class="relative" slot="visual">
        <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>

        <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
              <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-wider">Definition</span>
            </div>
            <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">{category}</span>
          </div>

          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_24px_rgba(16,185,129,0.3)]">
              <span class="text-2xl font-extrabold text-white">{term[0]}</span>
            </div>
            <div>
              <p class="text-lg font-extrabold text-gray-900 tracking-tight">{term}</p>
              <p class="text-xs text-gray-400 mt-0.5">{category}</p>
            </div>
          </div>

          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Kategorie</p>
              <p class="text-sm font-bold text-gray-900">{category}</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Verwandte</p>
              <p class="text-sm font-bold text-emerald-600">{related.length} Begriffe</p>
            </div>
          </div>
        </div>
      </div>

      <TrustLogos class="mt-16 hero-trust" slot="trust" />
    </HeroPage>

    <!-- Detailed Explanation -->
    <section class="relative py-32 md:py-44 overflow-hidden">
      <div class="absolute top-[15%] right-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">

          <!-- Main Content -->
          <div class="lg:col-span-2 fade-up">
            <div class="flex items-center gap-3 mb-8">
              <div class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-200 flex items-center justify-center">
                <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" /></svg>
              </div>
              <div>
                <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 tracking-tight">Was ist {term}?</h2>
              </div>
            </div>

            <div class="bg-white rounded-2xl border border-gray-100 p-8 md:p-10 card-lift">
              <div class="prose prose-gray max-w-none">
                <p class="text-base md:text-lg text-gray-600 leading-relaxed whitespace-pre-line">{desc}</p>
              </div>
            </div>

            <!-- Quick Facts Card -->
            <div class="mt-8 bg-gradient-to-br from-emerald-50/80 to-white rounded-2xl border border-emerald-100 p-8 fade-up">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center">
                  <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5" /><path d="M2 12l10 5 10-5" /></svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900">Auf einen Blick</h3>
              </div>
              <div class="grid sm:grid-cols-2 gap-4">
                <div class="flex items-start gap-3">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
                  <div>
                    <p class="text-xs font-mono uppercase tracking-wider text-gray-400 mb-1">Kategorie</p>
                    <p class="text-sm font-semibold text-gray-900">{category}</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 mt-2 shrink-0"></div>
                  <div>
                    <p class="text-xs font-mono uppercase tracking-wider text-gray-400 mb-1">Relevanz</p>
                    <p class="text-sm font-semibold text-gray-900">Hoch für SEO-Strategie</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Sidebar: Related Terms -->
          <div class="fade-up">
            <div class="sticky top-28">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center">
                  <svg class="w-4 h-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" /></svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900">Verwandte Begriffe</h3>
              </div>

              <div class="space-y-3">
                {related.map((r) => (
                  <a
                    href={"/glossar/" + r.slug}
                    class="group flex items-center gap-4 bg-white rounded-2xl p-5 border border-gray-100 hover:border-emerald-200 transition-all duration-300 hover:shadow-[0_8px_24px_-4px_rgba(16,185,129,0.08)] card-lift"
                  >
                    <div class="w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center group-hover:bg-emerald-50 group-hover:border-emerald-200 transition-all shrink-0">
                      <span class="text-sm font-mono font-bold text-gray-400 group-hover:text-emerald-600 transition-colors">{r.term[0]}</span>
                    </div>
                    <div class="min-w-0">
                      <p class="text-sm font-bold text-gray-900 group-hover:text-emerald-700 transition-colors truncate">{r.term}</p>
                      <p class="text-[10px] text-gray-400 mt-0.5">Definition ansehen</p>
                    </div>
                    <svg class="w-4 h-4 text-gray-300 group-hover:text-emerald-500 transition-colors ml-auto shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                ))}
              </div>

              <!-- Back to Glossar -->
              <a href="/glossar" class="mt-8 flex items-center gap-3 text-sm font-medium text-gray-500 hover:text-emerald-600 transition-colors group">
                <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 8H3m4-4L3 8l4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                Alle Begriffe im Glossar
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <CtaSection
      title="SEO nicht nur verstehen,"
      titleAccent="sondern umsetzen?"
      subtitle="Wir machen die Theorie zur Praxis. In einem kostenlosen Erstgespräch zeigen wir dir, wie diese Konzepte konkret für dein Unternehmen funktionieren."
      ctaText="Erstgespräch vereinbaren"
    />

  </main>

  <Footer />
  <VideoLightbox />
</Layout>