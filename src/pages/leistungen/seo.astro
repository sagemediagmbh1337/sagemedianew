---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import HeroPage from '../../components/HeroPage.astro'
import Section from '../../components/Section.astro'
import SectionHeader from '../../components/SectionHeader.astro'
import CtaSection from '../../components/CtaSection.astro'
import FaqSection from '../../components/FaqSection.astro'
import StatsStrip from '../../components/StatsStrip.astro'
import CaseStudies from '../../components/CaseStudies.astro'
import Testimonials from '../../components/Testimonials.astro'
import ProcessTimeline from '../../components/ProcessTimeline.astro'
import VideoLightbox from '../../components/VideoLightbox.astro'
import ServicesGrid from '../../components/ServicesGrid.astro'
import TrustLogos from '../../components/TrustLogos.astro'
import { videoTestimonials, textReviews } from '../../data/testimonials'

const seoFaqs = [
  { q: 'Was kostet die SEO-Betreuung bei sagemedia?', a: 'Im Erstgespräch besprechen wir den individuellen Invest. Der genaue Umfang hängt von deiner Branche, dem Wettbewerb und dem aktuellen Zustand deiner Website ab. Wir geben dir eine realistische Einschätzung.' },
  { q: 'Wann sehe ich erste Ergebnisse?', a: 'Erste Ranking-Verbesserungen sehen wir typischerweise nach 3-6 Monaten. Signifikante Ergebnisse wie Top-3-Rankings für umkämpfte Keywords können 6-12 Monate dauern. Dafür sind die Ergebnisse nachhaltig, kein Anzeigenbudget, das irgendwann leer ist.' },
  { q: 'Was bedeutet Branchenexklusivität konkret?', a: 'Wir betreuen pro Branche und Region genau einen Kunden. Wenn du z.B. Zahnarzt in München bist, wird kein anderer Zahnarzt in München von uns betreut. Deine Keywords, deine Content-Strategie und deine Backlinks bleiben exklusiv.' },
  { q: 'Wie unterscheidet sich sagemedia von anderen SEO-Agenturen?', a: 'Drei Dinge: (1) Branchenexklusivität, keine Interessenkonflikte. (2) Eigene, im Wettbewerb validierte Methodik. (3) Volle Transparenz über ein Echtzeit-Dashboard statt monatlicher PDFs. Plus: Wir optimieren bereits für KI-Suchsysteme wie ChatGPT und Google AI Overviews.' },
  { q: 'Gibt es eine Mindestvertragslaufzeit?', a: 'Unsere Verträge haben eine Mindestlaufzeit von 6 Monaten, weil SEO Zeit braucht, um Wirkung zu entfalten. Danach monatlich kündbar. Unsere durchschnittliche Kundenbindung liegt bei über 24 Monaten, weil die Ergebnisse für sich sprechen.' },
  { q: 'Kann ich SEO nicht einfach selbst machen?', a: 'Grundlegendes SEO kann man selbst umsetzen. Für nachhaltige Ergebnisse in umkämpften Branchen braucht es tiefgreifende Expertise, professionelle Tools (Ahrefs, Screaming Frog, etc.) und laufende Anpassung an Algorithmus-Updates. Unsere Methodik wurde unter Wettbewerbsbedingungen validiert.' },
]

const caseStudies = [
  { ytId: '2wpHWuAU8Zc', title: 'Energieversum: 100+ Leads/Monat', metric: '44.362', metricLabel: 'Org. Traffic', industry: 'Photovoltaik' },
  { ytId: '4nF2yb1rAzU', title: 'Beamtenberater: 88.586 Klicks/Monat', metric: '15.238', metricLabel: 'Keywords', industry: 'Versicherung' },
  { ytId: 'mTW5nOlHcpo', title: 'Cherry-Bikes: 470 Conversions/Monat', metric: '9.303', metricLabel: 'Keywords', industry: 'E-Commerce' },
  { ytId: 'S8fPqe5PWbQ', title: 'Iris Haag: +5.000% Traffic-Wachstum', metric: '+5.000%', metricLabel: 'Traffic', industry: 'Coaching' },
]

const processSteps = [
  { step: '01', title: 'Erstgespräch & Branchencheck', desc: 'Wir prüfen ob deine Branche und Region noch verfügbar ist. In einem 30-minütigen Call besprechen wir deine Ziele, deinen Wettbewerb und ob wir der richtige Partner sind.', detail: 'Kostenlos & unverbindlich' },
  { step: '02', title: 'SEO-Audit & Strategie', desc: 'Technischer Audit deiner Website, Wettbewerbsanalyse, Keyword-Recherche und Content-Gap-Analyse. Daraus entsteht deine individuelle SEO-Roadmap mit klaren KPIs.', detail: 'Innerhalb von 2 Wochen' },
  { step: '03', title: 'Umsetzung & Optimierung', desc: 'Technische Optimierung, Content-Erstellung, Schema-Markup und Linkaufbau. Alles dokumentiert, nachvollziehbar und auf dein Geschäftsmodell zugeschnitten.', detail: 'Monatliche Sprints' },
  { step: '04', title: 'Reporting & Skalierung', desc: 'Echtzeit-Dashboard mit Rankings, Traffic und Conversions. Monatliches Reporting, iterative Optimierung und Skalierung erfolgreicher Maßnahmen.', detail: 'Dashboard mit Echtzeitdaten' },
]
---

<Layout title="SEO-Agentur, Branchenexklusiv & datengetrieben | sagemedia" description="SEO-Agentur mit Branchenexklusivität: Wir betreuen nur einen Kunden pro Branche. 100.000+ Rankings, 648% Ø-Wachstum, SEO-Contest Gewinner 2021. Jetzt Verfügbarkeit prüfen.">
  <Header />

  <main class="pt-18">

    <!-- HERO -->
    <HeroPage
      eyebrow="SEO-Agentur"
      titleLine1="Deine Branche."
      titleLine2="Dein Ranking."
      subtitle="Wir betreuen pro Branche und Region nur einen Kunden. Deine SEO-Strategie wird nie für deinen Wettbewerber eingesetzt. Validiert durch den Gewinn des deutschen SEO-Contests 2021."
      ctaText="Verfügbarkeit prüfen"
      secondaryText="Ergebnisse ansehen"
      secondaryHref="#ergebnisse"
      breadcrumbs={[
        { label: 'Home', href: '/' },
        { label: 'Leistungen', href: '/leistungen' },
        { label: 'SEO' }
      ]}
    >
      <!-- Dashboard Visual -->
      <div class="relative" slot="visual">
        <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>
        <div class="absolute -inset-6 rounded-[2rem] border border-emerald-500/10 animate-pulse"></div>

        <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
              <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-wider">Live Dashboard</span>
            </div>
            <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">+648%</span>
          </div>

          <div class="flex items-end gap-[6px] h-36 mb-6" id="hero-chart">
            {[18,22,19,28,35,45,58,72,68,82,91,100].map((h, i) => {
              const bg = i < 4
                ? '#e5e7eb'
                : i < 7
                  ? 'linear-gradient(to top, #6ee7b7, #a7f3d0)'
                  : i < 9
                    ? 'linear-gradient(to top, #34d399, #6ee7b7)'
                    : 'linear-gradient(to top, #10b981, #34d399)'
              return (
                <div
                  class="flex-1 rounded-sm chart-bar transition-all duration-300"
                  style={`height: ${h}%; opacity: 0; background: ${bg};`}
                  data-delay={i * 80}
                />
              )
            })}
          </div>

          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>

          <div class="grid grid-cols-3 gap-6">
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Keywords</p>
              <p class="text-2xl font-extrabold text-gray-900 tracking-tight counter" data-target="1247">0</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">DR Score</p>
              <p class="text-2xl font-extrabold text-gray-900 tracking-tight counter" data-target="89">0</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Wachstum</p>
              <p class="text-2xl font-extrabold text-emerald-600 tracking-tight">
                <span class="counter" data-target="648">0</span><span class="text-lg">%</span>
              </p>
            </div>
          </div>
        </div>

        <div class="absolute -bottom-5 -left-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3 hero-badge">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_16px_rgba(16,185,129,0.4)]">
            <svg class="w-4 h-4 text-white" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 8l4 4 8-8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-gray-900">Platz 1</p>
            <p class="text-[10px] text-gray-400">SEO-Contest 2021</p>
          </div>
        </div>

        <div class="absolute -top-4 -right-4 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 hero-badge-2">
          <p class="text-xs font-bold text-gray-900">15+ Jahre</p>
          <p class="text-[10px] text-gray-400">SEO-Erfahrung</p>
        </div>
      </div>

      <TrustLogos class="mt-16 hero-trust" slot="trust" />

    </HeroPage>

    <!-- PROBLEM -->
    <section class="relative py-24 md:py-32 bg-gray-950 text-white overflow-hidden noise-bg">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent divider-glow"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/20 to-transparent"></div>
      <div class="absolute top-[20%] left-[10%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.1) 0%, transparent 60%);"></div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="max-w-3xl mx-auto text-center mb-16 fade-up">
          <div class="inline-flex items-center gap-2.5 mb-6">
            <span class="inline-block w-8 h-px bg-emerald-400"></span>
            <span class="text-xs font-mono font-medium text-emerald-400 uppercase tracking-[0.2em]">Das Problem</span>
            <span class="inline-block w-8 h-px bg-emerald-400"></span>
          </div>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-[1.1] tracking-[-0.04em]">
            Warum SEO bei den meisten
            <span class="bg-gradient-to-r from-emerald-300 to-emerald-500 bg-clip-text text-transparent"> Agenturen nicht funktioniert</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6 fade-up-stagger">
          {[
            { icon: 'conflict', title: 'Interessenkonflikte', desc: 'Die meisten Agenturen betreuen mehrere Kunden derselben Branche, oft in derselben Stadt. Deine Agentur optimiert gleichzeitig für deinen direkten Wettbewerber.' },
            { icon: 'template', title: 'Template-Strategien', desc: 'Standardisierte Abläufe statt individueller Analyse. Jede Branche, jeder Wettbewerb und jedes Geschäftsmodell braucht eine eigene Strategie, nicht ein Schema F.' },
            { icon: 'blackbox', title: 'Intransparenz', desc: 'Monatliche PDFs mit bunten Grafiken, aber keine echten KPIs. Kein Zugang zu den Tools. Keine Ahnung, wofür das Budget tatsächlich eingesetzt wird.' },
          ].map((item) => (
            <div class="relative bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 hover:bg-white/[0.06] hover:border-red-500/20 transition-all duration-500 fade-up overflow-hidden">
              <div class="w-10 h-10 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center mb-5">
                <svg class="w-5 h-5 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  {item.icon === 'conflict' && <path d="M18 6L6 18M6 6l12 12" />}
                  {item.icon === 'template' && <><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" /><path d="M9 5a2 2 0 012-2h2a2 2 0 012 2v0a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /><path d="M9 12h6M9 16h6" /></>}
                  {item.icon === 'blackbox' && <><path d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M3 3l18 18" /></>}
                </svg>
              </div>
              <h3 class="text-lg font-bold text-white">{item.title}</h3>
              <p class="mt-3 text-sm text-gray-400 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- DIFFERENTIATORS -->
    <section class="relative py-32 md:py-44 bg-gray-50/80" id="vorteile">
      <div class="absolute top-[20%] -left-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 60%);"></div>
      <div class="absolute bottom-[10%] right-[5%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.05) 0%, transparent 60%);"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-12 gap-16 lg:gap-8 items-start">
          <div class="lg:col-span-6 lg:pr-8">
            <div class="flex items-center gap-3 mb-6 fade-up">
              <span class="inline-block w-8 h-px bg-emerald-500"></span>
              <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Dein Vorteil</span>
            </div>
            <h2 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold leading-[1.05] tracking-[-0.04em] text-gray-950 fade-up">
              Was SEO mit sagemedia
              <span class="bg-gradient-to-r from-emerald-600 to-emerald-400 bg-clip-text text-transparent"> anders macht</span>
            </h2>
            <div class="mt-14 space-y-10">
              {[
                { num: '01', title: 'Branchenexklusivität, kein Interessenkonflikt.', text: 'Wir betreuen pro Branche und Region genau einen Kunden. Deine Keywords, deine Content-Strategie und deine Linkbuilding-Maßnahmen werden nie gleichzeitig für deinen Wettbewerber eingesetzt. Das ist unser Kernversprechen.' },
                { num: '02', title: 'Eigene Methodik, validiert im Wettbewerb.', text: 'Organic Ovation ist unsere proprietäre SEO-Methodik, entwickelt über 15 Jahre, validiert durch den Gewinn des deutschen SEO-Contests 2021. Keine Template-Strategien, sondern ein System, das unter Wettbewerbsbedingungen dominiert hat.' },
                { num: '03', title: 'Echte Transparenz mit Echtzeit-Dashboard.', text: 'Du siehst jederzeit, wo du stehst: Rankings, Traffic, Conversions. Kein monatliches PDF, sondern ein Dashboard mit Echtzeitdaten. Jede Maßnahme wird dokumentiert, jeder Euro nachvollziehbar eingesetzt.' },
                { num: '04', title: 'Zukunftssicher: Google + KI-Suche.', text: 'Wir optimieren nicht nur für Google, sondern auch für ChatGPT, Perplexity und Google AI Overviews. Deine Sichtbarkeit ist vorbereitet auf die nächste Generation der Suche, mit GEO, AIO und LLMO.' },
              ].map((item) => (
                <div class="group fade-up">
                  <div class="flex items-start gap-5">
                    <span class="shrink-0 text-xs font-mono font-medium text-emerald-400 mt-1.5 tracking-wider">{item.num}</span>
                    <div>
                      <h3 class="text-xl font-bold text-gray-900 tracking-tight">{item.title}</h3>
                      <p class="mt-2.5 text-gray-500 leading-relaxed">{item.text}</p>
                    </div>
                  </div>
                  <div class="mt-5 ml-10 h-px bg-gradient-to-r from-gray-200 via-emerald-200/30 to-transparent"></div>
                </div>
              ))}
            </div>
            <div class="mt-12 fade-up">
              <a href="/kontakt" class="group inline-flex items-center gap-3 text-gray-900 font-semibold hover:text-emerald-600 transition-colors">
                <span class="w-12 h-12 rounded-full border-2 border-gray-900 group-hover:border-emerald-500 group-hover:bg-emerald-500 group-hover:shadow-[0_0_24px_rgba(16,185,129,0.4)] flex items-center justify-center transition-all duration-300">
                  <svg class="w-4 h-4 group-hover:text-white transition-colors" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                Ist deine Branche noch frei?
              </a>
            </div>
          </div>

          <!-- Awards Visual -->
          <div class="lg:col-span-6 fade-up">
            <div class="relative lg:pl-8">
              <div class="absolute -inset-8 rounded-[2rem]" style="background: radial-gradient(ellipse at 60% 40%, rgba(16,185,129,0.12) 0%, rgba(16,185,129,0.04) 50%, transparent 70%);"></div>
              <div class="relative flex justify-center">
                <img src="/images/awards/sagemedia-pokal-contest.jpg" alt="SEO-Contest 2021, 1. Platz Pokal" class="relative w-64 md:w-72 rounded-2xl shadow-[0_32px_80px_-16px_rgba(0,0,0,0.15)]" loading="lazy" />
              </div>
              <div class="mt-8 grid grid-cols-2 gap-4">
                {[
                  { title: 'SEO-Contest 2021', sub: '1. Platz, deutschlandweit', icon: 'trophy' },
                  { title: 'SEO-Contest 2022', sub: '2 Webseiten in Top 5', icon: 'trophy' },
                  { title: 'Top SEO-Agentur', sub: 'Agenturtipp.de, 2022 & 2023', icon: 'badge' },
                  { title: '5.0 Google Rating', sub: 'Durchschnitt aller Reviews', icon: 'star' },
                ].map((a) => (
                  <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-gray-100 hover:border-emerald-200 transition-colors shadow-[0_4px_16px_rgba(0,0,0,0.04)]">
                    <div class="shrink-0 w-9 h-9 rounded-lg bg-emerald-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        {a.icon === 'trophy' && <><path d="M6 9H4.5a2.5 2.5 0 010-5H6" /><path d="M18 9h1.5a2.5 2.5 0 000-5H18" /><path d="M4 22h16" /><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22" /><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22" /><path d="M18 2H6v7a6 6 0 0012 0V2z" /></>}
                        {a.icon === 'badge' && <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138c.2.686.81 1.237 1.502 1.437a3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0" />}
                        {a.icon === 'star' && <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />}
                      </svg>
                    </div>
                    <div>
                      <p class="text-sm font-bold text-gray-900">{a.title}</p>
                      <p class="text-xs text-gray-400 mt-0.5">{a.sub}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LEISTUNGEN -->
    <ServicesGrid
      eyebrow="Was du bekommst"
      title="SEO-Leistungen"
      titleAccent=" im Überblick"
      subtitle="Keine Einzelmaßnahmen, sondern ein ganzheitliches System, individuell auf deine Branche zugeschnitten."
      services={[
        { href: '#leistungen', icon: 'search', title: 'Technisches SEO', desc: 'Core Web Vitals, Crawling, Indexierung, Schema Markup, Mobile-Optimierung und Ladezeit, die technische Basis für alles Weitere.' },
        { href: '#leistungen', icon: 'bulb', title: 'Content-Strategie', desc: 'Keyword-Recherche, Suchintention-Analyse, Themencluster und Content-Erstellung. Inhalte, die ranken und konvertieren.' },
        { href: '#leistungen', icon: 'cursor', title: 'Linkbuilding & Digital PR', desc: 'Qualitative Backlinks, Gastbeiträge und Brand-Aufbau. Strategischer Autoritätsaufbau statt gekaufter Links.' },
        { href: '#leistungen', icon: 'layout', title: 'OnPage-Optimierung', desc: 'Meta-Tags, Heading-Struktur, interne Verlinkung, Bilder-SEO und URL-Architektur. Jede Seite wird zum Asset.' },
        { href: '#leistungen', icon: 'monitor', title: 'Lokales SEO', desc: 'Google Business Profile, lokale Keywords, NAP-Konsistenz und Bewertungsmanagement, für Unternehmen mit regionalem Fokus.' },
        { href: '#leistungen', icon: 'people', title: 'Monitoring & Reporting', desc: 'Echtzeit-Dashboard, Google Search Console, Ahrefs-Daten und monatliches Reporting. Volle Transparenz über jeden KPI.' },
      ]}
    />

    <!-- PROZESS -->
    <ProcessTimeline
      title="In 4 Schritten zu"
      titleAccent=" messbaren Ergebnissen"
      subtitle="Vom ersten Gespräch bis zum wachsenden Traffic, strukturiert, transparent und ohne versteckte Kosten."
      steps={processSteps}
    />

    <!-- ERGEBNISSE -->
    <CaseStudies cases={caseStudies} />

    <!-- STATS -->
    <StatsStrip stats={[
      { val: '100k+', label: 'Rankings erzielt' },
      { val: '648%', label: 'Ø Traffic-Wachstum' },
      { val: '24+', label: 'Monate Kundenbindung' },
      { val: '5.0', label: 'Google Bewertung' },
    ]} />

    <!-- KUNDENSTIMMEN -->
    <Testimonials videos={videoTestimonials} reviews={textReviews} />

    <!-- FAQ -->
    <FaqSection
      title="Häufige Fragen"
      titleAccent="zu unserer SEO-Betreuung"
      subtitle="Die wichtigsten Antworten vor deinem Erstgespräch."
      faqs={seoFaqs}
    />

    <!-- CTA -->
    <CtaSection
      title="Ist deine Branche"
      titleAccent="noch verfügbar?"
      subtitle="Wir betreuen nur einen Kunden pro Branche und Region. Prüfe jetzt, ob dein Exklusivplatz noch frei ist, kostenlos und unverbindlich."
      ctaText="Verfügbarkeit prüfen"
    />

  </main>

  <Footer />
  <VideoLightbox />

  <!-- Schema: FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
