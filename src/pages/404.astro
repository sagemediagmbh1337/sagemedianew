---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
---

<Layout title="404 – Seite nicht gefunden | sagemedia">
  <Header />
  <main class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
    <p class="text-emerald-500 font-semibold text-lg mb-2">404</p>
    <h1 class="text-4xl font-bold text-gray-950 mb-4">Seite nicht gefunden</h1>
    <p class="text-gray-600 mb-8 max-w-md">Die angeforderte Seite existiert nicht oder wurde verschoben.</p>
    <a
      href="/v2/"
      class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-6 py-3 text-white font-medium hover:bg-emerald-700 transition-colors"
    >
      Zur Startseite
    </a>
  </main>
  <Footer />
</Layout>
