---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import HeroPage from '../../components/HeroPage.astro'
import StatsStrip from '../../components/StatsStrip.astro'
import CaseGrid from '../../components/CaseGrid.astro'
import CtaSection from '../../components/CtaSection.astro'
import VideoLightbox from '../../components/VideoLightbox.astro'
import TrustLogos from '../../components/TrustLogos.astro'
import { cases } from '../../data/cases'

const breadcrumbs = [
  { label: 'Home', href: '/v2/' },
  { label: 'Ergebnisse' },
]
---

<Layout title="Ergebnisse — Echte Case Studies | sagemedia" description="Keine Pitchdecks, sondern Ergebnisse. Entdecke, was wir für unsere Kunden aufgebaut haben.">
  <Header />

  <main class="pt-18">

    <HeroPage
      eyebrow="Case Studies"
      titleLine1="Echte Ergebnisse."
      titleLine2="Nicht nur Versprechen."
      subtitle="Keine Stockfotos, keine erfundenen Zahlen. Unsere Kunden sprechen selbst über ihre Ergebnisse."
      ctaText="Erstgespräch vereinbaren"
      secondaryText="Direkt zu den Cases"
      secondaryHref="#cases"
      breadcrumbs={breadcrumbs}
    >
      <div class="relative" slot="visual">
        <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>

        <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
          <!-- Header -->
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
              <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-wider">Ergebnisse</span>
            </div>
            <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">10 Projekte</span>
          </div>

          <!-- Growth Chart -->
          <div class="flex items-end gap-[6px] h-28 mb-6">
            {[14,18,16,24,32,42,55,68,62,78,88,100].map((h, i) => {
              const bg = i < 3
                ? '#e5e7eb'
                : i < 6
                  ? 'linear-gradient(to top, #6ee7b7, #a7f3d0)'
                  : i < 9
                    ? 'linear-gradient(to top, #34d399, #6ee7b7)'
                    : 'linear-gradient(to top, #10b981, #34d399)'
              return (
                <div
                  class="flex-1 rounded-sm"
                  style={`height: ${h}%; background: ${bg};`}
                />
              )
            })}
          </div>

          <!-- Metrics Row -->
          <div class="space-y-2.5 mb-6">
            <div class="flex items-center justify-between p-3 bg-gray-50/80 rounded-xl border border-gray-100">
              <div class="flex items-center gap-2.5">
                <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
                <span class="text-sm text-gray-600">Organic Traffic</span>
              </div>
              <span class="text-sm font-extrabold text-emerald-600">+648%</span>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-50/80 rounded-xl border border-gray-100">
              <div class="flex items-center gap-2.5">
                <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
                <span class="text-sm text-gray-600">Keyword Rankings</span>
              </div>
              <span class="text-sm font-extrabold text-gray-900">100k+</span>
            </div>
            <div class="flex items-center justify-between p-3 bg-gray-50/80 rounded-xl border border-gray-100">
              <div class="flex items-center gap-2.5">
                <div class="w-2 h-2 rounded-full bg-gray-300"></div>
                <span class="text-sm text-gray-600">Kundenbindung</span>
              </div>
              <span class="text-sm font-extrabold text-gray-900">24+ Monate</span>
            </div>
          </div>

          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>

          <!-- Aggregate Stats -->
          <div class="grid grid-cols-3 gap-4">
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Branchen</p>
              <p class="text-xl font-extrabold text-gray-900 tracking-tight">10</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Ø Wachstum</p>
              <p class="text-xl font-extrabold text-emerald-600 tracking-tight">648%</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Kundenbindung</p>
              <p class="text-xl font-extrabold text-gray-900 tracking-tight">24+ Mo</p>
            </div>
          </div>
        </div>

        <!-- Floating Badge -->
        <div class="absolute -bottom-5 -left-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_16px_rgba(16,185,129,0.4)]">
            <svg class="w-4 h-4 text-white" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 8l4 4 8-8" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>
          <div>
            <p class="text-xs font-bold text-gray-900">100k+ Rankings</p>
            <p class="text-[10px] text-gray-400">Über alle Projekte</p>
          </div>
        </div>
      </div>

      <TrustLogos class="mt-16 hero-trust" slot="trust" />
    </HeroPage>

    <StatsStrip stats={[
      { val: '100k+', label: 'Rankings erzielt' },
      { val: '648%', label: 'Ø Traffic-Wachstum' },
      { val: '24+', label: 'Monate Kundenbindung' },
      { val: '1', label: 'Kunde pro Branche' },
    ]} />

    <CaseGrid
      cases={cases}
      subtitle="10 Projekte aus 10 Branchen. Von Photovoltaik bis Personalvermittlung."
    />

    <CtaSection
      title="Bereit für deine"
      titleAccent="Erfolgsgeschichte?"
      subtitle="Wir zeigen dir in einem kostenlosen Erstgespräch, welche Ergebnisse in deiner Branche möglich sind."
      ctaText="Erstgespräch vereinbaren"
    />

  </main>

  <Footer />
  <VideoLightbox />
</Layout>
