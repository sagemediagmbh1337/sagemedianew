---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import HeroPage from '../../components/HeroPage.astro'
import Section from '../../components/Section.astro'
import SectionHeader from '../../components/SectionHeader.astro'
import CtaSection from '../../components/CtaSection.astro'
import FaqSection from '../../components/FaqSection.astro'
import StatsStrip from '../../components/StatsStrip.astro'
import CaseStudies from '../../components/CaseStudies.astro'
import Testimonials from '../../components/Testimonials.astro'
import ProcessTimeline from '../../components/ProcessTimeline.astro'
import VideoLightbox from '../../components/VideoLightbox.astro'
import ServicesGrid from '../../components/ServicesGrid.astro'
import TrustLogos from '../../components/TrustLogos.astro'

import SeoProblems from '../../components/seo-agentur/SeoProblems.astro'
import SeoVsSea from '../../components/seo-agentur/SeoVsSea.astro'
import LinkAccordion from '../../components/seo-agentur/LinkAccordion.astro'

import { getCollection } from 'astro:content'
import { videoTestimonials, textReviews } from '../../data/testimonials'
import { seoFaqs, seoCaseStudies, seoProcessSteps, seoServices, seoStats, cities, branches, buildSeoSchema } from '../../data/seo-agentur'

const schema = buildSeoSchema('/seo-agentur')

const cityPages = await getCollection('seoCity')
const citySlugs = new Set(cityPages.map(e => e.data.city))

const cityItems = cities.map(c => ({
  label: c,
  href: citySlugs.has(c) ? `/v2/seo-agentur/${c.toLowerCase().replace(/\s+/g, '-').replace(/ü/g, 'ue').replace(/ö/g, 'oe').replace(/ä/g, 'ae').replace(/ß/g, 'ss')}` : undefined,
}))

const branchItems = branches.map(b => ({ label: b }))

const checklist = [
  { title: 'Nachweisbare Ergebnisse', desc: 'Echte Case Studies mit konkreten Zahlen statt leere Versprechen. Eine professionelle SEO-Agentur zeigt, was sie für andere Kunden erreicht hat.', icon: 'chart' },
  { title: 'Transparente Arbeitsweise', desc: 'Zugang zu einem Echtzeit-Dashboard statt monatlicher PDF-Reports. Du solltest jederzeit sehen, wofür dein SEO-Dienstleister das Budget einsetzt.', icon: 'eye' },
  { title: 'Individuelle Strategie', desc: 'Keine Template-Lösungen. Jede Branche, jedes Geschäftsmodell und jeder Wettbewerb erfordert eine maßgeschneiderte Suchmaschinenoptimierung.', icon: 'compass' },
  { title: 'Technische Kompetenz', desc: 'Von Core Web Vitals über Schema Markup bis hin zu JavaScript-Rendering — eine Internetagentur für SEO muss die technische Seite beherrschen.', icon: 'cpu' },
  { title: 'Content-Expertise', desc: 'Google-Optimierung ohne hochwertigen Content funktioniert nicht. Die SEO-Firma muss Suchintentionen verstehen und Inhalte erstellen, die ranken und konvertieren.', icon: 'pen' },
  { title: 'Zukunftsorientierung', desc: 'Google AI Overviews, ChatGPT, Perplexity — eine moderne Agentur für Suchmaschinenoptimierung optimiert auch für KI-Suchsysteme und die Zukunft der Suche.', icon: 'sparkle' },
]

const onpageItems = [
  { title: 'Keyword-Recherche & Suchintention', desc: 'Identifikation der relevantesten Keywords und Analyse der Suchintention für jede Zielseite.', icon: 'search' },
  { title: 'Content-Optimierung & Erstellung', desc: 'SEO-optimierte Inhalte, die Suchintentionen bedienen, Nutzer überzeugen und Conversions generieren.', icon: 'edit' },
  { title: 'Meta-Tags & Heading-Struktur', desc: 'Title-Tags, Meta-Descriptions und H1-H6 Hierarchie für optimale Auslesbarkeit durch Suchmaschinen.', icon: 'code' },
  { title: 'Technisches SEO', desc: 'Core Web Vitals, Ladezeit, Crawling, Indexierung, Mobile-Optimierung und Schema Markup.', icon: 'zap' },
  { title: 'Interne Verlinkung & URL-Architektur', desc: 'Optimierung der Seitenstruktur und internen Links für bessere Nutzerführung und Crawlbarkeit.', icon: 'git' },
  { title: 'Bilder-SEO', desc: 'Alt-Tags, Komprimierung, Next-Gen-Formate und Dateinamen für mehr Sichtbarkeit in der Google Bildersuche.', icon: 'image' },
]

const offpageItems = [
  { title: 'Strategisches Linkbuilding', desc: 'Aufbau hochwertiger Backlinks durch Gastbeiträge, digitale PR und Content-Kooperationen.', icon: 'link' },
  { title: 'Wettbewerbsanalyse & Backlink-Audit', desc: 'Analyse deines Backlink-Profils und der Konkurrenz, um Potenziale und toxische Links zu identifizieren.', icon: 'shield' },
  { title: 'Content-Marketing & Digital PR', desc: 'Erstellung teilbarer Inhalte, Infografiken und Studien, die natürlich verlinkt und geteilt werden.', icon: 'share' },
  { title: 'Brand Mentions & Reputation', desc: 'Überwachung von Markenerwähnungen und Aufbau einer starken Online-Reputation als Ranking-Signal.', icon: 'at' },
  { title: 'Lokale SEO-Signale', desc: 'Google Business Profile, lokale Verzeichnisse, NAP-Konsistenz und Bewertungsmanagement.', icon: 'map' },
  { title: 'Social Signals & Community', desc: 'Strategische Präsenz auf relevanten Plattformen für Brand-Awareness und Referral-Traffic.', icon: 'users' },
]

const deepDive = [
  { num: '01', title: 'Die Aufgabe einer SEO-Agentur', type: 'pillars' as const },
  { num: '02', title: 'Für wen lohnt sich eine SEO-Agentur?', type: 'audience' as const },
  { num: '03', title: 'Wie viel kostet eine SEO-Agentur?', type: 'pricing' as const },
  { num: '04', title: 'SEO-Agentur beauftragen: Darauf achten', type: 'tips' as const },
]

const iconPaths: Record<string, string> = {
  search: 'M11 11a8 8 0 100-16 8 8 0 000 16zM21 21l-4.35-4.35',
  edit: 'M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z',
  code: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
  zap: 'M13 2L3 14h9l-1 8 10-12h-9l1-8',
  git: 'M18 18a3 3 0 100-6 3 3 0 000 6zM6 6a3 3 0 100-6 3 3 0 000 6zM6 21V9a9 9 0 009 9',
  image: 'M3 3h18a2 2 0 012 2v14a2 2 0 01-2 2H3a2 2 0 01-2-2V5a2 2 0 012-2z',
  link: 'M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  share: 'M18 5a3 3 0 100-6 3 3 0 000 6zM6 12a3 3 0 100-6 3 3 0 000 6zM18 19a3 3 0 100-6 3 3 0 000 6z',
  at: 'M12 12a4 4 0 100-8 4 4 0 000 8zM16 8v5a3 3 0 006 0v-1a10 10 0 10-3.92 7.94',
  map: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z',
  users: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75',
  chart: 'M18 20V10M12 20V4M6 20v-6',
  eye: 'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z',
  compass: 'M12 12a10 10 0 100-20 10 10 0 000 20z',
  cpu: 'M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2zM9 9h6v6H9z',
  pen: 'M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z',
  sparkle: 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z',
}
---

<Layout title="SEO-Agentur Deutschland — Professionelle Suchmaschinenoptimierung | sagemedia" description="SEO-Agentur mit Branchenexklusivität: Professionelle Suchmaschinenoptimierung von einer SEO-Firma, die nur einen Kunden pro Branche betreut. 100.000+ Rankings, 648% Ø-Wachstum. Jetzt Verfügbarkeit prüfen.">
  <Header />

  <main class="pt-18">

    <!-- 1. HERO -->
    <HeroPage
      eyebrow="SEO-Agentur"
      titleLine1="Deine SEO-Agentur."
      titleLine2="Exklusiv für dich."
      subtitle="Professionelle Suchmaschinenoptimierung mit Branchenexklusivität. Wir betreuen nur einen Kunden pro Branche und Region — keine geteilten Strategien, keine Interessenkonflikte. Validiert durch den Gewinn des deutschen SEO-Contests 2021."
      ctaText="Verfügbarkeit prüfen"
      secondaryText="Ergebnisse ansehen"
      secondaryHref="#ergebnisse"
      breadcrumbs={[{ label: 'Home', href: '/v2/' }, { label: 'SEO-Agentur' }]}
    >
      <div class="relative" slot="visual">
        <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>
        <div class="absolute -inset-6 rounded-[2rem] border border-emerald-500/10 animate-pulse"></div>

        <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
              <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-[0.2em]">Live Dashboard</span>
            </div>
            <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">+648%</span>
          </div>
          <div class="flex items-end gap-[6px] h-36 mb-6" id="hero-chart">
            {[18,22,19,28,35,45,58,72,68,82,91,100].map((h, i) => (
              <div
                class="flex-1 rounded-sm chart-bar transition-all duration-300"
                style={`height: ${h}%; opacity: 0; background: ${i < 4 ? '#e5e7eb' : i < 7 ? 'linear-gradient(to top, #6ee7b7, #a7f3d0)' : i < 9 ? 'linear-gradient(to top, #34d399, #6ee7b7)' : 'linear-gradient(to top, #10b981, #34d399)'};`}
                data-delay={i * 80}
              />
            ))}
          </div>
          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>
          <div class="grid grid-cols-3 gap-6">
            <div>
              <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-400 mb-1">Keywords</p>
              <p class="text-2xl font-extrabold text-gray-900 tracking-tight counter" data-target="100000">0</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-400 mb-1">Projekte</p>
              <p class="text-2xl font-extrabold text-gray-900 tracking-tight counter" data-target="10">0</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-gray-400 mb-1">Wachstum</p>
              <p class="text-2xl font-extrabold text-emerald-600 tracking-tight"><span class="counter" data-target="648">0</span><span class="text-lg">%</span></p>
            </div>
          </div>
        </div>
        <div class="absolute -bottom-5 -left-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3 hero-badge">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_16px_rgba(16,185,129,0.4)]">
            <svg class="w-4 h-4 text-white" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 8l4 4 8-8" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </div>
          <div><p class="text-xs font-bold text-gray-900">Platz 1</p><p class="text-[10px] text-gray-400">SEO-Contest 2021</p></div>
        </div>
        <div class="absolute -top-4 -right-4 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 hero-badge-2">
          <p class="text-xs font-bold text-gray-900">15+ Jahre</p><p class="text-[10px] text-gray-400">SEO-Erfahrung</p>
        </div>
      </div>
      <TrustLogos class="mt-16 hero-trust" slot="trust" />
    </HeroPage>


    <!-- 2. PROBLEM (Dark) -->
    <SeoProblems />


    <!-- 3. DIFFERENTIATORS (Gray) -->
    <section class="relative py-32 md:py-44 bg-gray-50/80 overflow-hidden" id="vorteile">
      <div class="absolute top-[20%] -left-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 60%);"></div>
      <div class="absolute bottom-[10%] right-[5%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.05) 0%, transparent 60%);"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-12 gap-16 lg:gap-8 items-start">
          <div class="lg:col-span-6 lg:pr-8">
            <div class="flex items-center gap-3 mb-6 fade-up">
              <span class="inline-block w-8 h-px bg-emerald-500"></span>
              <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Warum sagemedia</span>
            </div>
            <h2 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold leading-[1.05] tracking-[-0.04em] text-gray-950 fade-up">
              Die SEO-Agentur, die<span class="bg-gradient-to-r from-emerald-600 to-emerald-400 bg-clip-text text-transparent"> anders arbeitet</span>
            </h2>
            <div class="mt-14 space-y-10">
              {[
                { num: '01', title: 'Branchenexklusivität statt Massenabfertigung.', text: 'Pro Branche und Region genau ein Kunde. Deine Keywords, dein Content und dein Linkprofil werden nie für einen Wettbewerber eingesetzt. Dieses Prinzip eliminiert Interessenkonflikte und ist unser Kernversprechen seit Tag eins.' },
                { num: '02', title: 'Eigene Methodik, validiert unter Wettbewerbsdruck.', text: 'Organic Ovation ist unsere proprietäre SEO-Methodik — entwickelt über 15 Jahre, perfektioniert durch den Gewinn des deutschen SEO-Contests 2021 gegen die besten SEOs Deutschlands.' },
                { num: '03', title: 'Volle Transparenz statt monatlicher PDFs.', text: 'Rankings, Traffic, Conversions — alles in einem Echtzeit-Dashboard. Jede Maßnahme dokumentiert, jeder Euro nachvollziehbar eingesetzt. Kein Blackbox-SEO.' },
                { num: '04', title: 'Zukunftssicher: Google, ChatGPT & KI-Suche.', text: 'Wir optimieren nicht nur für Google, sondern auch für ChatGPT, Perplexity und Google AI Overviews. GEO, AIO und LLM-Optimierung sind fester Bestandteil unserer Strategie.' },
              ].map((item) => (
                <div class="group fade-up">
                  <div class="flex items-start gap-5">
                    <span class="shrink-0 text-xs font-mono font-medium text-emerald-400 mt-1.5 tracking-[0.2em]">{item.num}</span>
                    <div>
                      <h3 class="text-xl font-bold text-gray-900 tracking-tight">{item.title}</h3>
                      <p class="mt-2.5 text-gray-500 leading-relaxed">{item.text}</p>
                    </div>
                  </div>
                  <div class="mt-5 ml-10 h-px bg-gradient-to-r from-gray-200 via-emerald-200/30 to-transparent"></div>
                </div>
              ))}
            </div>
            <div class="mt-12 fade-up">
              <a href="/v2/kontakt" class="group inline-flex items-center gap-3 text-gray-900 font-semibold hover:text-emerald-600 transition-colors">
                <span class="w-12 h-12 rounded-full border-2 border-gray-900 group-hover:border-emerald-500 group-hover:bg-emerald-500 group-hover:shadow-[0_0_24px_rgba(16,185,129,0.4)] flex items-center justify-center transition-all duration-300">
                  <svg class="w-4 h-4 group-hover:text-white transition-colors" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </span>
                Ist deine Branche noch frei?
              </a>
            </div>
          </div>

          <div class="lg:col-span-6 fade-up">
            <div class="relative lg:pl-8">
              <div class="absolute -inset-8 rounded-[2rem]" style="background: radial-gradient(ellipse at 60% 40%, rgba(16,185,129,0.12) 0%, rgba(16,185,129,0.04) 50%, transparent 70%);"></div>
              <div class="relative flex justify-center">
                <img src="/v2/images/awards/sagemedia-pokal-contest.jpg" alt="SEO-Contest 2021, 1. Platz Pokal" class="relative w-64 md:w-72 rounded-2xl shadow-[0_32px_80px_-16px_rgba(0,0,0,0.15)]" loading="lazy" />
              </div>
              <div class="mt-8 grid grid-cols-2 gap-4">
                {[
                  { title: 'SEO-Contest 2021', sub: '1. Platz, deutschlandweit', icon: 'trophy' },
                  { title: 'SEO-Contest 2022', sub: '2 Webseiten in Top 5', icon: 'trophy' },
                  { title: 'Top SEO-Agentur', sub: 'Agenturtipp.de, 2022 & 2023', icon: 'badge' },
                  { title: '5.0 Google Rating', sub: 'Durchschnitt aller Reviews', icon: 'star' },
                ].map((a) => (
                  <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-gray-100 hover:border-emerald-200 transition-colors shadow-[0_4px_16px_rgba(0,0,0,0.04)]">
                    <div class="shrink-0 w-9 h-9 rounded-lg bg-emerald-100 flex items-center justify-center">
                      <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        {a.icon === 'trophy' && <><path d="M6 9H4.5a2.5 2.5 0 010-5H6" /><path d="M18 9h1.5a2.5 2.5 0 000-5H18" /><path d="M4 22h16" /><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22" /><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22" /><path d="M18 2H6v7a6 6 0 0012 0V2z" /></>}
                        {a.icon === 'badge' && <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138c.2.686.81 1.237 1.502 1.437a3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0" />}
                        {a.icon === 'star' && <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />}
                      </svg>
                    </div>
                    <div><p class="text-sm font-bold text-gray-900">{a.title}</p><p class="text-xs text-gray-400 mt-0.5">{a.sub}</p></div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- 4. ERGEBNISSE -->
    <CaseStudies eyebrow="Ergebnisse" title="Echte Kunden." titleAccent=" Echte Zahlen." subtitle="Keine Stockfotos, keine erfundenen Metriken. Unsere Kunden sprechen selbst." cases={seoCaseStudies} showAllLink />

    <!-- 5. STATS -->
    <StatsStrip stats={seoStats} />

    <!-- 6. KUNDENSTIMMEN -->
    <Testimonials eyebrow="Kundenstimmen" title="Was unsere Kunden" titleAccent=" über uns sagen" videos={videoTestimonials} reviews={textReviews} showGoogleBadge />

    <!-- 7. LEISTUNGEN -->
    <ServicesGrid eyebrow="Leistungen" title="Was eine SEO-Agentur" titleAccent=" für dich tut" subtitle="Keine Einzelmaßnahmen, sondern ein ganzheitliches System — individuell auf deine Branche zugeschnitten." services={seoServices} />


    <!-- 8. ONPAGE & OFFPAGE (Dark) -->
    <section class="relative py-32 md:py-44 bg-gray-950 text-white overflow-hidden noise-bg">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent divider-glow"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/20 to-transparent"></div>
      <div class="absolute top-[15%] left-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.1) 0%, transparent 60%);"></div>
      <div class="absolute bottom-[10%] right-[15%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.07) 0%, transparent 60%);"></div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-16 fade-up">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <span class="inline-block w-8 h-px bg-emerald-400"></span>
              <span class="text-xs font-mono font-medium text-emerald-400 uppercase tracking-[0.2em]">SEO-Optimierung im Detail</span>
            </div>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-[1.1] tracking-[-0.04em]">
              OnPage- &<span class="bg-gradient-to-r from-emerald-300 to-emerald-500 bg-clip-text text-transparent"> OffPage-Optimierung</span>
            </h2>
          </div>
          <p class="text-gray-400 leading-relaxed max-w-md">Professionelle Suchmaschinenoptimierung umfasst zwei Disziplinen. Unsere SEO-Agentur beherrscht beide.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {[
            { title: 'OnPage-Optimierung', headerIcon: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8', items: onpageItems },
            { title: 'OffPage-Optimierung', headerIcon: 'M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71', items: offpageItems },
          ].map((col) => (
            <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-8 fade-up">
              <div class="flex items-center gap-3 mb-8 pb-5 border-b border-white/10">
                <div class="w-10 h-10 rounded-xl bg-emerald-500/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={col.headerIcon} /></svg>
                </div>
                <h3 class="text-lg font-bold text-white">{col.title}</h3>
              </div>
              <div class="space-y-0">
                {col.items.map((item) => (
                  <div class="group flex items-start gap-4 py-4 border-b border-white/[0.06] last:border-b-0">
                    <div class="shrink-0 w-8 h-8 rounded-lg bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mt-0.5">
                      <svg class="w-3.5 h-3.5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths[item.icon]} /></svg>
                    </div>
                    <div>
                      <p class="text-sm font-semibold text-white group-hover:text-emerald-300 transition-colors">{item.title}</p>
                      <p class="text-xs text-gray-400 leading-relaxed mt-1">{item.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- 9. PROZESS -->
    <ProcessTimeline title="So arbeitet eine" titleAccent=" professionelle SEO-Agentur" subtitle="Vom ersten Gespräch bis zum messbaren Wachstum — transparent, strukturiert und ohne versteckte Kosten." steps={seoProcessSteps} ctaText="Erstgespräch vereinbaren" />

    <!-- 10. SEO vs. SEA -->
    <SeoVsSea />


    <!-- 11. CHECKLISTE -->
    <Section>
      <SectionHeader eyebrow="Checkliste" title="Woran du eine gute" titleAccent=" SEO-Agentur erkennst" subtitle="6 Kriterien, die du bei der Auswahl deiner SEO-Agentur prüfen solltest." />
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-16 fade-up-stagger">
        {checklist.map((item, i) => (
          <div class="group relative bg-white rounded-2xl border border-gray-100 p-8 hover:border-emerald-200 transition-all duration-500 hover:shadow-[0_16px_48px_-8px_rgba(16,185,129,0.08)] card-lift fade-up">
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl" style="background: radial-gradient(circle at 50% 0%, rgba(16,185,129,0.04) 0%, transparent 60%);"></div>
            <div class="relative">
              <div class="flex items-center gap-4 mb-5">
                <div class="w-10 h-10 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center group-hover:bg-emerald-100 transition-colors">
                  <svg class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths[item.icon]} /></svg>
                </div>
                <span class="text-xs font-mono text-emerald-600 font-medium tracking-[0.2em]">0{i + 1}</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 tracking-tight mb-3">{item.title}</h3>
              <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </Section>


    <!-- 12. CONTENT DEEP-DIVE (Dark) -->
    <section class="relative py-32 md:py-44 bg-gray-950 text-white overflow-hidden noise-bg">
