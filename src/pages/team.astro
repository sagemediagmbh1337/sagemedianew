---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import HeroPage from '../components/HeroPage.astro'
import CtaSection from '../components/CtaSection.astro'
import StatsStrip from '../components/StatsStrip.astro'
import Testimonials from '../components/Testimonials.astro'
import VideoLightbox from '../components/VideoLightbox.astro'
import TrustLogos from '../components/TrustLogos.astro'
import { videoTestimonials, textReviews } from '../data/testimonials'

const teamMembers = [
  { name: 'Janin Schäfer', role: 'Geschäftsführerin & Projektmanagement', image: '/v2/images/janin-schaefer-sagemedia.jpg', initials: 'JS', desc: 'Koordiniert alle Kundenprojekte und sorgt dafür, dass Timelines, Budgets und Qualität stimmen. Strukturiert, lösungsorientiert, immer erreichbar.' },
  { name: 'Saskia A.', role: 'Content-Strategie & SEO', image: '', initials: 'SA', desc: 'Keyword-Recherche, Themencluster und Content-Erstellung. Verbindet Suchintention mit überzeugenden Inhalten, die ranken und konvertieren.' },
  { name: 'Miriam A.', role: 'Projektmanagement & Kundenbetreuung', image: '', initials: 'MA', desc: 'Begleitet Kundenprojekte von der Strategie bis zur Umsetzung. Kommunikationsstark, detailorientiert und immer einen Schritt voraus.' },
]
---

<Layout title="Team, Die Menschen hinter sagemedia" description="Lerne das Team der sagemedia GmbH kennen. SEO-Experten mit 15+ Jahren Erfahrung, Gewinner des SEO-Contests 2021 und Branchenexklusivität als Prinzip.">
  <Header />

  <main class="pt-18">

    <!-- HERO -->
    <HeroPage
      eyebrow="Unser Team"
      titleLine1="Menschen."
      titleLine2="Keine Agentur-Maschine."
      subtitle="Bei sagemedia kennt jeder Kunde sein Team persönlich. Kein Callcenter, kein Junior der dein Projekt betreut, sondern erfahrene Spezialisten, die wissen was sie tun."
      ctaText="Team kennenlernen"
      ctaHref="#team"
      secondaryText="Kontakt aufnehmen"
      secondaryHref="/kontakt"
      breadcrumbs={[
        { label: 'Home', href: '/v2/' },
        { label: 'Team' }
      ]}
    >
      <!-- Visual: Büro -->
      <div class="relative" slot="visual">
        <div class="absolute -inset-8 rounded-[2rem]" style="background: radial-gradient(ellipse at 60% 40%, rgba(16,185,129,0.12) 0%, rgba(16,185,129,0.04) 50%, transparent 70%);"></div>
        <div class="relative aspect-[4/3] bg-gray-100 rounded-[1.5rem] overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,0,0,0.15)]">
          <img src="/v2/images/sagemedia-buero.jpg" alt="sagemedia Agentur, Bad Staffelstein" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-gray-950/30 to-transparent"></div>
          <div class="absolute bottom-4 left-5">
            <p class="text-xs font-medium text-white/70">sagemedia HQ, Bad Staffelstein</p>
          </div>
        </div>

        <div class="absolute -bottom-5 -left-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3 hero-badge">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_16px_rgba(16,185,129,0.4)]">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <div>
            <p class="text-xs font-bold text-gray-900">Kompaktes Team</p>
            <p class="text-[10px] text-gray-400">Persönlich & direkt</p>
          </div>
        </div>

        <div class="absolute -top-4 -right-4 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 hero-badge-2">
          <p class="text-xs font-bold text-gray-900">15+ Jahre</p>
          <p class="text-[10px] text-gray-400">SEO-Erfahrung</p>
        </div>
      </div>

      <TrustLogos class="mt-16 hero-trust" slot="trust" />
    </HeroPage>

    <!-- STATS -->
    <StatsStrip stats={[
      { val: '15+', label: 'Jahre Erfahrung' },
      { val: '100k+', label: 'Rankings erzielt' },
      { val: '#1', label: 'SEO-Contest 2021' },
      { val: '5.0', label: 'Google Bewertung' },
    ]} />

    <!-- GRÜNDER -->
    <section class="relative py-32 md:py-44 overflow-hidden">
      <div class="absolute top-[15%] right-[5%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <!-- Portrait -->
          <div class="lg:col-span-5 fade-up">
            <div class="relative">
              <div class="absolute -inset-6 rounded-[2rem]" style="background: radial-gradient(ellipse at 50% 50%, rgba(16,185,129,0.1) 0%, transparent 65%);"></div>
              <div class="relative aspect-[3/4] bg-gray-100 rounded-[1.5rem] overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,0,0,0.1)]">
                <img src="/v2/images/andre-schaefer-stage.jpg" alt="André Schäfer" class="absolute inset-0 w-full h-full object-cover object-[center_20%]" loading="lazy" />
                <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-gray-900/30 to-transparent"></div>
              </div>

              <div class="absolute -bottom-5 -right-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 p-4 fade-up">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_4px_16px_rgba(16,185,129,0.35)]">
                    <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" /></svg>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-gray-900">15+ Jahre SEO</p>
                    <p class="text-[10px] text-gray-400">Seit 2021 hauptberuflich</p>
                  </div>
                </div>
              </div>

              <div class="absolute -top-3 -left-3 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(245,158,11,0.08)] border border-amber-100/50 px-4 py-3 fade-up">
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  <div>
                    <p class="text-xs font-bold text-gray-900">Platz 1</p>
                    <p class="text-[10px] text-gray-400">SEO-Contest 2021</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="lg:col-span-7">
            <div class="flex items-center gap-3 mb-6 fade-up">
              <span class="inline-block w-8 h-px bg-emerald-500"></span>
              <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Über den Gründer</span>
            </div>

            <h2 class="text-4xl md:text-5xl font-extrabold leading-[1.1] tracking-[-0.04em] text-gray-950 fade-up">André Schäfer</h2>
            <p class="mt-1 text-lg font-mono text-emerald-600 fade-up">Geschäftsführer & SEO-Stratege</p>

            <div class="mt-8 text-gray-600 leading-[1.85] space-y-4 fade-up">
              <p>André beschäftigt sich seit 2009 mit Suchmaschinenoptimierung, zunächst aus Neugier, dann aus Überzeugung. Was als Experiment mit Affiliate-Projekten begann, wurde schnell zur Berufung: die Mechanik hinter Google, Crawlern und Rankings wirklich zu verstehen.</p>
              <p>Nach Stationen in den USA und Kanada gründete er die sagemedia GmbH in Bad Staffelstein, Bayern. Der Ansatz war von Anfang an klar: <strong>ein Kunde pro Branche, eine Region, keine Kompromisse.</strong></p>
              <p>2021 gewann André den deutschen SEO-Contest und bewies damit, dass die selbst entwickelte Organic Ovation Methodik nicht nur in der Theorie funktioniert, sondern unter Wettbewerbsbedingungen dominiert.</p>
            </div>

            <div class="mt-10 grid sm:grid-cols-2 gap-4 fade-up">
              {[
                { icon: 'award', title: 'SEO-Contest Gewinner 2021', sub: 'Platz 1, deutschlandweit' },
                { icon: 'award', title: 'SEO-Contest 2022, Top 5', sub: '2 Webseiten in den Top 5' },
                { icon: 'globe', title: 'Internationale Erfahrung', sub: 'USA, Kanada, Deutschland' },
                { icon: 'bolt', title: 'Organic Ovation Methodik', sub: 'Eigenentwickelt, 100.000+ Rankings' },
              ].map((cred) => (
                <div class="flex items-start gap-3.5 p-4 bg-gray-50/80 rounded-xl border border-gray-100 hover:border-emerald-200 transition-colors">
                  <div class="shrink-0 w-9 h-9 rounded-lg bg-emerald-100 flex items-center justify-center">
                    <svg class="w-4 h-4 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      {cred.icon === 'globe' && <path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />}
                      {cred.icon === 'award' && <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138c.2.686.81 1.237 1.502 1.437a3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0" />}
                      {cred.icon === 'bolt' && <path d="M13 10V3L4 14h7v7l9-11h-7z" />}
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-gray-900">{cred.title}</p>
                    <p class="text-xs text-gray-400 mt-0.5">{cred.sub}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TEAM GRID -->
    <section class="relative py-32 md:py-44 bg-gray-50/80 overflow-hidden" id="team">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
      <div class="absolute top-[20%] left-[5%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 60%);"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="max-w-2xl mb-20">
          <div class="flex items-center gap-3 mb-6 fade-up">
            <span class="inline-block w-8 h-px bg-emerald-500"></span>
            <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Das Team</span>
          </div>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-[-0.04em] text-gray-950 fade-up">
            Kompakt, erfahren,
            <span class="bg-gradient-to-r from-emerald-600 to-emerald-400 bg-clip-text text-transparent"> persönlich</span>
          </h2>
          <p class="mt-6 text-gray-500 leading-relaxed fade-up">
            Kein aufgeblähter Apparat. Jeder im Team ist Spezialist in seinem Bereich und dein direkter Ansprechpartner.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 fade-up-stagger">
          {teamMembers.map((member) => (
            <div class="group relative bg-white rounded-2xl border border-gray-100 hover:border-emerald-200 transition-all duration-500 hover:shadow-[0_16px_48px_-8px_rgba(16,185,129,0.08)] overflow-hidden fade-up card-lift">
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 0%, rgba(16,185,129,0.04) 0%, transparent 60%);"></div>
              <!-- Photo -->
              <div class="aspect-[4/3] bg-gradient-to-br from-gray-50 via-gray-100 to-gray-50 relative overflow-hidden">
                {member.image ? (
                  <img src={member.image} alt={member.name} class="absolute inset-0 w-full h-full object-cover object-[center_30%] group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                ) : (
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-20 h-20 rounded-full bg-gradient-to-br from-emerald-100 to-emerald-200 border-2 border-emerald-300/30 flex items-center justify-center">
                      <span class="text-2xl font-extrabold text-emerald-600">{member.initials}</span>
                    </div>
                  </div>
                )}
              </div>
              <!-- Info -->
              <div class="relative p-6">
                <h3 class="text-lg font-bold text-gray-900 tracking-tight">{member.name}</h3>
                <p class="mt-1 text-sm text-emerald-600 font-mono">{member.role}</p>
                <p class="mt-3 text-sm text-gray-500 leading-relaxed">{member.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WERTE -->
    <section class="relative py-32 md:py-44 bg-gray-950 text-white overflow-hidden noise-bg">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/50 to-transparent divider-glow"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/30 to-transparent"></div>
      <div class="absolute top-[5%] left-[20%] w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.12) 0%, rgba(16,185,129,0.03) 50%, transparent 70%);"></div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="max-w-3xl mx-auto text-center mb-20 fade-up">
          <div class="inline-flex items-center gap-2.5 mb-6">
            <span class="inline-block w-8 h-px bg-emerald-400"></span>
            <span class="text-xs font-mono font-medium text-emerald-400 uppercase tracking-[0.2em]">Unsere Werte</span>
            <span class="inline-block w-8 h-px bg-emerald-400"></span>
          </div>
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold leading-[1.1] tracking-[-0.04em]">
            Woran wir
            <span class="bg-gradient-to-r from-emerald-300 to-emerald-500 bg-clip-text text-transparent"> glauben</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 fade-up-stagger">
          {[
            { title: 'Exklusivität', desc: 'Ein Kunde pro Branche und Region. Dein Erfolg ist nicht verhandelbar und wird nie gegen den deines Wettbewerbers abgewogen.' },
            { title: 'Transparenz', desc: 'Kein Marketing-Sprech, keine versteckten Kosten. Du siehst jederzeit was wir tun, warum wir es tun und was es bringt.' },
            { title: 'Ownership', desc: 'Wir behandeln dein Projekt wie unser eigenes. Keine Ausreden, keine Schuldzuweisungen, nur Ergebnisse und Verantwortung.' },
            { title: 'Langfristigkeit', desc: 'Keine Quick Fixes. Wir bauen nachhaltige Sichtbarkeit auf, die wächst, nicht zusammenbricht, sobald das Budget stoppt.' },
          ].map((value) => (
            <div class="group relative bg-white/[0.03] backdrop-blur-sm border border-white/[0.06] rounded-2xl p-8 hover:bg-white/[0.06] hover:border-emerald-500/20 transition-all duration-500 overflow-hidden fade-up">
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 0%, rgba(16,185,129,0.08) 0%, transparent 60%);"></div>
              <div class="relative">
                <h3 class="text-lg font-bold text-white">{value.title}</h3>
                <p class="mt-3 text-sm text-gray-400 leading-relaxed">{value.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- KUNDENSTIMMEN -->
    <Testimonials videos={videoTestimonials} reviews={textReviews} />

    <!-- CTA -->
    <CtaSection
      title="Bereit, uns"
      titleAccent="kennenzulernen?"
      subtitle="In einem 30-minütigen Call besprechen wir deine Ziele und prüfen ob deine Branche noch verfügbar ist. Kostenlos und unverbindlich."
      ctaText="Erstgespräch vereinbaren"
    />

  </main>

  <Footer />
  <VideoLightbox />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "mainEntity": {
      "@type": "Organization",
      "name": "sagemedia GmbH",
      "url": "https://sagemedia.de",
      "founder": { "@type": "Person", "name": "André Schäfer", "jobTitle": "Geschäftsführer & SEO-Stratege" },
      "address": { "@type": "PostalAddress", "streetAddress": "Goethestraße 12", "addressLocality": "Bad Staffelstein", "postalCode": "96231", "addressCountry": "DE" }
    }
  })} />
</Layout>
