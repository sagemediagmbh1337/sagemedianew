---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import HeroPage from '../../components/HeroPage.astro'
import CtaSection from '../../components/CtaSection.astro'
import TrustLogos from '../../components/TrustLogos.astro'
import VideoLightbox from '../../components/VideoLightbox.astro'

const glossar = [
  { term: 'Above the Fold', category: 'Webdesign', desc: 'Der sichtbare Bereich einer Webseite, den der Nutzer ohne Scrollen sieht. Wichtig f\u00fcr SEO, weil Google bewertet, welcher Content sofort sichtbar ist.' },
  { term: 'Alt-Text', category: 'OnPage SEO', desc: 'Alternativer Text, der Bilder f\u00fcr Suchmaschinen und Screenreader beschreibt. Ein wichtiger Rankingfaktor f\u00fcr die Bildersuche und ein Beitrag zur Barrierefreiheit.' },
  { term: 'Backlink', category: 'OffPage SEO', desc: 'Ein eingehender Link von einer externen Website auf deine Seite. Backlinks sind einer der wichtigsten Rankingfaktoren. Qualit\u00e4t schl\u00e4gt dabei immer Quantit\u00e4t.' },
  { term: 'Bounce Rate', category: 'Analyse', desc: 'Der Prozentsatz der Besucher, die eine Website nach dem Aufruf einer einzigen Seite wieder verlassen. Kann auf irrelevante Inhalte oder schlechte UX hinweisen.' },
  { term: 'Canonical Tag', category: 'Technisches SEO', desc: 'Ein HTML-Element, das Suchmaschinen mitteilt, welche URL die Original-Version einer Seite ist. Verhindert Duplicate-Content-Probleme.' },
  { term: 'Content Gap', category: 'Content', desc: 'Themen oder Keywords, f\u00fcr die deine Wettbewerber ranken, du aber nicht. Eine Content-Gap-Analyse identifiziert Chancen f\u00fcr neue Inhalte.' },
  { term: 'Core Web Vitals', category: 'Technisches SEO', desc: 'Googles Metriken f\u00fcr die Nutzererfahrung: LCP (Largest Contentful Paint), INP (Interaction to Next Paint) und CLS (Cumulative Layout Shift). Seit 2021 Rankingfaktor.' },
  { term: 'Crawling', category: 'Technisches SEO', desc: 'Der Prozess, bei dem Suchmaschinen-Bots Webseiten systematisch durchsuchen und deren Inhalte erfassen. Voraussetzung f\u00fcr Indexierung.' },
  { term: 'Domain Authority', category: 'OffPage SEO', desc: 'Ein von Moz entwickelter Score (0-100), der die Wahrscheinlichkeit vorhersagt, mit der eine Domain in Suchergebnissen rankt.' },
  { term: 'Duplicate Content', category: 'Technisches SEO', desc: 'Identische oder sehr \u00e4hnliche Inhalte unter verschiedenen URLs. Kann zu Ranking-Problemen f\u00fchren, da Suchmaschinen die bevorzugte Version nicht kennen.' },
  { term: 'E-E-A-T', category: 'Content', desc: 'Experience, Expertise, Authoritativeness, Trustworthiness. Googles Qualit\u00e4tskriterien f\u00fcr Inhalte. Besonders wichtig f\u00fcr YMYL-Themen wie Gesundheit und Finanzen.' },
  { term: 'Featured Snippet', category: 'SERP', desc: 'Ein hervorgehobener Textausschnitt direkt \u00fcber den organischen Google-Ergebnissen (Position 0). Beantwortet die Suchanfrage direkt auf der Ergebnisseite.' },
  { term: 'Google AI Overviews', category: 'KI-Suche', desc: 'KI-generierte Zusammenfassungen, die Google direkt in den Suchergebnissen anzeigt. Sie zitieren verschiedene Quellen und ver\u00e4ndern die Interaktion mit Suchergebnissen.' },
  { term: 'Google Search Console', category: 'Analyse', desc: 'Kostenloses Google-Tool mit Daten zu Suchanfragen, Klicks, Impressionen und technischen Problemen deiner Website. Essentiell f\u00fcr jede SEO-Strategie.' },
  { term: 'GEO', category: 'KI-Suche', desc: 'Generative Engine Optimization. Die Optimierung von Inhalten f\u00fcr KI-gest\u00fctzte Suchsysteme wie ChatGPT, Perplexity und Google AI Overviews.' },
  { term: 'Heading-Struktur', category: 'OnPage SEO', desc: 'Die hierarchische Gliederung einer Seite durch HTML-\u00dcberschriften (H1-H6). Hilft Suchmaschinen den Inhalt zu verstehen und verbessert die Barrierefreiheit.' },
  { term: 'Indexierung', category: 'Technisches SEO', desc: 'Der Prozess, bei dem eine gecrawlte Seite in den Google-Index aufgenommen wird. Nur indexierte Seiten k\u00f6nnen in den Suchergebnissen erscheinen.' },
  { term: 'Interne Verlinkung', category: 'OnPage SEO', desc: 'Links innerhalb deiner eigenen Website, die Seiten miteinander verbinden. Strategische interne Verlinkung verteilt Link-Equity und verbessert die Crawlbarkeit.' },
  { term: 'Keyword', category: 'Content', desc: 'Ein Suchbegriff, den Nutzer in Suchmaschinen eingeben. Die Keyword-Recherche ist die Grundlage jeder SEO-Strategie und bestimmt deine Sichtbarkeitsziele.' },
  { term: 'Keyword Difficulty', category: 'Content', desc: 'Ein Score, der angibt, wie schwer es ist, f\u00fcr ein bestimmtes Keyword auf Seite 1 zu ranken. Abh\u00e4ngig von Wettbewerb und Content-Qualit\u00e4t.' },
  { term: 'LLMO', category: 'KI-Suche', desc: 'Large Language Model Optimization. Die Optimierung von Inhalten, damit KI-Modelle dein Unternehmen als vertrauensw\u00fcrdige Quelle erkennen und empfehlen.' },
  { term: 'Local SEO', category: 'OnPage SEO', desc: 'SEO-Ma\u00dfnahmen f\u00fcr lokale Sichtbarkeit: Google Business Profile, lokale Keywords, NAP-Konsistenz (Name, Address, Phone) und Bewertungsmanagement.' },
  { term: 'Meta Description', category: 'OnPage SEO', desc: 'Der Beschreibungstext unter dem Seitentitel in Suchergebnissen. Kein direkter Rankingfaktor, beeinflusst aber die Click-Through-Rate massiv.' },
  { term: 'Meta Title', category: 'OnPage SEO', desc: 'Der Seitentitel in Suchergebnissen und im Browser-Tab. Einer der wichtigsten OnPage-Rankingfaktoren \u2014 sollte das Hauptkeyword enthalten.' },
  { term: 'Nofollow', category: 'OffPage SEO', desc: 'Ein Link-Attribut (rel=nofollow), das Suchmaschinen signalisiert, dem Link nicht zu folgen und keinen PageRank weiterzugeben. Typisch f\u00fcr bezahlte Links.' },
  { term: 'Organischer Traffic', category: 'Analyse', desc: 'Besucher, die \u00fcber unbezahlte Suchergebnisse auf deine Website kommen \u2014 im Gegensatz zu bezahltem Traffic (Google Ads). Das Hauptziel von SEO.' },
  { term: 'PageSpeed', category: 'Technisches SEO', desc: 'Die Ladegeschwindigkeit einer Webseite. Ein Rankingfaktor und entscheidend f\u00fcr die Nutzererfahrung. Wird \u00fcber Core Web Vitals gemessen.' },
  { term: 'Robots.txt', category: 'Technisches SEO', desc: 'Eine Textdatei im Stammverzeichnis einer Website, die Suchmaschinen-Crawlern mitteilt, welche Bereiche gecrawlt werden d\u00fcrfen und welche nicht.' },
  { term: 'Schema Markup', category: 'Technisches SEO', desc: 'Strukturierte Daten im JSON-LD-Format, die Suchmaschinen helfen den Inhalt zu verstehen. Erm\u00f6glicht Rich Snippets in den Suchergebnissen.' },
  { term: 'Search Intent', category: 'Content', desc: 'Die Absicht hinter einer Suchanfrage: informational (lernen), navigational (finden), transactional (kaufen) oder commercial (vergleichen).' },
  { term: 'SERP', category: 'SERP', desc: 'Search Engine Results Page \u2014 die Suchergebnisseite von Google mit organischen Ergebnissen, Anzeigen, Featured Snippets und AI Overviews.' },
  { term: 'Sitemap', category: 'Technisches SEO', desc: 'Eine XML-Datei mit allen wichtigen URLs deiner Website. Hilft Suchmaschinen beim Crawling und wird \u00fcber die Google Search Console eingereicht.' },
  { term: 'Suchvolumen', category: 'Content', desc: 'Die durchschnittliche Anzahl monatlicher Suchanfragen f\u00fcr ein Keyword. Hoher Wert = mehr Traffic-Potenzial, aber auch mehr Wettbewerb.' },
  { term: 'Themencluster', category: 'Content', desc: 'Content-Strategie mit Pillar-Artikel und verlinkten Unterartikeln. Signalisiert Google thematische Autorit\u00e4t und verbessert Rankings f\u00fcr verwandte Keywords.' },
  { term: 'URL-Struktur', category: 'Technisches SEO', desc: 'Die Gestaltung deiner Website-URLs. SEO-freundliche URLs sind kurz, beschreibend, enthalten das Keyword und nutzen Bindestriche als Trennzeichen.' },
]

function toSlug(term: string): string {
  return term
    .toLowerCase()
    .replace(/[\u00e4\u00f6\u00fc\u00df]/g, (c: string) => ({ '\u00e4': 'ae', '\u00f6': 'oe', '\u00fc': 'ue', '\u00df': 'ss' }[c] || c))
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '')
}

const categories = [...new Set(glossar.map(g => g.category))].sort()
const letters = [...new Set(glossar.map(g => g.term[0].toUpperCase()))].sort()
---

<Layout title="SEO-Glossar | Alle Begriffe einfach erkl\u00e4rt | sagemedia" description="SEO-Glossar von A bis Z: Alle wichtigen Begriffe aus SEO, Content, Technik und KI-Suche verst\u00e4ndlich erkl\u00e4rt. Von sagemedia.">
  <Header />

  <main class="pt-18">

    <HeroPage
      eyebrow="SEO-Glossar"
      titleLine1="SEO verstehen."
      titleLine2="Nicht raten."
      subtitle="Alle wichtigen Begriffe aus SEO, Content-Strategie, technischem SEO und KI-Suche \u2014 verst\u00e4ndlich erkl\u00e4rt. Dein Nachschlagewerk f\u00fcr digitale Sichtbarkeit."
      ctaText="Erstgespr\u00e4ch vereinbaren"
      secondaryText="Direkt zum Glossar"
      secondaryHref="#glossar"
      breadcrumbs={[
        { label: 'Home', href: '/' },
        { label: 'Glossar' }
      ]}
    >
      <div class="relative" slot="visual">
        <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>

        <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
              <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-wider">Glossar</span>
            </div>
            <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">{glossar.length} Begriffe</span>
          </div>

          <div class="space-y-3 mb-6">
            {glossar.slice(0, 4).map((g) => (
              <div class="flex items-center justify-between p-3 bg-gray-50/80 rounded-xl border border-gray-100">
                <div class="min-w-0">
                  <span class="text-sm font-semibold text-gray-900">{g.term}</span>
                  <p class="text-[10px] text-gray-400 mt-0.5 truncate">{g.desc}</p>
                </div>
                <span class="text-[10px] font-mono text-emerald-600 bg-emerald-50 border border-emerald-100 px-2 py-0.5 rounded-full shrink-0 ml-3">{g.category}</span>
              </div>
            ))}
          </div>

          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>

          <div class="grid grid-cols-3 gap-4">
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Begriffe</p>
              <p class="text-xl font-extrabold text-gray-900 tracking-tight">{glossar.length}</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Kategorien</p>
              <p class="text-xl font-extrabold text-emerald-600 tracking-tight">{categories.length}</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">A bis Z</p>
              <p class="text-xl font-extrabold text-gray-900 tracking-tight">{letters.length}</p>
            </div>
          </div>
        </div>

        <div class="absolute -bottom-5 -left-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3 hero-badge">
          <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_16px_rgba(16,185,129,0.4)]">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" /><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" /></svg>
          </div>
          <div>
            <p class="text-xs font-bold text-gray-900">Kostenlos</p>
            <p class="text-[10px] text-gray-400">F\u00fcr alle verf\u00fcgbar</p>
          </div>
        </div>
      </div>

      <TrustLogos class="mt-16 hero-trust" slot="trust" />
    </HeroPage>

    <!-- GLOSSAR -->
    <section class="relative py-32 md:py-44 overflow-hidden" id="glossar">
      <div class="absolute top-[15%] right-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">

        <!-- Search & Filters -->
        <div class="mb-16 fade-up">
          <div class="relative max-w-2xl mb-8">
            <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
              <svg class="w-5 h-5 text-gray-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
            </div>
            <input
              type="text"
              id="glossar-search"
              placeholder="Begriff suchen..."
              class="w-full pl-14 pr-28 py-4 bg-white rounded-2xl border border-gray-200 text-base text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-emerald-300 focus:shadow-[0_0_0_4px_rgba(16,185,129,0.1)] transition-all"
            />
            <div class="absolute inset-y-0 right-0 pr-5 flex items-center">
              <span id="result-count" class="text-xs font-mono text-gray-400"></span>
            </div>
          </div>

          <!-- Letter Filter -->
          <div class="flex flex-wrap gap-2 mb-6">
            <button class="letter-btn px-3 py-1.5 rounded-lg text-xs font-mono font-medium border transition-all cursor-pointer bg-emerald-50 text-emerald-600 border-emerald-200" data-letter="all">Alle</button>
            {letters.map(l => (
              <button class="letter-btn px-3 py-1.5 rounded-lg text-xs font-mono font-medium border border-gray-200 text-gray-500 hover:border-emerald-200 hover:text-emerald-600 hover:bg-emerald-50/50 transition-all cursor-pointer" data-letter={l}>{l}</button>
            ))}
          </div>

          <!-- Category Filter -->
          <div class="flex flex-wrap gap-2">
            <button class="cat-btn px-4 py-2 rounded-full text-sm font-medium border transition-all cursor-pointer bg-gray-950 text-white border-gray-950" data-cat="all">Alle Kategorien</button>
            {categories.map(c => (
              <button class="cat-btn px-4 py-2 rounded-full text-sm font-medium border border-gray-200 text-gray-500 hover:border-emerald-200 hover:text-emerald-600 transition-all cursor-pointer" data-cat={c}>{c}</button>
            ))}
          </div>
        </div>

        <!-- Empty State -->
        <div id="empty-state" class="hidden text-center py-20">
          <div class="w-16 h-16 rounded-2xl bg-gray-50 border border-gray-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-gray-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><path d="M21 21l-4.35-4.35" /></svg>
          </div>
          <p class="text-lg font-bold text-gray-900">Kein Begriff gefunden</p>
          <p class="mt-2 text-sm text-gray-400">Versuch einen anderen Suchbegriff oder Filter.</p>
        </div>

        <!-- Glossar Grid -->
        <div id="glossar-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {glossar.map((g) => (
            <div
              class="glossar-item group relative bg-white rounded-2xl border border-gray-100 hover:border-emerald-200 transition-all duration-500 hover:shadow-[0_16px_48px_-8px_rgba(16,185,129,0.08)] overflow-hidden card-lift fade-up"
              data-term={g.term.toLowerCase()}
              data-letter={g.term[0].toUpperCase()}
              data-cat={g.category}
            >
              <a href={"/glossar/" + toSlug(g.term)} class="block p-7">
                <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: radial-gradient(circle at 50% 0%, rgba(16,185,129,0.04) 0%, transparent 60%);"></div>
                <div class="relative">
                  <div class="flex items-start justify-between gap-3 mb-4">
                    <div class="w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center group-hover:bg-emerald-50 group-hover:border-emerald-200 transition-all duration-300 shrink-0">
                      <span class="text-sm font-mono font-bold text-gray-400 group-hover:text-emerald-600 transition-colors">{g.term[0]}</span>
                    </div>
                    <span class="text-[10px] font-mono text-emerald-600 bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full shrink-0">{g.category}</span>
                  </div>
                  <h3 class="text-lg font-bold text-gray-900 tracking-tight group-hover:text-emerald-700 transition-colors">{g.term}</h3>
                  <p class="mt-3 text-sm text-gray-500 leading-relaxed">{g.desc}</p>
                  <div class="mt-4 flex items-center gap-1.5 text-xs font-medium text-emerald-600 opacity-0 group-hover:opacity-100 transition-opacity">
                    <span>Mehr erfahren</span>
                    <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </div>
                </div>
              </a>
            </div>
          ))}
        </div>

      </div>
    </section>

    <CtaSection
      title="SEO nicht nur verstehen,"
      titleAccent="sondern umsetzen?"
      subtitle="Wir machen die Theorie zur Praxis. In einem kostenlosen Erstgespr\u00e4ch zeigen wir dir, wie diese Konzepte konkret f\u00fcr dein Unternehmen funktionieren."
      ctaText="Erstgespr\u00e4ch vereinbaren"
    />

  </main>

  <Footer />
  <VideoLightbox />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "DefinedTermSet",
    "name": "SEO-Glossar",
    "description": "Alle wichtigen SEO-Begriffe verst\u00e4ndlich erkl\u00e4rt.",
    "url": "https://sagemedia.de/glossar",
    "hasDefinedTerm": glossar.map(g => ({
      "@type": "DefinedTerm",
      "name": g.term,
      "description": g.desc,
    }))
  })} />
</Layout>

<script>
  const search = document.getElementById('glossar-search') as HTMLInputElement
  const grid = document.getElementById('glossar-grid')!
  const items = document.querySelectorAll('.glossar-item')
  const letterBtns = document.querySelectorAll('.letter-btn')
  const catBtns = document.querySelectorAll('.cat-btn')
  const resultCount = document.getElementById('result-count')!
  const emptyState = document.getElementById('empty-state')!

  let activeLetter = 'all'
  let activeCat = 'all'

  function updateCount(n: number) {
    resultCount.textContent = n + (n === 1 ? ' Begriff' : ' Begriffe')
  }
  updateCount(items.length)

  function filterItems() {
    const query = search.value.toLowerCase().trim()
    let visible = 0

    items.forEach(item => {
      const el = item as HTMLElement
      const term = el.dataset.term || ''
      const letter = el.dataset.letter || ''
      const cat = el.dataset.cat || ''

      const matchSearch = !query || term.includes(query)
      const matchLetter = activeLetter === 'all' || letter === activeLetter
      const matchCat = activeCat === 'all' || cat === activeCat

      if (matchSearch && matchLetter && matchCat) {
        el.style.display = ''
        visible++
      } else {
        el.style.display = 'none'
      }
    })

    updateCount(visible)
    emptyState.classList.toggle('hidden', visible > 0)
    grid.classList.toggle('hidden', visible === 0)
  }

  search.addEventListener('input', filterItems)

  letterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      letterBtns.forEach(b => {
        b.classList.remove('bg-emerald-50', 'text-emerald-600', 'border-emerald-200')
        b.classList.add('border-gray-200', 'text-gray-500')
      })
      btn.classList.add('bg-emerald-50', 'text-emerald-600', 'border-emerald-200')
      btn.classList.remove('border-gray-200', 'text-gray-500')
      activeLetter = (btn as HTMLElement).dataset.letter || 'all'
      filterItems()
    })
  })

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      catBtns.forEach(b => {
        b.classList.remove('bg-gray-950', 'text-white', 'border-gray-950')
        b.classList.add('border-gray-200', 'text-gray-500')
      })
      btn.classList.add('bg-gray-950', 'text-white', 'border-gray-950')
      btn.classList.remove('border-gray-200', 'text-gray-500')
      activeCat = (btn as HTMLElement).dataset.cat || 'all'
      filterItems()
    })
  })
</script>