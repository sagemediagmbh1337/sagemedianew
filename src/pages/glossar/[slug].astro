---
import { getCollection, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import HeroPage from '../../components/HeroPage.astro'
import CtaSection from '../../components/CtaSection.astro'
import VideoLightbox from '../../components/VideoLightbox.astro'
import TrustLogos from '../../components/TrustLogos.astro'

export async function getStaticPaths() {
  const entries = await getCollection('lexikon')
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { title, category, description, related, author, ctas } = entry.data
const { Content } = await render(entry)

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Glossar', href: '/glossar' },
  { label: title }
]

const wordCount = entry.body?.split(/\s+/).length || 0
const readingTime = Math.max(1, Math.ceil(wordCount / 200))
---

<Layout title={title + " — SEO-Glossar | sagemedia"} description={description}>
  <Header />

  <main class="pt-18">

    <HeroPage
      eyebrow={category}
      titleLine1={title}
      titleLine2=""
      subtitle={description}
      ctaText="Erstgespräch vereinbaren"
      secondaryText="Zurück zum Glossar"
      secondaryHref="/glossar"
      breadcrumbs={breadcrumbs}
    >
      <div class="relative" slot="visual">
        <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>

        <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
              <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-wider">Definition</span>
            </div>
            <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">{category}</span>
          </div>

          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_24px_rgba(16,185,129,0.3)]">
              <span class="text-2xl font-extrabold text-white">{title[0]}</span>
            </div>
            <div>
              <p class="text-lg font-extrabold text-gray-900 tracking-tight">{title}</p>
              <p class="text-xs text-gray-400 mt-0.5">{category}</p>
            </div>
          </div>

          <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>

          <div class="grid grid-cols-3 gap-4">
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Kategorie</p>
              <p class="text-sm font-bold text-gray-900">{category}</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Verwandte</p>
              <p class="text-sm font-bold text-emerald-600">{related.length} Begriffe</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Lesezeit</p>
              <p class="text-sm font-bold text-gray-900">~{readingTime} Min.</p>
            </div>
          </div>
        </div>
      </div>

      <TrustLogos class="mt-16 hero-trust" slot="trust" />
    </HeroPage>

    <!-- Article Content -->
    <section class="relative py-24 md:py-36 overflow-hidden lexikon-article-bg">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
      <div class="absolute top-[10%] right-[5%] w-[500px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(16,185,129,0.05) 0%, transparent 60%);"></div>
      <div class="absolute bottom-[10%] left-[5%] w-[400px] h-[400px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(16,185,129,0.04) 0%, transparent 60%);"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-[1fr_280px] gap-12 lg:gap-14">

          <!-- Main Content -->
          <div class="min-w-0">
            <div class="fade-up">
              <!-- Section Title -->
              <div class="flex items-center gap-3 mb-8">
                <div class="w-10 h-10 rounded-xl bg-gray-950 flex items-center justify-center">
                  <span class="text-xl font-extrabold text-emerald-400 leading-none">/</span>
                </div>
                <div>
                  <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 tracking-tight">Was ist {title}?</h2>
                </div>
              </div>

              <!-- Markdown Content -->
              <div class="lexikon-content" data-ctas={JSON.stringify(ctas)}>
                <Content />
              </div>
            </div>

            <!-- Author Box -->
            {author && (
              <div class="mt-12 fade-up">
                <div class="lexikon-author">
                  <div class="flex flex-col sm:flex-row gap-5 items-start">
                    <div class="shrink-0">
                      {author.image ? (
                        <img src={author.image} alt={author.name} class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl object-cover shadow-[0_8px_24px_-4px_rgba(16,185,129,0.15)]" loading="lazy" />
                      ) : (
                        <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center">
                          <span class="text-xl font-extrabold text-white">{author.name.split(' ').map(n => n[0]).join('')}</span>
                        </div>
                      )}
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-mono font-medium uppercase tracking-[0.2em] text-emerald-600 mb-1.5">Geschrieben von</p>
                      <p class="text-sm font-bold text-gray-900 tracking-tight">{author.name}</p>
                      <p class="text-sm text-gray-500 mt-0.5">{author.role}</p>
                      {author.bio && (
                        <p class="text-sm text-gray-500 leading-relaxed mt-3">{author.bio}</p>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>

          <!-- Sidebar -->
          <div class="fade-up hidden lg:block">
            <div class="sticky top-24 space-y-4 max-h-[calc(100vh-7rem)] overflow-y-auto lexikon-sidebar">

              <!-- TOC -->
              <nav id="lexikon-toc" class="lexikon-sidebar-card" style="display:none;">
                <div class="lexikon-sidebar-header">
                  <svg class="w-3.5 h-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                  <span>Inhalt</span>
                </div>
                <ul id="toc-list" class="space-y-0">
                  <!-- Filled by JS -->
                </ul>
              </nav>

              <!-- Related Terms -->
              {related.length > 0 && (
                <div class="lexikon-sidebar-card">
                  <div class="lexikon-sidebar-header">
                    <svg class="w-3.5 h-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" /></svg>
                    <span>Verwandt</span>
                  </div>

                  <div class="space-y-0.5">
                    {related.map((r) => (
                      <a href={"/glossar/" + r.slug} class="lexikon-related-link group">
                        <span class="lexikon-related-letter">{r.term[0]}</span>
                        <span class="flex-1 truncate">{r.term}</span>
                        <svg class="w-3 h-3 text-gray-300 group-hover:text-emerald-500 transition-colors shrink-0 opacity-0 group-hover:opacity-100" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              <!-- Back -->
              <a href="/glossar" class="flex items-center gap-2 text-xs font-medium text-gray-400 hover:text-emerald-600 transition-colors group px-1 pt-1">
                <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 8H3m4-4L3 8l4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                Alle Begriffe
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <CtaSection
      title="SEO nicht nur verstehen,"
      titleAccent="sondern umsetzen?"
      subtitle="Wir machen die Theorie zur Praxis. In einem kostenlosen Erstgespräch zeigen wir dir, wie diese Konzepte konkret für dein Unternehmen funktionieren."
      ctaText="Erstgespräch vereinbaren"
    />

  </main>

  <Footer />
  <VideoLightbox />

  <script>
    function wrapLexikonSections() {
      const container = document.querySelector('.lexikon-content')
      if (!container) return

      const children = Array.from(container.childNodes)
      const sections: HTMLElement[] = []
      let currentSection: HTMLElement | null = null

      children.forEach(node => {
        if (node instanceof HTMLElement && node.tagName === 'H2') {
          if (currentSection) {
            sections.push(currentSection)
          }
          currentSection = document.createElement('div')
          currentSection.className = 'lexikon-section'
          currentSection.appendChild(node)
        } else if (currentSection) {
          currentSection.appendChild(node)
        } else {
          if (node instanceof HTMLElement || (node instanceof Text && node.textContent?.trim())) {
            if (!container.querySelector('.lexikon-intro')) {
              const intro = document.createElement('div')
              intro.className = 'lexikon-intro'
              container.insertBefore(intro, container.firstChild)
            }
            container.querySelector('.lexikon-intro')!.appendChild(node)
          }
        }
      })

      if (currentSection) {
        sections.push(currentSection)
      }

      sections.forEach(section => container.appendChild(section))

      // Inject inline CTAs
      const ctaData = container.getAttribute('data-ctas')
      if (ctaData) {
        const ctas = JSON.parse(ctaData) as { after_section: number; title: string; text: string; link_text: string; link_url: string }[]
        const allSections = container.querySelectorAll('.lexikon-section')
        ;[...ctas].sort((a, b) => b.after_section - a.after_section).forEach(cta => {
          const targetSection = allSections[cta.after_section - 1]
          if (!targetSection) return
          const ctaEl = document.createElement('div')
          ctaEl.className = 'lexikon-inline-cta'
          ctaEl.innerHTML = `
            <div class="lexikon-inline-cta-inner">
              <div class="lexikon-inline-cta-content">
                <p class="lexikon-inline-cta-title">${cta.title}</p>
                <p class="lexikon-inline-cta-text">${cta.text}</p>
              </div>
              <a href="${cta.link_url}" class="lexikon-inline-cta-btn">
                ${cta.link_text}
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </a>
            </div>
          `
          targetSection.after(ctaEl)
        })
      }
    }

    function makeTablesResponsive() {
      document.querySelectorAll('.lexikon-content table').forEach(table => {
        const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent?.trim() || '')
        table.querySelectorAll('tbody tr').forEach(row => {
          row.querySelectorAll('td').forEach((td, i) => {
            if (headers[i]) {
              td.setAttribute('data-label', headers[i])
            }
          })
        })
      })
    }

    function styleNumberedH3s() {
      document.querySelectorAll('.lexikon-content h3').forEach(h3 => {
        const text = h3.textContent || ''
        const match = text.match(/^(\d+)\.\s+(.+)$/)
        if (match) {
          const num = match[1]
          const label = match[2]
          h3.innerHTML = `<span class="lexikon-h3-num">${num}</span>${label}`
          h3.classList.add('lexikon-h3-numbered')
        }
      })
    }

    function buildTOC() {
      const tocList = document.getElementById('toc-list')
      const tocNav = document.getElementById('lexikon-toc')
      if (!tocList || !tocNav) return

      const headings = document.querySelectorAll('.lexikon-content h2')
      if (headings.length === 0) return

      headings.forEach((h2, i) => {
        const id = 'section-' + i
        h2.setAttribute('id', id)
        const li = document.createElement('li')
        const a = document.createElement('a')
        a.href = '#' + id
        a.textContent = h2.textContent || ''
        a.className = 'toc-link'
        a.dataset.target = id
        li.appendChild(a)
        tocList.appendChild(li)
      })

      tocNav.style.display = ''

      // Scroll spy
      const tocLinks = tocList.querySelectorAll('.toc-link') as NodeListOf<HTMLAnchorElement>
      // Set first as active by default
      if (tocLinks.length > 0) {
        tocLinks[0].classList.add('active')
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(link => link.classList.remove('active'))
            const activeLink = tocList.querySelector(`[data-target="${entry.target.id}"]`) as HTMLAnchorElement
            if (activeLink) {
              activeLink.classList.add('active')
            }
          }
        })
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 })

      headings.forEach(h2 => observer.observe(h2))
    }

    wrapLexikonSections()
    makeTablesResponsive()
    styleNumberedH3s()
    buildTOC()
  </script>
</Layout>
