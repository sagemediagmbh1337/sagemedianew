---
import { getCollection, render } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import CtaSection from '../../components/CtaSection.astro'
import VideoLightbox from '../../components/VideoLightbox.astro'

export async function getStaticPaths() {
  const entries = await getCollection('lexikon')
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { title, category, description, related, author } = entry.data
const { Content } = await render(entry)

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Glossar', href: '/glossar' },
  { label: title }
]

const wordCount = entry.body?.split(/\s+/).length || 0
const readingTime = Math.max(1, Math.ceil(wordCount / 200))
---

<Layout title={title + " — SEO-Glossar | sagemedia"} description={description}>
  <Header />

  <main class="pt-18">

    <!-- Glossar Article -->
    <section class="relative pt-32 pb-24 md:pt-44 md:pb-36">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(16,185,129,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(16,185,129,0.06)_1px,transparent_1px)] bg-[size:64px_64px]" style="mask-image: linear-gradient(to bottom, black 0%, transparent 600px); -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 600px);"></div>
      <!-- Recurring emerald glows -->
      <div class="absolute top-[5%] right-[5%] w-[700px] h-[700px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 40%, transparent 70%);"></div>
      <div class="absolute top-[5%] left-[15%] w-[300px] h-[300px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(6,78,59,0.06) 0%, transparent 60%);"></div>
      <div class="absolute top-[25%] right-[8%] w-[500px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(16,185,129,0.08) 0%, rgba(16,185,129,0.02) 50%, transparent 70%);"></div>
      <div class="absolute top-[45%] left-[-5%] w-[400px] h-[400px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(52,211,153,0.06) 0%, transparent 60%);"></div>
      <div class="absolute top-[60%] right-[3%] w-[600px] h-[600px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, rgba(16,185,129,0.02) 45%, transparent 70%);"></div>
      <div class="absolute top-[80%] left-[10%] w-[350px] h-[350px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(6,78,59,0.05) 0%, transparent 60%);"></div>
      <div class="absolute top-[90%] right-[10%] w-[500px] h-[500px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(52,211,153,0.06) 0%, transparent 65%);"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-[1fr_280px] gap-12 lg:gap-14">

          <!-- Left Column: Hero + Content -->
          <div class="min-w-0">
            <!-- Breadcrumbs -->
            <nav class="flex items-center gap-2 text-xs text-gray-400 mb-10" aria-label="Breadcrumb">
              {breadcrumbs.map((crumb, i) => (
                <>
                  {i > 0 && <span class="text-emerald-500 font-bold text-sm">/</span>}
                  {crumb.href ? (
                    <a href={crumb.href} class="hover:text-emerald-600 transition-colors">{crumb.label}</a>
                  ) : (
                    <span class="text-gray-600">{crumb.label}</span>
                  )}
                </>
              ))}
            </nav>

            <!-- Category + Meta -->
            <div class="flex flex-wrap items-center gap-3 mb-6">
              <span class="inline-flex items-center gap-2 text-xs font-medium text-emerald-600 bg-emerald-50 border border-emerald-100 px-3 py-1.5 rounded-full">
                {category}
              </span>
              <span class="text-xs text-gray-400">~{readingTime} Min. Lesezeit</span>
            </div>

            <!-- Title -->
            <h1 class="text-[clamp(2.25rem,6vw,6rem)] font-extrabold leading-[1.1] tracking-[-0.04em] text-gray-950 mb-6">
              {title}
            </h1>

            <!-- Description -->
            <p class="text-lg md:text-xl text-gray-500 leading-relaxed mb-10">
              {description}
            </p>

            <!-- Markdown Content -->

            <div class="lexikon-content">
              <Content />
            </div>

            <!-- Author Box -->
            {author && (
              <div class="mt-12">
                <div class="lexikon-author">
                  <div class="flex flex-col sm:flex-row gap-5 items-start">
                    <div class="shrink-0">
                      {author.image ? (
                        <img src={author.image} alt={author.name} class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl object-cover shadow-[0_8px_24px_-4px_rgba(16,185,129,0.15)]" loading="lazy" />
                      ) : (
                        <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center">
                          <span class="text-xl font-extrabold text-white">{author.name.split(' ').map(n => n[0]).join('')}</span>
                        </div>
                      )}
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-xs font-mono font-medium uppercase tracking-[0.2em] text-emerald-600 mb-1.5">Geschrieben von</p>
                      <p class="text-sm font-bold text-gray-900 tracking-tight">{author.name}</p>
                      <p class="text-sm text-gray-500 mt-0.5">{author.role}</p>
                      {author.bio && (
                        <p class="text-sm text-gray-500 leading-relaxed mt-3">{author.bio}</p>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>

          <!-- Sidebar -->
          <div class="hidden lg:block" id="glossar-sidebar">
            <div class="sticky top-24 space-y-4 max-h-[calc(100vh-7rem)] overflow-y-auto lexikon-sidebar">

              <!-- TOC -->
              <nav id="lexikon-toc" class="lexikon-sidebar-card" style="display:none;">
                <div class="lexikon-sidebar-header">
                  <svg class="w-3.5 h-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                  <span>Inhalt</span>
                </div>
                <ul id="toc-list" class="space-y-0">
                  <!-- Filled by JS -->
                </ul>
              </nav>

              <!-- Related Terms -->
              {related.length > 0 && (
                <div class="lexikon-sidebar-card">
                  <div class="lexikon-sidebar-header">
                    <svg class="w-3.5 h-3.5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" /><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" /></svg>
                    <span>Verwandt</span>
                  </div>

                  <div class="space-y-0.5">
                    {related.map((r) => (
                      <a href={"/glossar/" + r.slug} class="lexikon-related-link group">
                        <span class="lexikon-related-letter">{r.term[0]}</span>
                        <span class="flex-1 truncate">{r.term}</span>
                        <svg class="w-3 h-3 text-gray-300 group-hover:text-emerald-500 transition-colors shrink-0 opacity-0 group-hover:opacity-100" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              <!-- CTA Card -->
              <div class="bg-white rounded-2xl border border-gray-100 shadow-[0_8px_32px_rgba(0,0,0,0.04)] overflow-hidden">
                <div class="p-5">
                  <h4 class="text-base font-bold text-gray-900 tracking-tight">Noch Fragen?</h4>
                  <p class="mt-2 text-sm text-gray-500 leading-relaxed">
                    Sprich direkt mit unserem Team
                  </p>
                  <a href="/kontakt" class="group relative mt-4 w-full inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full text-sm font-semibold overflow-hidden transition-all duration-500 hover:shadow-[0_0_32px_rgba(16,185,129,0.3)]">
                    <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-emerald-500 transition-all duration-500 group-hover:from-emerald-500 group-hover:to-emerald-400"></div>
                    <div class="absolute inset-0 rounded-full shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"></div>
                    <span class="relative z-10 text-white">Erstgespräch vereinbaren</span>
                    <svg class="relative z-10 w-3.5 h-3.5 text-white group-hover:translate-x-1 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>

              <!-- Back -->
              <a href="/glossar" class="flex items-center gap-2 text-xs font-medium text-gray-400 hover:text-emerald-600 transition-colors group px-1 pt-1">
                <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 8H3m4-4L3 8l4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
                Alle Begriffe
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <CtaSection
      title="SEO nicht nur verstehen,"
      titleAccent="sondern umsetzen?"
      subtitle="Wir machen die Theorie zur Praxis. In einem kostenlosen Erstgespräch zeigen wir dir, wie diese Konzepte konkret für dein Unternehmen funktionieren."
      ctaText="Erstgespräch vereinbaren"
    />

  </main>

  <Footer />
  <VideoLightbox />

  <script>
    function wrapLexikonSections() {
      const container = document.querySelector('.lexikon-content')
      if (!container) return

      const children = Array.from(container.childNodes)
      const sections: HTMLElement[] = []
      let currentSection: HTMLElement | null = null

      const orphans: ChildNode[] = []

      children.forEach(node => {
        if (node instanceof HTMLElement && node.tagName === 'H2') {
          if (currentSection) {
            sections.push(currentSection)
          }
          currentSection = document.createElement('div')
          currentSection.className = 'lexikon-section'
          currentSection.appendChild(node)
        } else if (currentSection) {
          currentSection.appendChild(node)
        } else {
          orphans.push(node)
        }
      })

      orphans.forEach(node => node.remove())

      if (currentSection) {
        sections.push(currentSection)
      }

      sections.forEach(section => container.appendChild(section))
    }

    function makeTablesResponsive() {
      document.querySelectorAll('.lexikon-content table').forEach(table => {
        const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent?.trim() || '')
        table.querySelectorAll('tbody tr').forEach(row => {
          row.querySelectorAll('td').forEach((td, i) => {
            if (headers[i]) {
              td.setAttribute('data-label', headers[i])
            }
          })
        })
      })
    }

    function styleNumberedH3s() {
      document.querySelectorAll('.lexikon-content h3').forEach(h3 => {
        const text = h3.textContent || ''
        const match = text.match(/^(\d+)\.\s+(.+)$/)
        if (match) {
          const num = match[1]
          const label = match[2]
          h3.innerHTML = `<span class="lexikon-h3-num">${num}</span>${label}`
          h3.classList.add('lexikon-h3-numbered')
        }
      })
    }

    function buildTOC() {
      const tocList = document.getElementById('toc-list')
      const tocNav = document.getElementById('lexikon-toc')
      if (!tocList || !tocNav) return

      const headings = document.querySelectorAll('.lexikon-content h2')
      if (headings.length === 0) return

      headings.forEach((h2, i) => {
        const id = 'section-' + i
        h2.setAttribute('id', id)
        const li = document.createElement('li')
        const a = document.createElement('a')
        a.href = '#' + id
        a.textContent = h2.textContent || ''
        a.className = 'toc-link'
        a.dataset.target = id
        li.appendChild(a)
        tocList.appendChild(li)
      })

      tocNav.style.display = ''

      // Scroll spy
      const tocLinks = tocList.querySelectorAll('.toc-link') as NodeListOf<HTMLAnchorElement>
      // Set first as active by default
      if (tocLinks.length > 0) {
        tocLinks[0].classList.add('active')
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(link => link.classList.remove('active'))
            const activeLink = tocList.querySelector(`[data-target="${entry.target.id}"]`) as HTMLAnchorElement
            if (activeLink) {
              activeLink.classList.add('active')
            }
          }
        })
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 })

      headings.forEach(h2 => observer.observe(h2))
    }

    function alignSidebar() {
      const content = document.querySelector('.lexikon-content') as HTMLElement
      const sidebar = document.getElementById('glossar-sidebar')
      if (!content || !sidebar) return
      const contentTop = content.offsetTop
      const sidebarParentTop = sidebar.parentElement?.offsetTop || 0
      sidebar.style.paddingTop = (contentTop - sidebarParentTop) + 'px'
    }

    wrapLexikonSections()
    makeTablesResponsive()
    styleNumberedH3s()
    buildTOC()
    alignSidebar()
  </script>
</Layout>
