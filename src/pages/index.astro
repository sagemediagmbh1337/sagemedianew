---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import TrustLogos from '../components/TrustLogos.astro'
import ServicesGrid from '../components/ServicesGrid.astro'
import StatsStrip from '../components/StatsStrip.astro'
import Testimonials from '../components/Testimonials.astro'
import CtaSection from '../components/CtaSection.astro'
import VideoLightbox from '../components/VideoLightbox.astro'
import WhySagemedia from '../components/WhySagemedia.astro'
import FounderSection from '../components/FounderSection.astro'
import OrganicOvation from '../components/OrganicOvation.astro'
import PressMedia from '../components/PressMedia.astro'
import MagazinSlider from '../components/MagazinSlider.astro'
import AwardsStrip from '../components/AwardsStrip.astro'
import CaseStudies from '../components/CaseStudies.astro'
import { videoTestimonials, textReviews } from '../data/testimonials'
---

<Layout title="sagemedia GmbH, Premium SEO-Agentur aus Bad Staffelstein">
  <Header />

  <main class="pt-18">

    <!-- ══════ HERO ══════ -->
    <section class="relative overflow-hidden py-32 md:py-44" id="hero">
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(16,185,129,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(16,185,129,0.08)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
        <div class="absolute top-[10%] right-[5%] w-[700px] h-[700px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 40%, transparent 70%);"></div>
        <div class="absolute -bottom-[20%] -left-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.1) 0%, transparent 60%);"></div>
        <div class="absolute top-[5%] left-[15%] w-[300px] h-[300px] rounded-full" style="background: radial-gradient(circle, rgba(6,78,59,0.06) 0%, transparent 60%);"></div>
        <div class="absolute top-[60%] right-[30%] w-[250px] h-[250px] rounded-full" style="background: radial-gradient(circle, rgba(245,158,11,0.04) 0%, transparent 60%);"></div>
      </div>
      <div class="absolute inset-0 noise-bg pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-gray-50/80 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-6 items-center">
          <div class="lg:col-span-7 lg:pr-8">
            <div class="hero-eyebrow inline-flex items-center gap-2.5 mb-8">
              <span class="inline-block w-8 h-px bg-emerald-500"></span>
              <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Branchenexklusivität</span>
            </div>

            <h1 class="hero-title">
              <span class="block text-[clamp(2.25rem,6vw,6rem)] font-extrabold leading-[1.1] tracking-[-0.04em] text-gray-950">
                Deine Branche.
              </span>
              <span class="block text-[clamp(2.25rem,6vw,6rem)] font-extrabold leading-[1.1] tracking-[-0.04em] mt-1 bg-gradient-to-r from-emerald-600 via-emerald-500 to-emerald-400 bg-clip-text text-transparent gradient-shimmer">
                Dein Vorsprung.
              </span>
            </h1>

            <p class="hero-sub mt-8 text-lg md:text-xl text-gray-500 leading-relaxed max-w-lg">
              Wir betreuen nur einen Kunden pro Branche und Region. Dein SEO-Erfolg bleibt exklusiv, nicht verwässert.
            </p>

            <div class="hero-cta mt-10 flex flex-wrap items-center gap-5">
              <a href="/kontakt" class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-semibold overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(16,185,129,0.3)]">
                <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-emerald-500 transition-all duration-500 group-hover:from-emerald-500 group-hover:to-emerald-400"></div>
                <div class="absolute inset-0 rounded-full shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"></div>
                <span class="relative z-10 text-white">Verfügbarkeit prüfen</span>
                <svg class="relative z-10 w-4 h-4 text-white group-hover:translate-x-1 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
              <a href="/ergebnisse" class="group inline-flex items-center gap-2 text-gray-500 hover:text-emerald-600 font-medium transition-colors">
                Ergebnisse ansehen
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>

            <TrustLogos class="hero-trust mt-16" />
          </div>

          <!-- Dashboard Card -->
          <div class="lg:col-span-5 hero-visual">
            <div class="relative">
              <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>
              <div class="absolute -inset-6 rounded-[2rem] border border-emerald-500/10"></div>

              <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
                <div class="flex items-center justify-between mb-6">
                  <div class="flex items-center gap-3">
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)]"></div>
                    <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-wider">Live Dashboard</span>
                  </div>
                  <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">+648%</span>
                </div>

                <div class="flex items-end gap-[6px] h-36 mb-6" id="hero-chart">
                  {[18,22,19,28,35,45,58,72,68,82,91,100].map((h, i) => {
                    const bg = i < 4
                      ? '#e5e7eb'
                      : i < 7
                        ? 'linear-gradient(to top, #6ee7b7, #a7f3d0)'
                        : i < 9
                          ? 'linear-gradient(to top, #34d399, #6ee7b7)'
                          : 'linear-gradient(to top, #10b981, #34d399)'
                    return (
                      <div
                        class="flex-1 rounded-sm chart-bar transition-all duration-300"
                        style={`height: ${h}%; opacity: 0; background: ${bg};`}
                        data-delay={i * 80}
                      />
                    )
                  })}
                </div>

                <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>

                <div class="grid grid-cols-3 gap-6">
                  <div>
                    <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Keywords</p>
                    <p class="text-2xl font-extrabold text-gray-900 tracking-tight counter" data-target="1247">0</p>
                  </div>
                  <div>
                    <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">DR Score</p>
                    <p class="text-2xl font-extrabold text-gray-900 tracking-tight counter" data-target="89">0</p>
                  </div>
                  <div>
                    <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Wachstum</p>
                    <p class="text-2xl font-extrabold text-emerald-600 tracking-tight">
                      <span class="counter" data-target="648">0</span><span class="text-lg">%</span>
                    </p>
                  </div>
                </div>
              </div>

              <div class="absolute -bottom-5 -left-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3 hero-badge">
                <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_16px_rgba(16,185,129,0.4)]">
                  <svg class="w-4 h-4 text-white" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M2 8l4 4 8-8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold text-gray-900">Platz 1</p>
                  <p class="text-[10px] text-gray-400">SEO-Contest 2021</p>
                </div>
              </div>

              <div class="absolute -top-4 -right-4 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 hero-badge-2">
                <p class="text-xs font-bold text-gray-900">15+ Jahre</p>
                <p class="text-[10px] text-gray-400">SEO-Erfahrung</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════ SOCIAL PROOF ZAHLEN ══════ -->
    <StatsStrip stats={[
      { val: '15+', label: 'Jahre Erfahrung' },
      { val: '100k+', label: 'Rankings erzielt' },
      { val: '5.0', label: 'Google Bewertung' },
      { val: '1', label: 'Kunde pro Branche' },
    ]} />

    <!-- ══════ WARUM SAGEMEDIA ══════ -->
    <WhySagemedia />

    <!-- ══════ ÜBER DEN GRÜNDER ══════ -->
    <FounderSection />

    <!-- ══════ ORGANIC OVATION ══════ -->
    <OrganicOvation />

    <!-- ══════ LEISTUNGEN ══════ -->
    <ServicesGrid services={[
      { href: '/leistungen/seo', icon: 'search', title: 'Suchmaschinen-optimierung', desc: 'Technisches SEO, Content-Strategie und strategischer Linkaufbau, abgestimmt auf deine Branche und Region. Wir optimieren für Google und zunehmend auch für KI-basierte Suchsysteme. Datengetrieben mit Google Search Console, Ahrefs und eigenen Analyse-Tools.' },
      { href: '/leistungen/geo-aio-llmo', icon: 'bulb', title: 'GEO / AIO / LLMO', desc: 'Generative Engine Optimization für ChatGPT, Perplexity und Google AI Overviews. Wir sorgen dafür, dass KI-Systeme dein Unternehmen als vertrauenswürdige Quelle erkennen und in ihren Antworten empfehlen. Die nächste Stufe der Suchmaschinenoptimierung.' },
      { href: '/leistungen/google-stellenanzeigen', icon: 'people', title: 'Google Stellenanzeigen', desc: 'Google for Jobs Integration und KI-optimierte Karriereseiten mit strukturierten Daten (JobPosting Schema). Deine Stellenanzeigen erscheinen direkt in der Google-Suche, dort, wo Kandidaten aktiv suchen, nicht auf überladenen Jobbörsen.' },
    ]} />

    <!-- ══════ ERGEBNISSE ══════ -->
    <CaseStudies cases={[
      { ytId: '2wpHWuAU8Zc', title: 'Energieversum: 100+ Leads/Monat', metric: '44.362', metricLabel: 'Org. Traffic', industry: 'Photovoltaik' },
      { ytId: '4nF2yb1rAzU', title: 'Beamtenberater: 88.586 Klicks/Monat', metric: '15.238', metricLabel: 'Keywords', industry: 'Versicherung' },
      { ytId: 'mTW5nOlHcpo', title: 'Cherry-Bikes: 470 Conversions/Monat', metric: '9.303', metricLabel: 'Keywords', industry: 'E-Commerce' },
      { ytId: 'S8fPqe5PWbQ', title: 'Iris Haag: +5.000% Traffic-Wachstum', metric: '+5.000%', metricLabel: 'Traffic', industry: 'Coaching' },
    ]} />

    <!-- ══════ STATS ══════ -->
    <StatsStrip stats={[
      { val: '100k+', label: 'Rankings erzielt' },
      { val: '648%', label: 'Ø Traffic-Wachstum' },
      { val: '24+', label: 'Monate Kundenbindung' },
      { val: '1', label: 'Kunde pro Branche' },
    ]} />

    <!-- ══════ KUNDENSTIMMEN ══════ -->
    <Testimonials videos={videoTestimonials} reviews={textReviews} />

    <!-- ══════ PRESSE & MEDIEN ══════ -->
    <PressMedia />

    <!-- ══════ MAGAZIN ══════ -->
    <MagazinSlider />

    <!-- ══════ AUSZEICHNUNGEN ══════ -->
    <AwardsStrip />

    <!-- ══════ CTA ══════ -->
    <CtaSection
      title="Bereit für nachhaltige"
      titleAccent="Sichtbarkeit?"
      subtitle="Prüfe jetzt, ob deine Branche noch verfügbar ist. Kein Pitch, nur ein ehrliches Gespräch."
      ctaText="Jetzt Kontakt aufnehmen"
    />

  </main>

  <Footer />
  <VideoLightbox />

  <!-- Hero-specific animations -->
  <script>
    // Chart bars
    setTimeout(() => {
      document.querySelectorAll('.chart-bar').forEach(bar => {
        const delay = parseInt(bar.getAttribute('data-delay') || '0')
        setTimeout(() => bar.classList.add('animate'), delay)
      })
    }, 600)

    // Counter animation
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const counter = entry.target as HTMLElement
          const target = parseInt(counter.getAttribute('data-target') || '0')
          const duration = 1500
          const start = performance.now()

          function update(now: number) {
            const elapsed = now - start
            const progress = Math.min(elapsed / duration, 1)
            const eased = 1 - Math.pow(1 - progress, 3)
            const val = Math.floor(eased * target)
            counter.textContent = counter.getAttribute('data-no-format') ? val.toString() : val.toLocaleString('de-DE')
            if (progress < 1) requestAnimationFrame(update)
          }

          requestAnimationFrame(update)
          counterObserver.unobserve(counter)
        }
      })
    }, { threshold: 0.5 })

    document.querySelectorAll('.counter').forEach(el => counterObserver.observe(el))
  </script>
</Layout>
