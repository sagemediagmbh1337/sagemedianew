---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import TrustLogos from '../components/TrustLogos.astro'
import ServicesGrid from '../components/ServicesGrid.astro'
---

<Layout title="sagemedia GmbH, Premium SEO-Agentur aus Bad Staffelstein">
  <Header />

  <main class="pt-18">

    <!-- ════════════════════════════════════════════
         HERO
    ════════════════════════════════════════════ -->
    <section class="relative overflow-hidden py-32 md:py-44" id="hero">
      <!-- Background layers -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-[linear-gradient(rgba(16,185,129,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(16,185,129,0.08)_1px,transparent_1px)] bg-[size:64px_64px]"></div>
        <div class="absolute top-[10%] right-[5%] w-[700px] h-[700px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 40%, transparent 70%);"></div>
        <div class="absolute -bottom-[20%] -left-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.1) 0%, transparent 60%);"></div>
        <div class="absolute top-[5%] left-[15%] w-[300px] h-[300px] rounded-full" style="background: radial-gradient(circle, rgba(6,78,59,0.06) 0%, transparent 60%);"></div>
        <div class="absolute top-[60%] right-[30%] w-[250px] h-[250px] rounded-full" style="background: radial-gradient(circle, rgba(245,158,11,0.04) 0%, transparent 60%);"></div>
      </div>
      <div class="absolute inset-0 noise-bg pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-gray-50/80 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-12 gap-8 lg:gap-6 items-center">
          <!-- Text -->
          <div class="lg:col-span-7 lg:pr-8">
            <div class="hero-eyebrow inline-flex items-center gap-2.5 mb-8">
              <span class="inline-block w-8 h-px bg-emerald-500"></span>
              <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Branchenexklusivität</span>
            </div>

            <h1 class="hero-title">
              <span class="block text-[clamp(3rem,7vw,6rem)] font-extrabold leading-[1.1] tracking-[-0.04em] text-gray-950">
                Deine Branche.
              </span>
              <span class="block text-[clamp(3rem,7vw,6rem)] font-extrabold leading-[1.1] tracking-[-0.04em] mt-1 bg-gradient-to-r from-emerald-600 via-emerald-500 to-emerald-400 bg-clip-text text-transparent gradient-shimmer">
                Dein Vorsprung.
              </span>
            </h1>

            <p class="hero-sub mt-8 text-lg md:text-xl text-gray-500 leading-relaxed max-w-lg">
              Wir betreuen nur einen Kunden pro Branche und Region. Dein SEO-Erfolg bleibt exklusiv, nicht verwässert.
            </p>

            <div class="hero-cta mt-10 flex flex-wrap items-center gap-5">
              <a href="/kontakt" class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-semibold overflow-hidden transition-all duration-500 hover:shadow-[0_0_40px_rgba(16,185,129,0.3)]">
                <div class="absolute inset-0 bg-gradient-to-r from-emerald-600 to-emerald-500 transition-all duration-500 group-hover:from-emerald-500 group-hover:to-emerald-400"></div>
                <div class="absolute inset-0 rounded-full shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]"></div>
                <span class="relative z-10 text-white">Verfügbarkeit prüfen</span>
                <svg class="relative z-10 w-4 h-4 text-white group-hover:translate-x-1 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
              <a href="/ergebnisse" class="group inline-flex items-center gap-2 text-gray-500 hover:text-emerald-600 font-medium transition-colors">
                Ergebnisse ansehen
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>

            <TrustLogos class="hero-trust mt-16" />
          </div>

          <!-- Dashboard Card -->
          <div class="lg:col-span-5 hero-visual">
            <div class="relative">
              <div class="absolute -inset-12 rounded-[3rem]" style="background: radial-gradient(ellipse at center, rgba(16,185,129,0.15) 0%, rgba(16,185,129,0.05) 50%, transparent 70%);"></div>
              <div class="absolute -inset-6 rounded-[2rem] border border-emerald-500/10 animate-pulse"></div>

              <div class="relative bg-white/70 backdrop-blur-2xl rounded-[1.25rem] border border-white/80 shadow-[0_32px_80px_-16px_rgba(16,185,129,0.15),0_0_0_1px_rgba(0,0,0,0.04)] p-7">
                <!-- Header -->
                <div class="flex items-center justify-between mb-6">
                  <div class="flex items-center gap-3">
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)] animate-pulse"></div>
                    <span class="text-xs font-mono font-medium text-gray-400 uppercase tracking-wider">Live Dashboard</span>
                  </div>
                  <span class="text-[10px] font-mono text-emerald-600 font-semibold bg-emerald-50 px-2.5 py-1 rounded-full border border-emerald-100">+648%</span>
                </div>

                <!-- Chart -->
                <div class="flex items-end gap-[6px] h-36 mb-6" id="hero-chart">
                  {[18,22,19,28,35,45,58,72,68,82,91,100].map((h, i) => {
                    const isGray = i < 4
                    const bg = isGray
                      ? '#e5e7eb'
                      : i < 7
                        ? 'linear-gradient(to top, #6ee7b7, #a7f3d0)'
                        : i < 9
                          ? 'linear-gradient(to top, #34d399, #6ee7b7)'
                          : 'linear-gradient(to top, #10b981, #34d399)'
                    return (
                      <div
                        class="flex-1 rounded-sm chart-bar transition-all duration-300"
                        style={`height: ${h}%; opacity: 0; background: ${bg};`}
                        data-delay={i * 80}
                      />
                    )
                  })}
                </div>

                <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent mb-6"></div>

                <!-- Stats -->
                <div class="grid grid-cols-3 gap-6">
                  <div>
                    <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Keywords</p>
                    <p class="text-2xl font-extrabold text-gray-900 tracking-tight counter" data-target="1247">0</p>
                  </div>
                  <div>
                    <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">DR Score</p>
                    <p class="text-2xl font-extrabold text-gray-900 tracking-tight counter" data-target="89">0</p>
                  </div>
                  <div>
                    <p class="text-[10px] font-mono uppercase tracking-wider text-gray-400 mb-1">Wachstum</p>
                    <p class="text-2xl font-extrabold text-emerald-600 tracking-tight">
                      <span class="counter" data-target="648">0</span><span class="text-lg">%</span>
                    </p>
                  </div>
                </div>
              </div>

              <!-- Floating badges -->
              <div class="absolute -bottom-5 -left-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3 hero-badge">
                <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_0_16px_rgba(16,185,129,0.4)]">
                  <svg class="w-4 h-4 text-white" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M2 8l4 4 8-8" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold text-gray-900">Platz 1</p>
                  <p class="text-[10px] text-gray-400">SEO-Contest 2021</p>
                </div>
              </div>

              <div class="absolute -top-4 -right-4 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 hero-badge-2">
                <p class="text-xs font-bold text-gray-900">15+ Jahre</p>
                <p class="text-[10px] text-gray-400">SEO-Erfahrung</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════
         SOCIAL PROOF ZAHLEN
    ════════════════════════════════════════════ -->
    <section class="relative py-20 md:py-24 bg-gray-950 text-white overflow-hidden noise-bg">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/40 to-transparent divider-glow"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-emerald-500/20 to-transparent"></div>
      <div class="absolute top-[20%] left-[10%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.1) 0%, transparent 60%);"></div>
      <div class="absolute bottom-[10%] right-[15%] w-[300px] h-[300px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.06) 0%, transparent 60%);"></div>

      <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-10 md:gap-16">
          {[
            { value: '15+', accent: '', label: 'Jahre Erfahrung', sub: 'Seit 2009 im SEO' },
            { value: '100k', accent: '+', label: 'Rankings erzielt', sub: 'Google, Bing & KI-Suche' },
            { value: '5.0', accent: '', label: 'Google Bewertung', sub: 'Durchschnitt aller Reviews' },
            { value: '1', accent: '', label: 'Kunde pro Branche', sub: 'Exklusivität garantiert' },
          ].map((s, i) => (
            <div class="relative text-center fade-up">
              {i > 0 && <div class="hidden md:block absolute -left-8 top-1/2 -translate-y-1/2 h-16 w-px bg-gradient-to-b from-transparent via-white/10 to-transparent"></div>}
              <div class="flex items-baseline justify-center gap-0.5">
                <span class="text-5xl md:text-6xl font-extrabold tracking-tight text-white">{s.value}</span>
                {s.accent && <span class="text-3xl font-extrabold bg-gradient-to-r from-emerald-300 to-emerald-500 bg-clip-text text-transparent">{s.accent}</span>}
              </div>
              <p class="mt-3 text-sm font-semibold text-white/80">{s.label}</p>
              <p class="mt-1 text-xs text-gray-500">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════
         WARUM SAGEMEDIA
    ════════════════════════════════════════════ -->
    <section class="relative py-32 md:py-44 bg-gray-50/80" id="warum-sagemedia">
      <div class="absolute top-[20%] -left-[10%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 60%);"></div>
      <div class="absolute bottom-[10%] right-[5%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(circle, rgba(52,211,153,0.05) 0%, transparent 60%);"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-12 gap-16 lg:gap-8 items-start">
          <!-- Content -->
          <div class="lg:col-span-6 lg:pr-8">
            <div class="flex items-center gap-3 mb-6 fade-up">
              <span class="inline-block w-8 h-px bg-emerald-500"></span>
              <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Dein Vorteil</span>
            </div>

            <h2 class="text-4xl md:text-5xl lg:text-[3.5rem] font-extrabold leading-[1.05] tracking-[-0.04em] text-gray-950 fade-up">
              Warum sagemedia
              <span class="bg-gradient-to-r from-emerald-600 to-emerald-400 bg-clip-text text-transparent"> als Partner?</span>
            </h2>

            <div class="mt-14 space-y-10">
              {[
                {
                  num: '01',
                  title: 'Branchenexklusivität statt Interessenkonflikte.',
                  text: 'Die meisten SEO-Agenturen betreuen mehrere Unternehmen derselben Branche, oft in derselben Stadt. Das bedeutet: Deine Agentur optimiert gleichzeitig für deinen direkten Wettbewerber. Bei sagemedia ist das ausgeschlossen. Wir arbeiten pro Branche und Region mit genau einem Unternehmen. So bleibt deine SEO-Strategie exklusiv und dein Wettbewerbsvorteil geschützt.'
                },
                {
                  num: '02',
                  title: 'Vorbereitet auf die nächste Generation der Suche.',
                  text: 'Google ist nicht mehr der einzige Kanal, über den Kunden dich finden. ChatGPT, Perplexity, Google AI Overviews und andere KI-Systeme verändern grundlegend, wie Menschen nach Produkten und Dienstleistungen suchen. Wir optimieren deine Sichtbarkeit bereits heute für diese Kanäle, mit Generative Engine Optimization (GEO), AI Overview Optimization (AIO) und Large Language Model Optimization (LLMO).'
                },
                {
                  num: '03',
                  title: 'Messbare Ergebnisse statt Marketing-Versprechen.',
                  text: 'Jede SEO-Maßnahme, die wir umsetzen, ist an konkrete KPIs gebunden: organischer Traffic, Keyword-Rankings, Conversion-Raten, Umsatz. Du bekommst kein Pitchdeck mit Prognosen, sondern ein Dashboard mit Echtzeitdaten. Unsere durchschnittliche Kundenbindung liegt bei über 24 Monaten, weil die Ergebnisse für sich sprechen.'
                },
              ].map((item) => (
                <div class="group fade-up">
                  <div class="flex items-start gap-5">
                    <span class="shrink-0 text-xs font-mono font-medium text-emerald-400 mt-1.5 tracking-wider">{item.num}</span>
                    <div>
                      <h3 class="text-xl font-bold text-gray-900 tracking-tight">{item.title}</h3>
                      <p class="mt-2.5 text-gray-500 leading-relaxed">{item.text}</p>
                    </div>
                  </div>
                  <div class="mt-5 ml-10 h-px bg-gradient-to-r from-gray-200 via-emerald-200/30 to-transparent"></div>
                </div>
              ))}
            </div>

            <div class="mt-12 fade-up">
              <a href="/kontakt" class="group inline-flex items-center gap-3 text-gray-900 font-semibold hover:text-emerald-600 transition-colors">
                <span class="w-12 h-12 rounded-full border-2 border-gray-900 group-hover:border-emerald-500 group-hover:bg-emerald-500 group-hover:shadow-[0_0_24px_rgba(16,185,129,0.4)] flex items-center justify-center transition-all duration-300">
                  <svg class="w-4 h-4 group-hover:text-white transition-colors" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 8h10m-4-4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                Ist deine Branche noch frei?
              </a>
            </div>
          </div>

          <!-- Visual -->
          <div class="lg:col-span-6 fade-up">
            <div class="relative lg:pl-8">
              <div class="absolute -inset-8 rounded-[2rem]" style="background: radial-gradient(ellipse at 60% 40%, rgba(16,185,129,0.12) 0%, rgba(16,185,129,0.04) 50%, transparent 70%);"></div>
              <div class="relative aspect-[4/3] bg-gray-100 rounded-[1.5rem] overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,0,0,0.15)]">
                <img src="/images/sagemedia-buero.jpg" alt="sagemedia Agentur, Bad Staffelstein" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-gray-950/30 to-transparent"></div>
                <div class="absolute bottom-4 left-5">
                  <p class="text-xs font-medium text-white/70">sagemedia HQ, Bad Staffelstein</p>
                </div>
              </div>

              <!-- Floating badges -->
              <div class="absolute -bottom-5 -left-4 lg:left-2 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 px-4 py-3 flex items-center gap-3 fade-up z-10">
                <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_4px_16px_rgba(16,185,129,0.35)]">
                  <span class="text-white text-sm font-extrabold">15</span>
                </div>
                <div>
                  <p class="text-xs font-bold text-gray-900">Jahre SEO-Erfahrung</p>
                  <p class="text-[10px] text-gray-400">USA, Kanada, Deutschland</p>
                </div>
              </div>

              <div class="absolute -top-3 -right-3 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(245,158,11,0.1)] border border-amber-100/50 px-4 py-3 fade-up z-10">
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  <div>
                    <p class="text-xs font-bold text-gray-900">Platz 1</p>
                    <p class="text-[10px] text-gray-400">SEO-Contest '21</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════════════════════════════════════
         ÜBER DEN GRÜNDER
    ════════════════════════════════════════════ -->
    <section class="relative py-32 md:py-44 overflow-hidden">
      <div class="absolute top-[15%] right-[5%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200/60 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 relative">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <!-- Portrait -->
          <div class="lg:col-span-5 fade-up">
            <div class="relative">
              <div class="absolute -inset-6 rounded-[2rem]" style="background: radial-gradient(ellipse at 50% 50%, rgba(16,185,129,0.1) 0%, transparent 65%);"></div>
              <div class="relative aspect-[3/4] bg-gray-100 rounded-[1.5rem] overflow-hidden shadow-[0_32px_64px_-16px_rgba(0,0,0,0.1)]">
                <img src="/images/andre-schaefer-stage.jpg" alt="André Schäfer" class="absolute inset-0 w-full h-full object-cover object-[center_20%]" loading="lazy" />
                <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-gray-900/30 to-transparent"></div>
              </div>

              <div class="absolute -bottom-5 -right-5 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] border border-gray-100 p-4 fade-up">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center shadow-[0_4px_16px_rgba(16,185,129,0.35)]">
                    <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><path d="M22 4L12 14.01l-3-3" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-gray-900">15+ Jahre SEO</p>
                    <p class="text-[10px] text-gray-400">Seit 2021 hauptberuflich</p>
                  </div>
                </div>
              </div>

              <div class="absolute -top-3 -left-3 bg-white/90 backdrop-blur-xl rounded-xl shadow-[0_8px_32px_rgba(245,158,11,0.08)] border border-amber-100/50 px-4 py-3 fade-up">
                <div class="flex items-center gap-2">
                  <svg class="w-5 h-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                  <div>
                    <p class="text-xs font-bold text-gray-900">Platz 1</p>
                    <p class="text-[10px] text-gray-400">SEO-Contest 2021</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class="lg:col-span-7">
            <div class="flex items-center gap-3 mb-6 fade-up">
              <span class="inline-block w-8 h-px bg-emerald-500"></span>
              <span class="text-xs font-mono font-medium text-emerald-600 uppercase tracking-[0.2em]">Über den Gründer</span>
            </div>

            <h2 class="text-4xl md:text-5xl font-extrabold leading-[1.1] tracking-[-0.04em] text-gray-950 fade-up">André Schäfer</h2>
            <p class="mt-1 text-lg font-mono text-emerald-600 fade-up">Geschäftsführer & SEO-Stratege</p>

            <div class="mt-8 text-gray-600 leading-[1.85] space-y-4 fade-up">
              <p>André beschäftigt sich seit 2009 mit Suchmaschinenoptimierung, zunächst aus Neugier, dann aus Überzeugung. Was als Experiment mit Affiliate-Projekten begann, wurde schnell zur Berufung: die Mechanik hinter Google, Crawlern und Rankings wirklich zu verstehen. Nicht oberflächlich, sondern auf technischer und semantischer Ebene.</p>
